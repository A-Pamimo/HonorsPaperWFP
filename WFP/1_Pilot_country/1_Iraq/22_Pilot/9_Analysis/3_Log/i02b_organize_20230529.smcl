{com}.         di `cdate'
{res}20230529
{txt}
{com}.         
.         * load dataset
.         use "${c -(}dta{c )-}/Iraq_RM_Household_Raw.dta", clear 
{txt}
{com}.         
.         gen     Status = 1 if (ADMIN5Name == 1 | ADMIN5Name == 5 | ADMIN5Name == 10) 
{txt}(268 missing values generated)

{com}.         replace Status = 2 if (ADMIN5Name == 2 | ADMIN5Name == 3) 
{txt}(268 real changes made)

{com}.         
. ** Demongraphics and basic respondents/household information
. 
.         gen RESPHHH     = (RESPRelationHHH              == 100)
{txt}
{com}.         gen RESPFemale  = (RESPSex                              == 0)
{txt}
{com}.         
.         gl var_demo RESPAge RESPSex RESPFemale RESPHHH HHSize
{txt}
{com}. 
. ** Outcome: [FCS] Food consumption score 
.         sum FCS*

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
{space 5}FCSStap {c |}{res}        540    5.866667    1.951357          0          7
{txt}{space 4}FCSPulse {c |}{res}        540    2.762963    1.929009          0          7
{txt}{space 4}FCSDairy {c |}{res}        540    5.003704    2.641187          0          7
{txt}{space 7}FCSPr {c |}{res}        540    1.074074    1.125713          0          7
{txt}{space 6}FCSVeg {c |}{res}        540    4.187037    2.454827          0          7
{txt}{hline 13}{c +}{hline 57}
{space 4}FCSFruit {c |}{res}        540        1.75    2.038247          0          7
{txt}{space 6}FCSFat {c |}{res}        540    6.753704    .9200333          0          7
{txt}{space 4}FCSSugar {c |}{res}        540    4.837037    3.068077          0          7
{txt}
{com}.         
.         gen FCS = FCSStap * 2 + FCSPulse * 3 + FCSDairy * 4 + FCSPr * 4 +                ///
>                           FCSVeg  * 1 + FCSFruit * 1 + FCSFat * 0.5 + FCSSugar * 0.5
{txt}
{com}.         gen FCSCat28 = cond(FCS <= 28, 1, cond(FCS <= 42, 2, 3))
{txt}
{com}.         
.         gen     FCG = 1 if (FCSCat28 == 1 | FCSCat28 == 2)
{txt}(416 missing values generated)

{com}.         replace FCG = 2 if (FCSCat28 == 3)
{txt}(416 real changes made)

{com}.         
.         gl  out_fcs FCSStap FCSPulse FCSDairy FCSPr FCSVeg FCSFruit FCSFat               ///
>                                 FCSSugar FCS FCSCat28 FCG 
{txt}
{com}. 
. ** Outcome: [rCSI] Reduced Coping Strategies (rCSI - Gendered)
. 
.         gen rCSI         = rCSILessQlty * 1 + rCSIBorrow * 2 + rCSIMealNb * 1 +         ///
>                                    rCSIMealSize * 1 + rCSIMealAdult * 3
{txt}
{com}.         
.         gl out_rcsi rCSILessQlty rCSIBorrow rCSIMealSize rCSIGenderMealSize rCSIMealAdult    ///
>                                 rCSIGenderMealAdult rCSIMealNb rCSIGenderMealNb rCSI 
{txt}
{com}.         
. ** LCS 
.         ren LcsEN_em_ChildWork Lcs_em_ChildWork
{res}{txt}
{com}.         gen Lcs_Stress_Coping    = (Lcs_stress_DomAsset   == 20 | Lcs_stress_DomAsset   == 30 | ///
>                                                                 Lcs_stress_CrdtFood   == 20 | Lcs_stress_CrdtFood   == 30 | ///
>                                                                 Lcs_stress_Saving     == 20 | Lcs_stress_Saving     == 30 | ///
>                                                                 Lcs_stress_BorrowCash == 20 | Lcs_stress_BorrowCash == 30 )
{txt}
{com}.         gen Lcs_Crisis_Coping    = (Lcs_crisis_ProdAssets == 20 | Lcs_crisis_ProdAssets == 30 | ///
>                                                                 Lcs_crisis_HealthEdu  == 20 | Lcs_crisis_HealthEdu  == 30 | ///
>                                                                 Lcs_crisis_OutSchool  == 20 | Lcs_crisis_OutSchool  == 30 )                     
{txt}
{com}.         gen Lcs_Emergency_Coping = (Lcs_em_ChildWork  == 20 | Lcs_em_ChildWork  == 30 | ///
>                                                                 Lcs_em_Begged     == 20 | Lcs_em_Begged     == 30 | ///
>                                                                 Lcs_em_IllegalAct == 20 | Lcs_em_IllegalAct == 30 )
{txt}
{com}.                                                                 
.         gen     LCS_Cat = 1
{txt}
{com}.         replace LCS_Cat = 2 if Lcs_Stress_Coping == 1
{txt}(485 real changes made)

{com}.         replace LCS_Cat = 3 if Lcs_Crisis_Coping == 1 
{txt}(332 real changes made)

{com}.         replace LCS_Cat = 4 if Lcs_Emergency_Coping == 1
{txt}(147 real changes made)

{com}.         
.         gl  out_lcs  Lcs_Stress_Coping Lcs_Crisis_Coping Lcs_Emergency_Coping LCS_Cat
{txt}
{com}.         
. ** Economic vulnerability: Income
.         
.         ** One additional group 9 High risk activity (e.g. begging, scavenging) became 2 options in HHIncFirst_SRi - need to recode or change the values
.         recode HHIncFirst_SRi (10 = 9)(11 = 10)(12 = 11)(13 = 12)(14 = 13)(15 = 14) ///
>                                                   (16 = 15), gen(HHIncFirst_SRi_C)
{txt}(70 differences between {bf:HHIncFirst_SRi} and {bf:HHIncFirst_SRi_C})

{com}.         order HHIncFirst_SRi_C, a(HHIncFirst_SRi)
{txt}
{com}.         drop  HHIncFirst_SRi
{txt}
{com}.         ren       HHIncFirst_SRi_C HHIncFirst_SRi
{res}{txt}
{com}.         
.         tab HHIncFirst_Oth

                                {txt}Specify {c |}      Freq.     Percent        Cum.
{hline 40}{c +}{hline 35}
                  راتب رعاية الاجتماعيه {c |}{res}          1        8.33        8.33
{txt}                              سائق تكسي {c |}{res}          2       16.67       25.00
{txt}                           عاطل على عمل {c |}{res}          2       16.67       41.67
{txt}            عاطل على عمل  لم يقدر العلم {c |}{res}          1        8.33       50.00
{txt}           عاطل على عمل ولم يعمل أي عمل {c |}{res}          1        8.33       58.33
{txt}                        عربانه بيع مواد {c |}{res}          1        8.33       66.67
{txt}                            لا أحد يعمل {c |}{res}          3       25.00       91.67
{txt}                                  متطوع {c |}{res}          1        8.33      100.00
{txt}{hline 40}{c +}{hline 35}
                                  Total {c |}{res}         12      100.00
{txt}
{com}.         replace HHIncFirst_SRi = 7 if HHIncFirst_Oth == "راتب رعاية الاجتماعيه" 
{txt}(1 real change made)

{com}.         // Social Welfare Salary as aid/gift
.         replace HHIncFirst_SRi = 2 if HHIncFirst_Oth == "سائق تكسي"
{txt}(2 real changes made)

{com}.         // Taxi driver as Wage Labor - Skilled
.         replace HHIncFirst_SRi = 11 if HHIncFirst_Oth == "عربانه بيع مواد"
{txt}(1 real change made)

{com}.         // Cart selling materials as petty trade/selling on streets
.         
.         gen CARI_Inc = .
{txt}(540 missing values generated)

{com}.         replace CARI_Inc = 1 if inlist(HHIncFirst_SRi, 1, 2, 5, 12, 13, 15) & inlist(HHIncChg, 0, 1, 5)
{txt}(55 real changes made)

{com}.         replace CARI_Inc = 2 if inlist(HHIncFirst_SRi, 1, 2, 5, 12, 13, 15) & inlist(HHIncChg, 2, 3, 4)
{txt}(59 real changes made)

{com}.         replace CARI_Inc = 2 if inlist(HHIncFirst_SRi, 3, 4, 6, 11) & inlist(HHIncChg, 0, 1, 5)
{txt}(129 real changes made)

{com}.         replace CARI_Inc = 3 if inlist(HHIncFirst_SRi, 3, 4, 6, 11) & inlist(HHIncChg, 2, 3, 4)
{txt}(145 real changes made)

{com}.         replace CARI_Inc = 4 if HHIncNb == 0 | inlist(HHIncFirst_SRi, 7, 8, 9, 10)
{txt}(151 real changes made)

{com}.         replace CARI_Inc = 5 if HHIncFirst_SRi == 999
{txt}(8 real changes made)

{com}.         * Recode missing values
.         replace CARI_Inc = . if CARI_Inc == 5
{txt}(8 real changes made, 8 to missing)

{com}.         
.         replace CARI_Inc = 4 if HHIncFirst_Oth == "عاطل على عمل" | ///
>                         HHIncFirst_Oth == "عاطل على عمل  لم يقدر العلم"  | ///
>                         HHIncFirst_Oth == "عاطل على عمل ولم يعمل أي عمل" | ///
>                         HHIncFirst_Oth == "لا أحد يعمل"
{txt}(7 real changes made)

{com}.         // unemployed or nobody works
.                 
. ** Outcome: [CARI] COMBINING CURRENT STATUS AND COPING CAPACITY
.         recode  FCSCat28 (1 = 4) (2 = 3) (3 = 1), gen(FCS_4pt_CARI)
{txt}(540 differences between {bf:FCSCat28} and {bf:FCS_4pt_CARI})

{com}.         replace FCS_4pt_CARI = 2 if FCSCat28 == 3 & rCSI >= 4
{txt}(310 real changes made)

{com}.         
.         gen CC_Inc_Cat   = (CARI_Inc + LCS_Cat)/2       // no round here
{txt}(1 missing value generated)

{com}.         gen CARI_Inc_Raw = (FCS_4pt_CARI + CC_Inc_Cat)/2
{txt}(1 missing value generated)

{com}.         gen CARI_Inc_Cat = round(CARI_Inc_Raw)
{txt}(1 missing value generated)

{com}.         
.         gen HH_Vul_CARI  = (CARI_Inc_Cat == 3 | CARI_Inc_Cat == 4)
{txt}
{com}. 
.         gl out_cari FCS_4pt_CARI CC_Inc_Cat CARI_Inc_Cat HH_Vul_CARI
{txt}
{com}.         
. ** Outcome: [FES] Food Expenditure Share
. 
.         * 7 days food purchase in cash/credit 
. egen HHExp_Food_Purch_MN_7D = rowtotal(HHExpStap_MNCRD_7D HHExpPro_MNCRD_7D HHExpFruVeg_MNCRD_7D ///
>          HHExpFOther_MNCRD_7D HHExpF_MNCRD_7D)
{txt}
{com}.         
.         * 7 days food gift/aid value
. egen HHExp_Food_GiftAid_MN_7D = rowtotal(HHExpStap_GiftAid_7D HHExpPro_GiftAid_7D ///
>          HHExpFruVeg_GiftAid_7D HHExpFOther_GiftAid_7D HHExpF_GiftAid_7D)
{txt}
{com}. 
.         * 7 days food own-production value
. egen HHExp_Food_Own_MN_7D = rowtotal(HHExpStap_Own_7D HHExpPro_Own_7D HHExpFruVeg_Own_7D  ///
>          HHExpFOther_Own_7D HHExpF_Own_7D)
{txt}
{com}. 
.         * 7 days food values in total and 1 month average 
.         gen HHExpFoodTotal_7D = HHExp_Food_Purch_MN_7D + HHExp_Food_GiftAid_MN_7D + HHExp_Food_Own_MN_7D
{txt}
{com}.         gen HHExpFoodTotal_1M = (HHExpFoodTotal_7D/7) * 30
{txt}
{com}.         
. ***** NON-FOOD EXPENDITURE *****************************************************
.         
.         **** 1 MONTH but actually 6 MONTH ****
.          replace HHExpNFEduMedCloth_MNCRD_1M  = HHExpNFEduMedCloth_MNCRD_1M/6
{txt}variable {bf}{res}HHExpNFEduMedCloth_MNCRD_1M{sf}{txt} was {bf}{res}long{sf}{txt} now {bf}{res}double{sf}
{txt}(272 real changes made)

{com}.          replace HHExpNFEduMedCloth_GiftAid_1M  = HHExpNFEduMedCloth_GiftAid_1M/6
{txt}variable {bf}{res}HHExpNFEduMedCloth_GiftAid_1M{sf}{txt} was {bf}{res}long{sf}{txt} now {bf}{res}double{sf}
{txt}(46 real changes made)

{com}.          
.         **** 1 MONTH ****
.         * Monthly non food expenditure in cash/credit
. egen HHExpNFTotal_Purch_MN_1M = rowtotal(HHExpNFHyg_MNCRD_1M HHExpNFTranspPh_MNCRD_1M  ///
>          HHExpNFUtilities_MNCRD_1M HHExpNFAlcTobac_MNCRD_1M HHExpNF_MNCRD_1M                       ///
>          HHExpNFEduMedCloth_MNCRD_1M)
{txt}
{com}. 
.          * Monthly non food gift/aid value
. egen HHExpNFTotal_GiftAid_MN_1M = rowtotal(HHExpNFHyg_GiftAid_1M HHExpNFTranspPh_GiftAid_1M ///
>          HHExpNFUtilities_GiftAid_1M HHExpNFAlcTobac_GiftAid_1M HHExpNF_GiftAid_1M                              ///
>          HHExpNFEduMedCloth_GiftAid_1M)
{txt}
{com}. 
.         **** TOTAL 1 MONTH AVERAGE ****
.         * Total monthly non-food
.         gen HHExpNFTotal_1M = HHExpNFTotal_Purch_MN_1M + HHExpNFTotal_GiftAid_MN_1M
{txt}
{com}.         
.         **** TOTAL **** 
.         gen HHExpTotal = HHExpFoodTotal_1M + HHExpNFTotal_1M
{txt}
{com}.         gen PCExpTotal = HHExpTotal/HHSize
{txt}
{com}. 
.         * FES // household level
.         gen     FES = HHExpFoodTotal_1M/HHExpTotal * 100
{txt}
{com}.         count if HHExpFoodTotal_1M == 0 // 3 missing
  {res}3
{txt}
{com}.         
.         replace FES = 0          if mi(FES)
{txt}(0 real changes made)

{com}.         
.         gen byte FES_Cat = 1 if FES <  50
{txt}(460 missing values generated)

{com}.         replace  FES_Cat = 2 if FES >= 50 & FES < 65
{txt}(81 real changes made)

{com}.         replace  FES_Cat = 3 if FES >= 65 & FES < 75
{txt}(92 real changes made)

{com}.         replace  FES_Cat = 4 if FES >= 75
{txt}(287 real changes made)

{com}.         
.         gl out_fes HHExpFoodTotal_1M HHExpNFTotal_Purch_MN_1M HHExpNFTotal_GiftAid_MN_1M  ///
>                            HHExpNFTotal_1M HHExpTotal PCExpTotal FES FES_Cat
{txt}
{com}. 
.         ** CARI based on FES
.         gen CC_FES_Cat   = (FES_Cat + LCS_Cat)/2        // no round here
{txt}
{com}.         gen CARI_FES_Raw = (FCS_4pt_CARI + CC_FES_Cat)/2
{txt}
{com}.         gen CARI_FES_Cat = round(CARI_FES_Raw)
{txt}
{com}.         
.         gen HH_Vul_CARI_FES  = (CARI_FES_Cat == 3 | CARI_FES_Cat == 4)
{txt}
{com}. 
