{txt}
{com}.         // Perform the t-test and store the results
.         ttest MDDW_Index, by(MDDR_Sex)

{txt}Two-sample t test with equal variances
{hline 9}{c TT}{hline 68}
   Group{col 10}{c |}{col 16}Obs{col 27}Mean{col 35}Std. err.{col 47}Std. dev.{col 59}[95% conf. interval]
{hline 9}{c +}{hline 68}
  Female {c |}{res}{col 12}    238{col 22} 5.235294{col 34} .1343962{col 46} 2.073363{col 58}  4.97053{col 70} 5.500058
    {txt}Male {c |}{res}{col 12}    193{col 22} 5.051813{col 34} .1403066{col 46} 1.949201{col 58} 4.775073{col 70} 5.328554
{txt}{hline 9}{c +}{hline 68}
Combined {c |}{res}{col 12}    431{col 22} 5.153132{col 34} .0972257{col 46} 2.018457{col 58} 4.962036{col 70} 5.344229
{txt}{hline 9}{c +}{hline 68}
    diff {c |}{res}{col 22} .1834806{col 34} .1955472{col 58}-.2008691{col 70} .5678304
{txt}{hline 9}{c BT}{hline 68}
    diff = mean({res}Female{txt}) - mean({res}Male{txt})                              t = {res}  0.9383
{txt}H0: diff = 0                                     Degrees of freedom = {res}     429

    {txt}Ha: diff < 0                 Ha: diff != 0                 Ha: diff > 0
 Pr(T < t) = {res}0.8257         {txt}Pr(|T| > |t|) = {res}0.3486          {txt}Pr(T > t) = {res}0.1743
{txt}
{com}. 
.         // Export the results as a LaTeX table
.         estout using "${c -(}tabs_tex{c )-}/Iraq_MDD_F2F_Gender_Difference_Unpaired_ttest.tex", cells("mean(fmt(%9.2f)) sd(fmt(%9.2f))") ///
>     replace label title("Unpaired Gender Difference for MDD") ///
>     stats(t statistic pvalue) star(* 0.1 ** 0.05 *** 0.01) ///
>     nonumber booktabs
{err}option {bf:star()} not allowed
{txt}{search r(198), local:r(198);}

end of do-file

