{txt}
{com}.         label var rCSIMealNb                    "Reduced the number of meals eaten per day"
{txt}
{com}.         label var rCSI                                  "Reduced Consumption Strategies Index (rCSI)"
{txt}
{com}.         
.         label def LCS_l         1 "Not adopting coping strategies"      ///
>                                                 2 "Stress coping strategies"            ///
>                                                 3 "Crisis coping strategies"            ///
>                                                 4 "Emergencies coping strategies" 
{txt}
