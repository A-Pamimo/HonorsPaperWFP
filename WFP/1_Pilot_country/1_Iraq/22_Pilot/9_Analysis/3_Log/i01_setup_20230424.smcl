{txt}
{com}.         
.         label var Lcs_stress_DomAsset   "Stress coping: Sold household assets/goods"
{txt}
{com}.         label var Lcs_stress_CrdtFood   "Stress coping: Purchased food/non-food on credit (incur debts)"
{txt}
{com}.         label var Lcs_stress_Saving             "Stress coping: Spent savings"
{txt}
{com}.         label var Lcs_stress_BorrowCash "Stress coping: Borrowed money"
{txt}
{com}.         label var Lcs_crisis_ProdAssets "Crisis coping: Sold productive assets or means of transport"
{txt}
{com}.         label var Lcs_crisis_HealthEdu  "Crisis coping: Reduced expenses on health or education"
{txt}
{com}.         label var Lcs_crisis_OutSchool  "Crisis coping: Withdrew children from school"
{txt}
{com}.         label var Lcs_em_ChildWork              "Emergency coping: Send children to work for household income"
