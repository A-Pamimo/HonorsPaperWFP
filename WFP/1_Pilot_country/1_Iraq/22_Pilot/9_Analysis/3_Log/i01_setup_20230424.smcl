{txt}
{com}.         
.         label var HHExp_Food_Purch_MN_7D                "Total weekly food expenditure on cash/credit"
{txt}
{com}.         label var HHExp_Food_GiftAid_MN_7D              "Total weekly food expenditure from gift aid"
{txt}
{com}.         label var HHExp_Food_Own_MN_7D                  "Total weekly food expenditure from own production"
