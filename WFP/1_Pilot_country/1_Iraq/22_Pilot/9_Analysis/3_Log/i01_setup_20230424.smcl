{com}.         label var Lcs_em_Begged                 "Emergency coping: Begged and/or scavenged"
{txt}
{com}.         label var Lcs_em_IllegalAct             "Emergency coping: Engaged in illegal income activities"
{txt}
{com}.         label var Lcs_Stress_Coping     "Household engaged in stress coping strategies" 
