{com}.         
. ********************************************************************************
. *                                       PART 3: Gender Perspective Comparison
. *******************************************************************************/
. 
.         use "${c -(}temp{c )-}/Iraq_rCSI_F2F_Analysis.dta", clear
{txt}
{com}.         keep HHID Group FCSCat28 Status FCG rCSIGenderMealSize_F         ///
>                  rCSIGenderMealSize_M rCSIGenderMealAdult_F rCSIGenderMealAdult_M        ///
>                  rCSIGenderMealNb_F rCSIGenderMealNb_M
{txt}
{com}.         
.         gl rcsi_short MealSize MealAdult MealNb
{txt}
{com}.                                                 
.         lab def gender_diff_short 1  "Mainly female" 0  "Consistent perception" ///
>                                                           -1 "Mainly male"
{txt}
{com}.                                                 
.         lab def gender_dis 1 "Full Disagreement" 0 "Agreement"
{txt}
{com}.         
.                                                 
. foreach var of global rcsi_short {c -(}
{txt}  2{com}.         gen rCSI`var'_MainM = (rCSIGender`var'_M == 1) if !mi(rCSIGender`var'_M)
{txt}  3{com}.         gen rCSI`var'_MainF = (rCSIGender`var'_F == 2) if !mi(rCSIGender`var'_F)
{txt}  4{com}. *       ttest rCSI`var'_MainM == rCSI`var'_MainF 
.         gen rCSI`var'_Diff  = rCSI`var'_MainF - rCSI`var'_MainM
{txt}  5{com}.         gen rCSI`var'_Disagree = (rCSI`var'_MainM == 1 & rCSI`var'_MainF == 1) if !mi(rCSI`var'_Diff)
{txt}  6{com}.         
.         lab var rCSI`var'_MainM "Male reported mainly male adults suffered rCSI`var'"
{txt}  7{com}.         lab var rCSI`var'_MainF "Female reported mainly female adults suffered rCSI`var'"
{txt}  8{com}.         lab var rCSI`var'_Diff  "Difference between female and male reported main suffering rCSI`var'"
{txt}  9{com}.         lab var rCSI`var'_Disagree "Household Gendered Disagreement on rCSI`var'"
{txt} 10{com}.         lab val rCSI`var'_Diff gender_diff_short
{txt} 11{com}.         lab val rCSI`var'_Disagree gender_dis
{txt} 12{com}.         
. {c )-}
