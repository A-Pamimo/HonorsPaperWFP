>                  rCSIGenderMealSize_M rCSIGenderMealAdult_F rCSIGenderMealAdult_M        ///
>                  rCSIGenderMealNb_F rCSIGenderMealNb_M
{txt}
{com}.         
.         save `master'
{txt}{p 0 4 2}
