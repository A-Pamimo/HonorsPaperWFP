>                                 OtherVeg OtherFruits Index Index_5
{txt}
{com}.         
. foreach var in $raw_mddw {c -(}
{txt}  2{com}.         gen     `var'_F = PWMDDW`var'R    if MDDR_Sex == 0
{txt}  3{com}.         replace `var'_F = PWMDDW`var'_oth if MDDWSexR == 0
{txt}  4{com}.         lab var `var'_F "`var' Female"
{txt}  5{com}.         
.         gen     `var'_M = PWMDDW`var'R    if MDDR_Sex == 1
{txt}  6{com}.         replace `var'_M = PWMDDW`var'_oth if MDDWSexR == 1
{txt}  7{com}.         lab var `var'_M "`var' Male"
{txt}  8{com}.         
.         gen `var'_g_diff = `var'_F - `var'_M if !mi(`var'_F) & !mi(`var'_M)
{txt}  9{com}.         lab var  `var'_g_diff "Difference between female reported and male reported MDDW `var'"
{txt} 10{com}.         
. {c )-}
