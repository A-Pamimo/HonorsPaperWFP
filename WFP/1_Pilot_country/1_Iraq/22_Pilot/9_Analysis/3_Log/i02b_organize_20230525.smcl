{com}.         
. /*       Variable |        N     Mean       SD      Min      Max
>         ----------+---------------------------------------------
>                   FCS |      549    33.03    19.48     0.00   107.00  
>           FCS_tot |      549    33.69    19.97     0.00   108.00  
> */
. /* The FCS categories are Poor with a FCS up to 28, Borderline with more than
>         28 and less than 42, and Acceptable with more than 42. cond() also works */
.         gen FCSCat28 = cond(FCS <= 28,1,cond(FCS <= 42,2,3))
{txt}
{com}.         
.         ** 2. Reduced Coping Strategies Index 
.         clonevar rCSILessQlty  = _51shift_less_preferred    
{txt}
{com}.         clonevar rCSIBorrow    = _51borrow
{txt}
{com}.         clonevar rCSIMealNb    = _51reduceno_meals
{txt}
{com}.         clonevar rCSIMealSize  = _51limit_portionconsumed
{txt}
{com}.         clonevar rCSIMealAdult = _51restrict_adults_cons
{txt}
{com}.         
.         gen rCSI = (rCSILessQlty * 1) + (rCSIBorrow * 2) + (rCSIMealNb * 1) + (rCSIMealSize * 1) + (rCSIMealAdult * 3)
{txt}
{com}.         
.         ** 3. ECMEN/FES: the amount in thousands (`000'),  e.g. 3,450 for 3,450,000 
.         gen  HHExpFoodTotal_7D = _32spend_food_7days
{txt}(3 missing values generated)

{com}.         egen HHExpTotal_7D = rowtotal(_32spend_food_7days _32spend_nonfood_7days        ///
>                  _32spend_water_7days _32debt_outstanding _32spend_debt)
{txt}
{com}.                  
.         gen FES = HHExpFoodTotal_7D/HHExpTotal_7D // 9 missing
{txt}(9 missing values generated)

{com}.         count if HHExpTotal_7D     == 0 // 6
  {res}6
{txt}
{com}.         count if HHExpFoodTotal_7D == 0 // 22
  {res}22
{txt}
{com}.         replace FES = 0 if mi(FES)
{txt}(9 real changes made)

{com}.         
.         gen HHExpFoodTotal_1M = (HHExpFoodTotal_7D/7) * 30
{txt}(3 missing values generated)

{com}.         
.         ** Change to USD to compare with Food MEB
.         replace HHExpFoodTotal_1M = HHExpFoodTotal_1M/8500              if region=="Awdal"
{txt}(114 real changes made)

{com}.         replace HHExpFoodTotal_1M = HHExpFoodTotal_1M/8406              if region=="Togdheer"
{txt}(155 real changes made)

{com}.         replace HHExpFoodTotal_1M = HHExpFoodTotal_1M/45000             if region=="Sool"
{txt}(91 real changes made)

{com}.         replace HHExpFoodTotal_1M = HHExpFoodTotal_1M/40000             if region=="Sanaag"
{txt}(77 real changes made)

{com}.         replace HHExpFoodTotal_1M = HHExpFoodTotal_1M/8520              if region=="Woqooyi Galbeed"
{txt}(87 real changes made)

{com}. 
.         ** ECMEN
.         gen ECMEN_recomp          = (below_MEB == 0)            // over MEB
{txt}
{com}.         gen ECMEN_SMEB_recomp = (below_MEB_food == 0)   // above SMEB/Food MEB
{txt}
{com}.         
.         ** LCS - FS
. /*      1=NO, BECAUSE I DID NOT FACE A SHORTAGE OF FOOD.
>         2=NO BECAUSE I ALREADY SOLD THOSE ASSETS OR HAVE ENGAGED IN THIS ACTIVITY AND CANNOT CONTINUE TO DO IT.
>         3=YES
>         4 = NOT APPLICABLE
> */
.         ren _52LCSI_* *
{res}{txt}
{com}.         
.         gen Stress_coping = (HHs_aasets == 2 | HHs_aasets == 3 |                        ///
>                                                  credit_purchase == 2 | credit_purchase == 3 |  ///
>                                                  savings == 2 | savings == 3 |                                  ///
>                                                  EatElsewhere == 2 | EatElsewhere == 3 |                ///
>                                                  SoldAnimal == 2 | SoldAnimal == 3 |                    ///
>                                                  Borrow == 2 | Borrow == 3)
{txt}
{com}.                                                  
.         gen Crisis_coping = (Pro_assets == 2 | Pro_assets == 3 |                ///
>                                                  WithdrawChild == 2 | WithdrawChild == 3 |      ///
>                                                  ExpInputs == 2 | ExpInputs == 3 |                      ///
>                                                  SkipDayEat == 2 | SkipDayEat == 3)                     // not in the questionnaire
{txt}
{com}.                                                  
.         gen Emergency_coping = (SellLand == 2 | SellLand == 3 |                 ///
>                                                         Begging == 2 | Begging == 3 |                   ///
>                                                         FemaleAnimal == 2 | FemaleAnimal == 3)
{txt}
{com}.         
.         gen     LCS_Cat = 1
{txt}
{com}.         replace LCS_Cat = 2 if Stress_coping == 1
{txt}(357 real changes made)

{com}.         replace LCS_Cat = 3 if Crisis_coping == 1
{txt}(225 real changes made)

{com}.         replace LCS_Cat = 4 if Emergency_coping == 1    
{txt}(217 real changes made)

{com}.                 
.         gen Stress_coping_s = (HHs_aasets == 2 | HHs_aasets == 3 |                      ///
>                                                    credit_purchase == 2 | credit_purchase == 3 |        ///
>                                                    savings == 2 | savings == 3 |                                        ///
>                                                    EatElsewhere == 2 | EatElsewhere == 3)
{txt}
{com}.                                                  
.         gen Crisis_coping_s = (Pro_assets == 2 | Pro_assets == 3 |              ///
>                                                    WithdrawChild == 2 | WithdrawChild == 3 |    ///
>                                                    ExpInputs == 2 | ExpInputs == 3)
{txt}
{com}.                                                  
.         gen Emergency_coping_s = (SellLand == 2 | SellLand == 3 |               ///
>                                                           Begging == 2 | Begging == 3 |                         ///
>                                                           FemaleAnimal == 2 | FemaleAnimal == 3)
{txt}
{com}.         
.         gen     LCS_Cat_s = 1
{txt}
{com}.         replace LCS_Cat_s = 2 if Stress_coping_s == 1
{txt}(325 real changes made)

{com}.         replace LCS_Cat_s = 3 if Crisis_coping_s == 1
{txt}(171 real changes made)

{com}.         replace LCS_Cat_s = 4 if Emergency_coping_s == 1
{txt}(217 real changes made)

{com}.         
. /* in-kind food gift/aid: indicate the amount (kg, not value) of staple food 
> items received in the last one month from the following sources:
>         _3511FoodGift_rice _3511FoodGift_sorg   ///
>         _3511FoodGift_maize _3511FoodGift_sugar _3521FoodAsst_rice _3521FoodAsst_sorg ///
>         _3521FoodAsst_maize _3521FoodAsst_CSB _3521FoodAsst_sugar)      */
. 
.         ** current status
.         sum FCSCat28 rCSI 

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
{space 4}FCSCat28 {c |}{res}        549    1.797814    .8822638          1          3
{txt}{space 8}rCSI {c |}{res}        549    9.990893    9.255592          0         43
{txt}
{com}.         ** COMBINING FCS and rCSI for CARI Calculation
.         recode FCSCat28 (1 = 1) (2 = 3) (3 = 4), gen(FCS_4pt_CARI)
{txt}(269 differences between {bf:FCSCat28} and {bf:FCS_4pt_CARI})

{com}.         /* Acceptable consumption and reduced Coping Index 4 or above */
.         replace FCS_4pt_CARI = 2 if FCSCat28 == 1 & rCSI >= 4
{txt}(229 real changes made)

{com}.         tab     FCS_4pt_CARI

  {txt}RECODE of {c |}
   FCSCat28 {c |}      Freq.     Percent        Cum.
{hline 12}{c +}{hline 35}
          1 {c |}{res}         51        9.29        9.29
{txt}          2 {c |}{res}        229       41.71       51.00
{txt}          3 {c |}{res}        100       18.21       69.22
{txt}          4 {c |}{res}        169       30.78      100.00
{txt}{hline 12}{c +}{hline 35}
      Total {c |}{res}        549      100.00
{txt}
{com}.         
.         ** COMBINING CURRENT STATUS AND COPING CAPACITY
.         
.         gen byte ECMEN_Cat = 1 if ECMEN_recomp == 1
{txt}(423 missing values generated)

{com}.         replace  ECMEN_Cat = 3 if ECMEN_recomp == 0 & ECMEN_SMEB_recomp == 1
{txt}(87 real changes made)

{com}.         replace  ECMEN_Cat = 4 if ECMEN_recomp == 0 & ECMEN_SMEB_recomp == 0
{txt}(336 real changes made)

{com}. 
.         gen byte FES_Cat = 1 if FES <  0.5
{txt}(297 missing values generated)

{com}.         replace  FES_Cat = 2 if FES >= 0.5  & FES < 0.65
{txt}(124 real changes made)

{com}.         replace  FES_Cat = 3 if FES >= 0.65 & FES < 0.75
{txt}(81 real changes made)

{com}.         replace  FES_Cat = 4 if FES >= 0.75
{txt}(92 real changes made)

{com}.         
.         gen CC_ECMEN_Cat = (ECMEN_Cat + LCS_Cat)/2      // no round here
{txt}
{com}.         gen CC_FES_Cat   = (FES_Cat + LCS_Cat)/2        // no round here
{txt}
{com}.         
.         gen CARI_ECMEN_Raw       = (FCS_4pt_CARI + CC_ECMEN_Cat)/2
{txt}
{com}.         gen CARI_FES_Raw         = (FCS_4pt_CARI + CC_FES_Cat)/2
{txt}
{com}.         
.         gen CARI_ECMEN_Cat   = round(CARI_ECMEN_Raw)
{txt}
{com}.         gen CARI_FES_Cat         = round(CARI_FES_Raw)
{txt}
{com}.         
. ********************************************************************************
. *                                                       Outcome indicators
. *******************************************************************************/        
.         
.         ren HH_number HHSize
{res}{txt}
{com}.         
.         gen     HHEconCap_Food = HHExpFoodTotal_1M
{txt}(3 missing values generated)

{com}.         
.         replace HHEconCap_Food = 0 if HHEconCap_Food < 0
{txt}(0 real changes made)

{com}.         // This is 60% Bangladesh and 80% DRC have negative capacity of overall sample
.         
.         gen     PCEconCap_Food = HHEconCap_Food/HHSize  
{txt}(4 missing values generated)

{com}.         gen     FoodGap  = MEB_food_PC - PCEconCap_Food         
{txt}(4 missing values generated)

{com}.         replace FoodGap  = 0                                                    if FoodGap < 0 
{txt}(259 real changes made)

{com}.         
.         gen             FoodGap_Percent = FoodGap/MEB_food_PC
{txt}(4 missing values generated)

{com}.         gen     FoodCap_Percent = 1 - FoodGap_Percent
{txt}(4 missing values generated)

{com}.         gen     FoodGap_Percent_R = - FoodGap_Percent
{txt}(4 missing values generated)

{com}.         
.         ren MEB_food_PC FoodMEB
{res}{txt}
{com}.         keep    HHSize HHEconCap_Food PCEconCap_Food FoodGap FoodCap_Percent ///
>                         FoodGap_Percent_R FoodMEB CARI_ECMEN_Cat CARI_FES_Cat
{txt}
{com}.                         
.         save "${c -(}output{c )-}/Somaliland_inkind_final.dta", replace    
{txt}{p 0 4 2}
