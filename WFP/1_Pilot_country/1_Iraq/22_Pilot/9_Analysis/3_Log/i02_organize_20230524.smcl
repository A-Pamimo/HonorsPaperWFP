{com}.     gen MDDW_OtherVeg    = (PWMDDWVegOthR == 1) if !mi(PWMDDWVegOthR)
{txt}(159 missing values generated)

{com}.     gen MDDW_OtherFruits = (PWMDDWFruitOthR == 1) if !mi(PWMDDWFruitOthR)
{txt}(159 missing values generated)

{com}.         gen MDDW_Index = MDDW_Staples + MDDW_Pulses + MDDW_NutsSeeds + MDDW_Dairies + MDDW_MeatFish + ///
>                            MDDW_Eggs + MDDW_LeafGVeg + MDDW_VitA + MDDW_OtherVeg + MDDW_OtherFruits if !mi(MDDW_Staples)
{txt}(159 missing values generated)

{com}.         gen MDDW_Index_5 = (MDDW_Index >= 5) if !mi(MDDW_Index)
{txt}(159 missing values generated)

{com}.         
.         gen MDDW_Staples_oth     = (PWMDDWStapCer_oth == 1 |  PWMDDWStapRoo_oth == 1 | PWMDDWSnf_oth == 1) if !mi(PWMDDWStapCer_oth)
