.         keep HHID Group Status FCG rCSIGenderMealNb_F rCSIGenderMealNb_M         
{txt}
{com}.         keep if !mi(rCSIGenderMealNb_F) & !mi(rCSIGenderMealNb_M)
{txt}(385 observations deleted)

{com}.         
.         reshape long rCSIGenderMealNb_, ///
>                         i(HHID Group Status FCG) j(Gender) string
{txt}(j = F M)

Data{col 36}Wide{col 43}->{col 48}Long
{hline 77}
Number of observations     {res}         191   {txt}->   {res}382         
{txt}Number of variables        {res}           6   {txt}->   {res}6           
