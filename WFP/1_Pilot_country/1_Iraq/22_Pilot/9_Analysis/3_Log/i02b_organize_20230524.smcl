.         ** COMBINING CURRENT STATUS AND COPING CAPACITY
.         
.         gen byte ECMEN_Cat = 1 if ECMEN_recomp == 1
{txt}(37,573 missing values generated)

{com}.         replace  ECMEN_Cat = 3 if ECMEN_recomp == 0 & ECMEN_SMEB_recomp == 1
{txt}(5,474 real changes made)

{com}.         replace  ECMEN_Cat = 4 if ECMEN_recomp == 0 & ECMEN_SMEB_recomp == 0
{txt}(32,099 real changes made)

{com}.         
.         ren Max_coping_behaviour LCS_Cat
{res}{txt}
{com}. 
.         gen byte FES_Cat = 1 if FES <  0.5
{txt}(46,451 missing values generated)

{com}.         replace  FES_Cat = 2 if FES >= 0.5  & FES < 0.65
{txt}(14,556 real changes made)

{com}.         replace  FES_Cat = 3 if FES >= 0.65 & FES < 0.75
{txt}(12,520 real changes made)

{com}.         replace  FES_Cat = 4 if FES >= 0.75
{txt}(19,375 real changes made)

{com}.         
.         gen CC_ECMEN_Cat = (ECMEN_Cat + LCS_Cat)/2      // no round here
{txt}
{com}.         gen CC_FES_Cat   = (FES_Cat + LCS_Cat)/2        // no round here
{txt}
{com}.         
.         gen CARI_ECMEN_Raw       = (FCS_4pt_CARI + CC_ECMEN_Cat)/2
{txt}
{com}.         gen CARI_FES_Raw         = (FCS_4pt_CARI + CC_FES_Cat)/2
{txt}
{com}.         
.         gen CARI_ECMEN_Cat   = round(CARI_ECMEN_Raw)
{txt}
{com}.         gen CARI_FES_Cat         = round(CARI_FES_Raw)
{txt}
{com}.         
.         label def fs_status     1 "Food Secure"         2 "Marginally Food Secure"      ///
>                                                         3 "Moderately Food Insecure" 4 "Severely Food Insecure"
{txt}
{com}.         label val CARI_ECMEN_Cat CARI_FES_Cat fs_status
{txt}
{com}. 
. *******************************************************************************/
. *                                               PART 5: Adding Djibouti                                *
. ********************************************************************************
. 
.         append using `djibouti'
{txt}(label {bf:{txt}fs_status} already defined)

{com}.         
. /*      
>         gen FoodGap_Percent_1 = FoodGap_Percent_R if CARI_FES_Cat == 1
>         gen FoodGap_Percent_2 = FoodGap_Percent_R if CARI_FES_Cat == 2
>         gen FoodGap_Percent_3 = FoodGap_Percent_R if CARI_FES_Cat == 3
>         gen FoodGap_Percent_4 = FoodGap_Percent_R if CARI_FES_Cat == 4
>         
>         graph bar (mean) FoodGap_Percent_1 FoodGap_Percent_2            ///
>                                          FoodGap_Percent_3 FoodGap_Percent_4            ///
>                                          , over(Country, gap(220))                                      ///
>         graphregion(color(white)) bgcolor(white)                                        ///
>         blabel(bar, format(%9.2fc) size(1.5))                                           ///
>         title("Average Food Gap by Country and Food Security Status (FES)", size(4.5)) ///
>         subtitle("Percentage of Food MEB", size(3))                             ///
>         outergap(50) bargap(20) ylabel(-0.8(0.2)0, labsize(2))          ///
>         ytitle("Average Food Gap", size(3))                                                     ///
>         note("Note: Only Bangladesh has cash assistance value", ring(4)  ///
>                 pos(6) size(2.5))                                                                               ///
>         legend(ring(4) pos(6) rows(1)                                                           ///
>           lab(1 "Food Secure")                                                                          ///
>           lab(2 "Marginally Food Secure")                                                       ///
>           lab(3 "Moderately Food Insecure")                                             ///
>           lab(4 "Severely Food Insecure") size(2.5))
>           
>         graph export "${c -(}output{c )-}/In_Kind_Assistance_Gap_FES.png", replace
> */      
.         gen FoodGap_Percent_1E = FoodGap_Percent_R if CARI_ECMEN_Cat == 1
{txt}(54,878 missing values generated)

{com}.         gen FoodGap_Percent_2E = FoodGap_Percent_R if CARI_ECMEN_Cat == 2
{txt}(43,829 missing values generated)

{com}.         gen FoodGap_Percent_3E = FoodGap_Percent_R if CARI_ECMEN_Cat == 3
{txt}(23,004 missing values generated)

{com}.         gen FoodGap_Percent_4E = FoodGap_Percent_R if CARI_ECMEN_Cat == 4
{txt}(45,548 missing values generated)

{com}.         
.         graph bar (mean) FoodGap_Percent_1E FoodGap_Percent_2E          ///
>                                          FoodGap_Percent_3E FoodGap_Percent_4E          ///
>                                          , over(Country, gap(200))                                      ///
>         graphregion(color(white)) bgcolor(white)                                        ///
>         blabel(bar, format(%9.2fc) size(2))                                             ///
>         title("Average Food Gap by Country and Food Security Status (ECMEN)", size(4.5)) ///
>         subtitle("Percentage of Food MEB", size(3))                             ///
>         outergap(50) bargap(60) ylabel(-0.8(0.2)0, labsize(2))          ///
>         ytitle("Average Food Gap", size(3))                                                     ///     
>         note("Note: Only Bangladesh and DRC has cash assistance value", ring(4)  ///
>                 pos(6) size(2.5))                                                                               ///
>         legend(ring(4) pos(6) rows(1)                                                           ///
>           lab(1 "Food Secure")                                                                          ///
>           lab(2 "Marginally Food Secure")                                                       ///
>           lab(3 "Moderately Food Insecure")                                             ///
>           lab(4 "Severely Food Insecure") size(2.5))
{res}{txt}
{com}.           
