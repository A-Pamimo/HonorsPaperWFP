{com}.         
.         ** export codebook
. *       iecodebook export using "${c -(}codebook{c )-}/Somaliland_raw_codebook.xlsx", replace
.         
. ********************************************************************************
. *                                                       Correct relevant variable types
. *******************************************************************************/
.         
.         label def yesno 1 "Yes" 0 "No"
{txt}
{com}.         
.         * categorical string to byte
. local conv_cat_var livelihood_zone settlement HDwellType _1sex_head
{txt}
{com}.           
. foreach var of local conv_cat_var {c -(}
{txt}  2{com}.         encode  `var', gen(`var'_b)
{txt}  3{com}.         order   `var'_b, a(`var')
{txt}  4{com}.         drop    `var'
{txt}  5{com}.         rename  `var'_b `var'
{txt}  6{com}. {c )-}
{res}{txt}
{com}. 
.         * numeric string to byte/int    
. local conv_num_var _3511FoodGift_rice _3511FoodGift_sorg _3511FoodGift_maize              ///
>           _3511FoodGift_sugar _3521FoodAsst_rice _3521FoodAsst_sorg _3521FoodAsst_maize   ///
>           _3521FoodAsst_CSB _3521FoodAsst_sugar _41cereals_grainsdays _41roots_tubersdays ///
>           _41legumes_nutsdays _41orangevegs_days _41green_leafyvegsdays _41other_vegsdays ///
>           _41orange_fruitsdays _41other_fruitsdays _41meat_days _41organ_meatdays                 ///
>           _41fish_shellfishdays _41eggsa_days _41milk_dairyproducts_days                                  ///
>           _41oilfats_butter_days _41sugar_sweet_days _41condiments_days                                   ///
>           _51shift_less_preferred _51borrow _51limit_portionconsumed                                      ///
>           _51restrict_adults_cons _51reduceno_meals _52LCSI_HHs_aasets                                    ///
>           _52LCSI_credit_purchase _52LCSI_savings _52LCSI_Borrow _52LCSI_ExpInputs                ///
>           _52LCSI_Pro_assets _52LCSI_WithdrawChild _52LCSI_EatElsewhere                                   ///
>           _52LCSI_SoldAnimal _52LCSI_SkipDayEat _52LCSI_FemaleAnimal _52LCSI_SellLand     ///
>           _52LCSI_Begging _32spend_food_7days 
{txt}
{com}.           
. foreach var of local conv_num_var {c -(}
{txt}  2{com}.         destring  `var'   , replace
{txt}  3{com}. {c )-}
