{com}.         local strvars "`r(varlist)'"
{txt}
{com}. 
. foreach var of local strvars {c -(}
{txt}  2{com}.         replace `var' = strproper(strtrim(`var'))               // remove unnecessary blanks in string and adjust the proper cases
{txt}  3{com}.         replace `var' = "" if `var' == "N/A"                            // drop NA values as missing
{txt}  4{com}.         replace `var' = subinstr(`var', "__", " ",.)    // remove __ and _ from strings
{txt}  5{com}.         replace `var' = subinstr(`var', "_", " ",.) 
{txt}  6{com}.     {c )-}
