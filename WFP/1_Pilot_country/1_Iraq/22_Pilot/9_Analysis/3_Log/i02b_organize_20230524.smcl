.         
. ********************************************************************************
. *                                       PART 2: rCSI Gendered Difference
. *******************************************************************************/
.   
. foreach var of global analysis_rcsi {c -(}
{txt}  2{com}.         gen     `var'_F = `var'         if RESPSex                 == 0
{txt}  3{com}.         replace `var'_F = `var'_oth if rCSIRESPSex_oth == 0
{txt}  4{com}.         lab var `var'_F "Female reported `var'"
{txt}  5{com}.         
.         gen     `var'_M = `var'         if RESPSex                 == 1
{txt}  6{com}.         replace `var'_M = `var'_oth if rCSIRESPSex_oth == 1
{txt}  7{com}.         lab var `var'_M "Male reported `var'"
{txt}  8{com}.         
.         gen `var'_g_diff = `var'_F - `var'_M
{txt}  9{com}.         lab var  `var'_g_diff "Difference between female reported and male Reported `var'"
{txt} 10{com}. {c )-}
