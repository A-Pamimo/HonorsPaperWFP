{com}.         
. *******************************************************************************/
. *                       PART 4: ANALYZE POVERY LINE COMPARISON                         *
. ********************************************************************************
. 
.         gen             HHEconCap_Food = HHExp_Food_Own_1M + HHExpFood_MN_1M + HHExp_Food_CRD_1M ///
>                                                          - HHAsstHumanCBTRec_1M
{txt}
{com}. /*      Country |      Freq.     Percent        Cum.
> ----------------+-----------------------------------
>      Bangladesh |      4,534       84.29       84.29
>             DRC |        845       15.71      100.00
> ----------------+-----------------------------------
>           Total |      5,379      100.00
> 
> . tab Country           
> 
>         Country |      Freq.     Percent        Cum.
> ----------------+-----------------------------------
>      Bangladesh |      7,372       13.51       13.51
>        Cameroon |      1,026        1.88       15.39    */
.            
.         replace HHEconCap_Food = 0 if HHEconCap_Food < 0 //5,379 values changed
{txt}(5,379 real changes made)

{com}.         // This is 60% Bangladesh and 80% DRC have negative capacity of overall sample
.         
.         gen     PCEconCap_Food = HHEconCap_Food/HHSize  
{txt}
{com}.         gen     FoodGap  = FoodMEB - PCEconCap_Food     
{txt}
{com}.         replace FoodGap  = 0                                                    if FoodGap < 0 
{txt}(18,128 real changes made)

{com}.         
.         gen             FoodGap_Percent = FoodGap/FoodMEB
{txt}
{com}.         gen     FoodCap_Percent = 1 - FoodGap_Percent
{txt}
{com}.         gen     FoodGap_Percent_R = - FoodGap_Percent
{txt}
{com}.                 
. /*                                                      Re-Calculating CARI                                                               */
.         ** current status
.         sum FCSCat28 rCSI 

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
{space 4}FCSCat28 {c |}{res}     54,581    2.021912    .8431583          1          3
{txt}{space 8}rCSI {c |}{res}     54,581    11.78432    12.51199          0         56
{txt}
{com}.         ** COMBINING FCS and rCSI for CARI Calculation
.         recode FCSCat28 (1 = 1) (2 = 3) (3 = 4), gen(FCS_4pt_CARI)
{txt}(35765 differences between {bf:FCSCat28} and {bf:FCS_4pt_CARI})

{com}.         /* Acceptable consumption and reduced Coping Index 4 or above */
.         replace FCS_4pt_CARI = 2 if FCSCat28 == 1 & rCSI >= 4
{txt}(15,086 real changes made)

{com}.         tab     FCS_4pt_CARI

  {txt}RECODE of {c |}
   FCSCat28 {c |}
       (FCS {c |}
Categories, {c |}
 thresholds {c |}
     28-42) {c |}      Freq.     Percent        Cum.
{hline 12}{c +}{hline 35}
          1 {c |}{res}      3,730        6.83        6.83
{txt}          2 {c |}{res}     15,086       27.64       34.47
{txt}          3 {c |}{res}     15,753       28.86       63.34
{txt}          4 {c |}{res}     20,012       36.66      100.00
{txt}{hline 12}{c +}{hline 35}
      Total {c |}{res}     54,581      100.00
{txt}
{com}.         
.         ** COMBINING CURRENT STATUS AND COPING CAPACITY
.         
.         gen byte ECMEN_Cat = 1 if ECMEN_recomp == 1
{txt}(37,573 missing values generated)

{com}.         replace  ECMEN_Cat = 3 if ECMEN_recomp == 0 & ECMEN_SMEB_recomp == 1
{txt}(5,474 real changes made)

{com}.         replace  ECMEN_Cat = 4 if ECMEN_recomp == 0 & ECMEN_SMEB_recomp == 0
{txt}(32,099 real changes made)

{com}.         
.         ren Max_coping_behaviour LCS_Cat
{res}{txt}
{com}. 
.         gen byte FES_Cat = 1 if FES <  0.5
{txt}(46,451 missing values generated)

{com}.         replace  FES_Cat = 2 if FES >= 0.5  & FES < 0.65
{txt}(14,556 real changes made)

{com}.         replace  FES_Cat = 3 if FES >= 0.65 & FES < 0.75
{txt}(12,520 real changes made)

{com}.         replace  FES_Cat = 4 if FES >= 0.75
{txt}(19,375 real changes made)

{com}.         
.         gen CC_ECMEN_Cat = (ECMEN_Cat + LCS_Cat)/2      // no round here
{txt}
{com}.         gen CC_FES_Cat   = (FES_Cat + LCS_Cat)/2        // no round here
{txt}
{com}.         
.         gen CARI_ECMEN_Raw       = (FCS_4pt_CARI + CC_ECMEN_Cat)/2
{txt}
{com}.         gen CARI_FES_Raw         = (FCS_4pt_CARI + CC_FES_Cat)/2
{txt}
{com}.         
.         gen CARI_ECMEN_Cat   = round(CARI_ECMEN_Raw)
{txt}
{com}.         gen CARI_FES_Cat         = round(CARI_FES_Raw)
{txt}
{com}.         
.         label def fs_status     1 "Food Secure"         2 "Marginally Food Secure"      ///
>                                                         3 "Moderately Food Insecure" 4 "Severely Food Insecure"
{txt}
{com}.         label val CARI_ECMEN_Cat CARI_FES_Cat fs_status
{txt}
{com}. 
. *******************************************************************************/
. *                                               PART 5: Adding Djibouti                                *
. ********************************************************************************
. 
.         append using `djibouti'
{txt}(label {bf:{txt}fs_status} already defined)

{com}.         
. /*      
>         gen FoodGap_Percent_1 = FoodGap_Percent_R if CARI_FES_Cat == 1
>         gen FoodGap_Percent_2 = FoodGap_Percent_R if CARI_FES_Cat == 2
>         gen FoodGap_Percent_3 = FoodGap_Percent_R if CARI_FES_Cat == 3
>         gen FoodGap_Percent_4 = FoodGap_Percent_R if CARI_FES_Cat == 4
>         
>         graph bar (mean) FoodGap_Percent_1 FoodGap_Percent_2            ///
