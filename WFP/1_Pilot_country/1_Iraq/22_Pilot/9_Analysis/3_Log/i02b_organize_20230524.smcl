{txt}  2{com}.                 cap which `command'
{txt}  3{com}.                 if _rc == 111 ssc install `command'
{txt}  4{com}.         {c )-}
. {c )-} // Note that this never updates outdated versions of already installed commands
{txt}
{com}.   // To update commands use adoupdate
. 
. *Standardize settings accross users
