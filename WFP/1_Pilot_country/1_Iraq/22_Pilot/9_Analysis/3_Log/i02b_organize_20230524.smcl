.         
.         * add your directory below
.         display c(username)     // Get your username and add path to the working folder
{res}nicolewu
{txt}
{com}.         
.         global nicole    1
{txt}
{com}. 
.         * set the GD Folder
. if $nicole {c -(}
.         global inkind  "/Users/nicolewu/Library/CloudStorage/OneDrive-WorldFoodProgramme/5_Gap_Analysis/1_DataWork"
.         {c )-}
{txt}
{com}.         
.         
.         * Subfolder globals
.         * -----------------
.         gl somaliland   "${c -(}inkind{c )-}/1_Data/Somaliland"
{txt}
{com}.         
.         gl dataset              "${c -(}somaliland{c )-}/01_Data" 
{txt}
{com}.         gl dofile               "${c -(}somaliland{c )-}/02_Code"
{txt}
{com}.         gl output               "${c -(}somaliland{c )-}/03_Output"
{txt}
{com}.         gl instrument   "${c -(}somaliland{c )-}/04_Instrument"
{txt}
{com}.         gl codebook             "${c -(}somaliland{c )-}/05_Codebook"
{txt}
{com}.         
.         gl data_raw             "${c -(}dataset{c )-}/Raw"
{txt}
{com}.         gl data_clean   "${c -(}dataset{c )-}/Clean"
{txt}
{com}.         
.         use "${c -(}data_clean{c )-}/Somaliland_inkind_analysis.dta", clear
{txt}
{com}.         compress
