{res}{txt}(label {bf:{txt}meb_area_lab} already defined)
(label {bf:{txt}camp_lab} already defined)

{col 5}Result{col 33}Number of obs
{col 5}{hline 41}
{col 5}Not matched{col 30}{res}               0
{txt}{col 5}Matched{col 30}{res}           1,168{txt}  (_merge==3)
{col 5}{hline 41}

{com}. 
. rename (_l21_1 _l21_2 _l21_3 _l21_4) (Lcs_stress_CrdtFood Lcs_stress_saving Lcs_stress_send Lcs_stress_DomAsset )
{res}{txt}
{com}. rename (_l22_1 _l22_2 _l22_3 _l22_4) (Lcs_crisis_HealthEdu      Lcs_crisis_ProdAsset Lcs_crisis_OutSchool Lcs_crisis_ChildTra)
{res}{txt}
{com}. rename (_l23_1 _l23_2 _l23_3 _l23_4) (Lcs_em_IllegalAct Lcs_em_Begged Lcs_em_Fem Lcs_em_House)
{res}{txt}
{com}. 
. 
. /*
> 1 `No, because I did not need to'
> 2 `No because I already sold those assets or have engaged in this activity within the last 12 months and cannot continue to do it'
> 3 `Yes'
> 4 `Not applicable (don't have children/ these assets)'.
> */
. gen stress_coping =0
{txt}
{com}. replace stress_coping =1  if (Lcs_stress_DomAsset == 2) | (Lcs_stress_DomAsset == 3) | (Lcs_stress_CrdtFood == 2) | (Lcs_stress_CrdtFood == 3) | (Lcs_stress_saving ==2) | (Lcs_stress_saving ==0) | (Lcs_stress_send ==2) | (Lcs_stress_send ==3)
{txt}(324 real changes made)

{com}. 
. 
. gen crisis_coping =0
{txt}
{com}. replace crisis_coping=1 if (Lcs_crisis_ChildTra == 2) | (Lcs_crisis_ChildTra ==3) | (Lcs_crisis_HealthEdu ==2) | (Lcs_crisis_HealthEdu==3) | (Lcs_crisis_OutSchool ==2) | (Lcs_crisis_OutSchool ==3)
{txt}(94 real changes made)

{com}. 
. 
. gen emergency_coping =0
{txt}
{com}. replace emergency_coping=1 if (Lcs_em_IllegalAct == 2) | (Lcs_em_IllegalAct ==3) | (Lcs_em_Begged ==2) | (Lcs_em_Begged==3) | (Lcs_em_Fem ==2) | (Lcs_em_Fem ==3)
{txt}(95 real changes made)

{com}. 
. recode  stress_coping (0=0) (1=2) 
{txt}(324 changes made to {bf:stress_coping})

{com}. recode  crisis_coping (0=0) (1=3) 
{txt}(94 changes made to {bf:crisis_coping})

{com}. recode  emergency_coping (0=0) (1=4)
{txt}(95 changes made to {bf:emergency_coping})

{com}. 
. egen Max_coping_behaviour=rowmax(stress_coping  crisis_coping  emergency_coping) 
{txt}
{com}. recode Max_coping_behaviour (0=1)
{txt}(790 changes made to {bf:Max_coping_behaviour})

{com}. 
. drop mktass*
{txt}
{com}. 
. 
. * FOOD EXPENDITURES
. 
.         // Sum expenditures in cash and own production 
.         foreach i of numlist $food{c -(}
{txt}  2{com}.                 egen gap_pcd_food_exp_`i'=rowtotal(exp`i'_f_cash_pcd  exp`i'_f_ownp_pcd exp`i'_f_cred_pcd), missing
{txt}  3{com}.                 {c )-}
{txt}(58 missing values generated)
(46 missing values generated)
(33 missing values generated)
(59 missing values generated)
(57 missing values generated)

{com}.                 
.         // Calculate total food capacity to consume (pcd)
.         order gap_pcd_food_exp_*
{txt}
{com}.         egen gap_pcd_food_exp=rowtotal(gap_pcd_food_exp_1 - gap_pcd_food_exp_51), miss
{txt}
{com}. 
.         // Calculate total food assistance  (pcd)
.         order *f_ass_pcd
{txt}
{com}.         egen gap_pcd_food_ass=rowtotal(exp1_f_ass_pcd - exp51_f_ass_pcd),miss
{txt}
{com}.         
.         // Calculate PCM capacity to consume and assistance
.         gen gap_pcm_food_ass=gap_pcd_food_ass*30
{txt}
{com}.         gen gap_pcm_food_exp=gap_pcd_food_exp*30
{txt}
{com}.         
.         // Calculate PHHM capacity to consume and assistance 
.         gen gap_hhm_food_exp=gap_pcm_food_exp*hh_size
{txt}
{com}. 
. 
. * NON-FOOD EXPENDITURES 
. 
.         //recalculate eid expenditures.
.         *rename exp1_nf_cash_pcm exp1_nf_cash_pcm
.         gen exp1_nf_cash_pcm_12m        =( i1_6m_nonfood_purch_cash             / 12 )  / hh_size
{txt}(930 missing values generated)

{com}. 
.         // Sum expenditures in cash and own production 
.         foreach i of numlist $nonfood{c -(}
{txt}  2{com}.                 egen gap_pcm_nonfood_exp_`i'=rowtotal(exp`i'_nf_cash_pcm exp`i'_nf_cred_pcm ), missing
{txt}  3{com}.                 {c )-}
{txt}
{com}.                 
.         // Calculate total non-food capacity to consume (pcm)
.         order gap_pcm_nonfood_exp_*
{txt}
{com}.         egen gap_pcm_nonfood_exp=rowtotal(gap_pcm_nonfood_exp_1 - gap_pcm_nonfood_exp_26), miss
{txt}
{com}.         
.         // Calculate total food assistance  (pc)
.         order *nf_ass_pcm
{txt}
{com}.         egen gap_pcm_nonfood_ass=rowtotal(exp1_nf_ass_pcm - exp26_nf_ass_pcm), miss
{txt}
{com}.         
.         // Calculate PHHM capacity to consume and assistance 
.         gen gap_hhm_nonfood_exp=gap_pcm_nonfood_exp*hh_size
{txt}
{com}. 
. 
. 
. *  CTC
.         // per housheold and per capita
.         egen gap_pcm_exp=rowtotal(gap_pcm_nonfood_exp gap_pcm_food_exp), missing
{txt}
{com}.         egen gap_hhm_exp=rowtotal(gap_hhm_nonfood_exp gap_hhm_food_exp), missing
{txt}
{com}.         
.         gen PCExp_ECMEN=gap_pcm_exp
{txt}
{com}. 
.         la var gap_pcm_exp "Capacity to Consume - Per Capita"
{txt}
{com}.         la var gap_hhm_exp "Capacity to Consume - Per Household"
{txt}
{com}. /*
> graph bar (mean) gap_hhm_exp (mean) gap_pcm_exp [aweight = weight] if hh_size<=5, over(meb_area) blabel(bar, format(%9.1gc)) legend(label(1 "Per Household CtC") label(2 "Per Capita CtC"))
> graph export "C:\Users\angela.diperna\Documents\Stata\DJIDATA\Analysis\CTC per household and per capita  hh_size max 5.pdf", as(pdf) replace
> graph bar (mean) gap_hhm_exp (mean) gap_pcm_exp [aweight = weight], over(meb_area) blabel(bar, format(%9.1gc)) legend(label(1 "Per Household CtC") label(2 "Per Capita CtC"))
> graph export "C:\Users\angela.diperna\Documents\Stata\DJIDATA\Analysis\CTC per household and per capita all hh_size.pdf", as(pdf) replace
> */
. 
. * Assistance
.         // per housheold and per capita
.         egen assistance_pcm = rowtotal( gap_pcm_nonfood_ass  gap_pcm_food_ass) , miss
{txt}
{com}.         gen assistance_hhm = assistance_pcm*hh_size if hh_size!=.
{txt}
{com}. 
. 
. * MEB
.         gen food_meb_pc=.
{txt}(1,168 missing values generated)

{com}.         replace food_meb_pc=4770 if meb_area==1
{txt}(657 real changes made)

{com}.         replace food_meb_pc=6630 if meb_area==2
{txt}(178 real changes made)

{com}.         replace food_meb_pc=5910 if meb_area==3
{txt}(333 real changes made)

{com}.         
.         gen FoodMEB=food_meb_pc
{txt}
{com}. 
. 
.         gen meb_pc_camps=.
{txt}(1,168 missing values generated)

{com}.         replace meb_pc_camps=6718 if  meb_area==1
{txt}(657 real changes made)

{com}.         replace meb_pc_camps=9338 if  meb_area==2
{txt}(178 real changes made)

{com}. 
. 
.         gen meb_hhm=.
{txt}(1,168 missing values generated)

{com}.         replace meb_hhm=6718 if hh_size==1 & meb_area==1
{txt}(109 real changes made)

{com}.         replace meb_hhm=13436 if hh_size==2 & meb_area==1
{txt}(63 real changes made)

{com}.         replace meb_hhm=20154 if hh_size==3 & meb_area==1
{txt}(74 real changes made)

{com}.         replace meb_hhm=26872 if hh_size==4 & meb_area==1
{txt}(79 real changes made)

{com}.         replace meb_hhm=33590 if hh_size==5 & meb_area==1
{txt}(82 real changes made)

{com}.         replace meb_hhm=meb_pc_camps*hh_size if hh_size>5 & meb_area==1 & hh_size!=.
{txt}(250 real changes made)

{com}. 
. 
.         replace meb_hhm=9338 if hh_size==1 & meb_area==2
{txt}(38 real changes made)

{com}.         replace meb_hhm=18676 if hh_size==2 & meb_area==2
{txt}(34 real changes made)

{com}.         replace meb_hhm=28014 if hh_size==3 & meb_area==2
{txt}(34 real changes made)

{com}.         replace meb_hhm=37352 if hh_size==4 & meb_area==2
{txt}(18 real changes made)

{com}.         replace meb_hhm=46690 if hh_size==5 & meb_area==2
{txt}(20 real changes made)

{com}.         replace meb_hhm=meb_pc_camps*hh_size if hh_size>5 & meb_area==2 & hh_size!=.
{txt}(34 real changes made)

{com}. 
. 
.         replace meb_hhm=19573 if hh_size==1 & meb_area==3
{txt}(187 real changes made)

{com}.         replace meb_hhm=25483 if hh_size==2 & meb_area==3
{txt}(39 real changes made)

{com}.         replace meb_hhm=43008 if hh_size==3 & meb_area==3
{txt}(17 real changes made)

{com}.         replace meb_hhm=48918 if hh_size==4 & meb_area==3
{txt}(27 real changes made)

{com}.         replace meb_hhm=61422 if hh_size==5 & meb_area==3
{txt}(25 real changes made)

{com}.         replace meb_hhm=(food_meb_pc*hh_size)+31872 if hh_size>5  & meb_area==3 & hh_size!=.
{txt}(38 real changes made)

{com}. 
. 
.         gen meb_pcm=.
{txt}(1,168 missing values generated)

{com}.         replace meb_pcm=meb_hhm/hh_size if hh_size!=.
{txt}(1,168 real changes made)

{com}.         gen MEB=meb_pcm
{txt}
{com}. 
. *Calculate the Gap excluding assistance
. 
.         gen total_gap_hhm= meb_hhm - gap_hhm_exp
{txt}
{com}.         gen total_gap_pcm= meb_pcm - gap_pcm_exp
{txt}
{com}. 
. *Calculate the Gap including assistance
. 
.         gen total_gap_ass_hhm= meb_hhm - gap_hhm_exp - assistance_hhm
{txt}
{com}.         gen total_gap_ass_pcm= meb_pcm - gap_pcm_exp - assistance_pcm
{txt}
{com}. 
.         
. *Calculate the Food Gap 
.         
.         gen food_gap_pcm=.
{txt}(1,168 missing values generated)

{com}.         replace food_gap_pcm= food_meb_pc - gap_pcm_food_exp
{txt}(1,168 real changes made)

{com}.         replace food_gap_pcm=0 if food_gap_pcm<0
{txt}(204 real changes made)

{com}.         gen food_gap_perc=food_gap_pcm/food_meb_pc
{txt}
{com}. 
