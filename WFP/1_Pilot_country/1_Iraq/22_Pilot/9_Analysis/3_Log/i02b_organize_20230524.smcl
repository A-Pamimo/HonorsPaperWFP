. /*  We are trying to calculate the gap of in-kind assistance by measuring the 
>         Cost of Essential Needs (SMEB/Food MEB) – Household Economic Capacity 
>         (Food Expenditure or Calorie intake)                                                                              */
. 
.         tempfile master bangladesh cameroon drc tigray gambia jordan mozambique rwanda sierraleone somaliland djibouti
{txt}
{com}.         
.         //lebanon
.         
.         ** bangladesh
.         use "${c -(}data_bgd{c )-}.dta", clear
{txt}(File created by user 'onadata' at Mon Nov 22 07:40:03 2021)

{com}. /*  Bangladesh: the survey date variable is a long numbers that can't be 
>         converted to anything meaningful but the dataset was created at Nov 22 2021 */
.         
.         keep country year national refugees hhid weights                           ///
>                  HHSize HHExpFood_MN_1M HHExp_Food_CRD_1M HHExp_Food_GiftAid_1M ///
