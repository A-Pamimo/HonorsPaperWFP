{com}. 
. ********************************************************************************
. *                                       PART 2: rCSIGenderMealSize
. *******************************************************************************/
. 
.         **      Reshape 
.         
.         keep HHID Group Status FCG rCSIGenderMealSize_F rCSIGenderMealSize_M     
{txt}
{com}.         keep if !mi(rCSIGenderMealSize_F) & !mi(rCSIGenderMealSize_M)
{txt}(338 observations deleted)

{com}.         
.         reshape long rCSIGenderMealSize_, ///
>                         i(HHID Group Status FCG) j(Gender) string
{txt}(j = F M)

Data{col 36}Wide{col 43}->{col 48}Long
{hline 77}
Number of observations     {res}         238   {txt}->   {res}476         
{txt}Number of variables        {res}           6   {txt}->   {res}6           
{txt}j variable (2 values)                     ->   {res}Gender
{txt}xij variables:
{res}rCSIGenderMealSize_F rCSIGenderMealSize_M {txt}->   {res}rCSIGenderMealSize_
{txt}{hline 77}

{com}.         ren *_ *
{res}{txt}
{com}.         
.         gen Female = (Gender == "F")
{txt}
{com}.         
.         lab def fem_l 1 "Female" 0 "Male"
{txt}
{com}.         lab def gender_option 1 "Mainly adult male (18+)"       ///
>                                                   2 "Mainly adult female (18+)" ///
>                                                   3 "Mainly kids and youth male (<18)" ///
>                                                   4 "Mainly kids and youth female (<18)" ///
>                                                   5 "All adults equally"                ///
>                                                   6 "All family members equally"                                          
{txt}
{com}.         lab val Female fem_l
{txt}
{com}.         lab val rCSIGenderMealSize gender_option
{txt}
{com}.         
.         tab  Status Female if !mi(rCSIGenderMealSize)

 {txt}Household {c |}
Status IDP {c |}
       vs. {c |}        Female
   Refugee {c |}      Male     Female {c |}     Total
{hline 11}{c +}{hline 22}{c +}{hline 10}
       IDP {c |}{res}       108        108 {txt}{c |}{res}       216 
