>         note("Note: Bangladesh has assistance value from WFP", ring(4)  ///
>                 pos(6) size(2.5)) 
>           
>         graph export "${c -(}output{c )-}/In_Kind_Assistance_Gap_Bangladesh_FES.png", replace
> */
