{com}.         
.         ** export codebook
. *       iecodebook export using "${c -(}codebook{c )-}/Somaliland_raw_codebook.xlsx", replace
.         
. ********************************************************************************
. *                                                       Correct relevant variable types
. *******************************************************************************/
.         
.         label def yesno 1 "Yes" 0 "No"
{txt}
{com}.         
.         * categorical string to byte
. local conv_cat_var livelihood_zone settlement HDwellType _1sex_head
{txt}
{com}.           
. foreach var of local conv_cat_var {c -(}
{txt}  2{com}.         encode  `var', gen(`var'_b)
{txt}  3{com}.         order   `var'_b, a(`var')
{txt}  4{com}.         drop    `var'
{txt}  5{com}.         rename  `var'_b `var'
{txt}  6{com}. {c )-}
{res}{txt}
{com}. 
.         * numeric string to byte/int    
. local conv_num_var _3511FoodGift_rice _3511FoodGift_sorg _3511FoodGift_maize              ///
>           _3511FoodGift_sugar _3521FoodAsst_rice _3521FoodAsst_sorg _3521FoodAsst_maize   ///
>           _3521FoodAsst_CSB _3521FoodAsst_sugar _41cereals_grainsdays _41roots_tubersdays ///
>           _41legumes_nutsdays _41orangevegs_days _41green_leafyvegsdays _41other_vegsdays ///
