>           lab(2 "Marginally Food Secure")                                                       ///
>           lab(3 "Moderately Food Insecure")                                             ///
>           lab(4 "Severely Food Insecure") size(2.5))
{res}{txt}
{com}.           
.         graph export "${c -(}output{c )-}/In_Kind_Assistance_Gap_FES.png", replace
{txt}{p 0 4 2}
