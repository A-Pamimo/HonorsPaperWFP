{com}.         // other cbt doesn't count, only Bangladesh and DRC has WFP assistance value
.         // and it equals to humanitarian assistance value, so only deduct one
.         
.         replace HHAsstHumanCBTRec_1M = 0 if mi(HHAsstHumanCBTRec_1M)
{txt}(45,881 real changes made)

{com}.         // Only Bangladesh and DRC have Assistance value from WFP sources
.         
.         keep Country hhid HHSize HHExp_Food_Own_1M HHExpFood_MN_1M HHExp_Food_CRD_1M ///
>                  HHAsstHumanCBTRec_1M   ///
>                  FoodMEB ECMEN_recomp ECMEN_SMEB_recomp                                 ///
