.         use "${c -(}dta{c )-}/Iraq_Full_Household_Raw.dta", clear
{txt}
{com}.         
.         /* check modality first */
.         
.         ** F2F Date Time Check 
.         gen date_start_str = substr(start, 1, 10)
{txt}(86 missing values generated)

{com}.         gen date_start = clock(date_start_str, "YMD") 
{txt}(86 missing values generated)

{com}.         gen date_end_str = substr(end, 1, 10)
{txt}(86 missing values generated)

{com}.         gen date_end = clock(date_end_str, "YMD") 
{txt}(86 missing values generated)

{com}.         
.         format date_start date_end %tc
{txt}
{com}.         gen date_diff = date_start - date_end // 579 no diff and all negative ok 
{txt}(86 missing values generated)

{com}.         // use today as start date - all the same
.         
.         ** Remote Date Time Check 
.         gen r_date_start_str = substr(r_start, 1, 10)
{txt}(136 missing values generated)

{com}.         gen r_date_start = clock(r_date_start_str, "YMD") 
{txt}(136 missing values generated)

{com}.         gen r_date_end_str = substr(r_end, 1, 10)
{txt}(136 missing values generated)

{com}.         gen r_date_end = clock(r_date_end_str, "YMD") 
{txt}(136 missing values generated)

{com}.         
.         format r_date_start r_date_end %tC
{txt}
{com}.         gen r_date_diff = r_date_start - r_date_start // perfect 540 no diff
{txt}(136 missing values generated)

{com}.         // use submission time
. 
.         gen time_diff_start      = date_start - r_date_start
{txt}(222 missing values generated)

{com}.         gen time_diff_end                = date_end   - r_date_end
{txt}(222 missing values generated)

{com}.         
.         gen time_diff_submission = ___submission_time - r____submission_time
{txt}(222 missing values generated)

{com}.         gen time_diff_today              = today - r_today
{txt}(222 missing values generated)

{com}.         gen time_inconsistent    = time_diff_today - time_diff_submission
{txt}(222 missing values generated)

{com}.         
.         ** use both date 
.         gen     f2f_first_1 = (time_diff_submission < 0 & time_diff_today < 0) if !mi(time_diff_today)
{txt}(222 missing values generated)

{com}.         gen     f2f_first_2 = (time_diff_end < 0 & time_diff_start < 0) if !mi(time_diff_start)
{txt}(222 missing values generated)

{com}.         gen     f2f_first = (f2f_first_1 == 1 & f2f_first_2 == 1) 
{txt}
{com}.         replace f2f_first = 1 if _merge == 1 // 136 f2f only
{txt}(136 real changes made)

{com}.         
.         ** use both date 
.         gen     rm_first_1  = (time_diff_submission > 0 & time_diff_today > 0) if !mi(time_diff_today)
{txt}(222 missing values generated)

{com}.         gen     rm_first_2  = (time_diff_end > 0 & time_diff_start > 0) if !mi(time_diff_start)
{txt}(222 missing values generated)

{com}.         gen     rm_first  = (rm_first_1 == 1 & rm_first_2 == 1) 
{txt}
{com}.         replace rm_first  = 1 if _merge == 2 // 86 rm only
{txt}(86 real changes made)

{com}.         
. *       keep if f2f_first == 0 & rm_first == 0
. /*      keep HHID time_diff_submission ___submission_time r____submission_time ///
>                  f2f_first rm_first time_diff_today today r_today time_inconsistent ///
>                  start end r_start r_end time_diff_start time_diff_end*/
. 
.         order HHID start r_start end r_end today r_today ___submission_time r____submission_time, first
{txt}
{com}. 
.         replace rm_first  = 1 if inlist(HHID, 110101121, 110101124, 110101125, 110101127, 3300201164)
{txt}(5 real changes made)

{com}.         replace f2f_first = 1 if inlist(HHID, 210201045, 320101080, 2100101154, 2100101200, 2100101218, 2100201055, 2100201058, 4200101041, 4200101047, 4200101048)
{txt}(10 real changes made)

{com}.         
.         order f2f_first rm_first, first
