.         count if f2f_first == 1 & !mi(r_start) // assigned to f2f first and finished remote 233
  {res}233
{txt}
{com}.         count if rm_first == 1  & !mi(start)   // assigned to remote first and finished f2f 221
  {res}221
{txt}
