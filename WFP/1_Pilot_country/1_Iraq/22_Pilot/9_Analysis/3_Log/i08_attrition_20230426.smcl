{com}.         
.         * Percentile & Quintile
.         sort    HHWealth_Score
{txt}
{com}.         pctile  WI_Ppct = HHWealth_Score, nq(306) genp(WI_Ppercent)
{txt}
{com}.         gen     WI_Ppercentile = round(WI_Ppercent)
{txt}(285 missing values generated)

{com}.         egen    WI_Pquin = cut(WI_Ppercentile), at (0,20,40,60,80,100) 
{txt}(286 missing values generated)

{com}.         gen     WI_Pquintile = (WI_Pquin / 20) + 1 
{txt}(286 missing values generated)

{com}.         
.         drop WI_Pquin
{txt}
{com}.         
.         lab var HHWealth_Score  "Household Common Wealth Score PCA"
{txt}
{com}.         lab var WI_Ppct                 "Household wealth score for percentile"
{txt}
{com}.         lab var WI_Ppercent             "Household wealth score raw percentage"
{txt}
{com}.         lab var WI_Ppercentile  "Household wealth score rounded percentage"
{txt}
{com}.         lab var WI_Pquintile    "Household wealth score quintile"
{txt}
{com}.         
.         sum     HHWealth_Score, detail

