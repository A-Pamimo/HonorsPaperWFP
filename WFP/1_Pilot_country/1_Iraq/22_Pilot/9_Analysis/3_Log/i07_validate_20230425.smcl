{com}.         
. /*      Sex of the | Sex of the respondent
>         respondent |    Female       Male |     Total
>         -----------+----------------------+----------
>                 Female |        83        149 |       232 
>                   Male |        27        195 |       222 
>         -----------+----------------------+----------
>                  Total |       110        344 |       454 
> */
.         gen Respondent = (RESPSex == r_RESPSex) & !mi(RESPSex) & !mi(r_RESPSex)
{txt}
{com}.         // if Respondent == 1 means the same gender interviewed 
