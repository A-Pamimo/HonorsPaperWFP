. *                                               PART 3: Label Variables
. *******************************************************************************/        
. 
.         label def YesNo                 0 "No"   1 "Yes"
{txt}
{com}.         label val $var_assets $var_house Lcs_Stress_Coping Lcs_Crisis_Coping ///
>                           Lcs_Emergency_Coping HH_Vul_CARI YesNo
{txt}
{com}.         
