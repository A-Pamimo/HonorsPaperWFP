.         // very different results which seem like 3 people involved
.         // Standard MDDW method - SNF home group will be grains
.         gen MDDW_Staples         = (PWMDDWStapCerR == 1 |  PWMDDWStapRooR == 1 | PWMDDWSnfR == 1) if !mi(PWMDDWStapCerR)
{txt}(159 missing values generated)

{com}.         gen MDDW_Pulses          = (PWMDDWPulseR == 1)  if !mi(PWMDDWPulseR)
{txt}(159 missing values generated)

{com}.         gen MDDW_NutsSeeds       = (PWMDDWNutsR == 1)   if !mi(PWMDDWNutsR)
{txt}(159 missing values generated)

{com}.         gen MDDW_Dairies         = (PWMDDWDairyR == 1   | PWMDDWMilkR == 1) if !mi(PWMDDWDairyR)
{txt}(159 missing values generated)

{com}.         gen MDDW_MeatFish        = (PWMDDWPrMeatOR == 1 | PWMDDWPrMeatFR == 1 | PWMDDWPrMeatProR == 1 | ///
>                                                         PWMDDWPrMeatWhiteR == 1 |  PWMDDWPrFishR == 1) if !mi(PWMDDWPrMeatOR)
{txt}(159 missing values generated)

{com}.         gen MDDW_Eggs            = (PWMDDWPrEggR == 1)  if !mi(PWMDDWPrEggR)
{txt}(159 missing values generated)

{com}.         gen MDDW_LeafGVeg        = (PWMDDWVegGreR == 1) if !mi(PWMDDWVegGreR)
{txt}(159 missing values generated)

{com}.         gen MDDW_VitA            = (PWMDDWVegOrgR == 1 | PWMDDWFruitOrgR == 1) if !mi(PWMDDWVegOrgR)
{txt}(159 missing values generated)

{com}.     gen MDDW_OtherVeg    = (PWMDDWVegOthR == 1) if !mi(PWMDDWVegOthR)
{txt}(159 missing values generated)

{com}.     gen MDDW_OtherFruits = (PWMDDWFruitOthR == 1) if !mi(PWMDDWFruitOthR)
{txt}(159 missing values generated)

{com}.         gen MDDW_Index = MDDW_Staples + MDDW_Pulses + MDDW_NutsSeeds + MDDW_Dairies + MDDW_MeatFish + ///
>                            MDDW_Eggs + MDDW_LeafGVeg + MDDW_VitA + MDDW_OtherVeg + MDDW_OtherFruits if !mi(MDDW_Staples)
{txt}(159 missing values generated)

{com}.         gen MDDW_Index_5 = (MDDW_Index >= 5) if !mi(MDDW_Index)
{txt}(159 missing values generated)

{com}.         
.         gen MDDW_Staples_oth     = (PWMDDWStapCer_oth == 1 |  PWMDDWStapRoo_oth == 1 | PWMDDWSnf_oth == 1) if !mi(PWMDDWStapCer_oth)
{txt}(179 missing values generated)

{com}.         gen MDDW_Pulses_oth              = (PWMDDWPulse_oth == 1)  if !mi(PWMDDWPulse_oth)
{txt}(179 missing values generated)

{com}.         gen MDDW_NutsSeeds_oth   = (PWMDDWNuts_oth == 1)        if !mi(PWMDDWNuts_oth)
{txt}(179 missing values generated)

{com}.         gen MDDW_Dairies_oth     = (PWMDDWDairy_oth == 1        | PWMDDWMilk_oth == 1) if !mi(PWMDDWDairy_oth)
{txt}(179 missing values generated)

{com}.         gen MDDW_MeatFish_oth    = (PWMDDWPrMeatO_oth == 1 | PWMDDWPrMeatF_oth == 1 | PWMDDWPrMeatPro_oth == 1 | ///
>                                                         PWMDDWPrMeatWhite_oth == 1 |  PWMDDWPrFish_oth == 1) if !mi(PWMDDWPrMeatO_oth)
{txt}(179 missing values generated)

{com}.         gen MDDW_Eggs_oth                = (PWMDDWPrEgg_oth == 1)  if !mi(PWMDDWPrEgg_oth)
{txt}(179 missing values generated)

{com}.         gen MDDW_LeafGVeg_oth= (PWMDDWVegGre_oth == 1) if !mi(PWMDDWVegGre_oth)
{txt}(179 missing values generated)

{com}.         gen MDDW_VitA_oth                = (PWMDDWVegOrg_oth == 1 | PWMDDWFruitOrg_oth == 1) if !mi(PWMDDWVegOrg_oth)
{txt}(179 missing values generated)

{com}.     gen MDDW_OtherVeg_oth        = (PWMDDWVegOth_oth == 1) if !mi(PWMDDWVegOth_oth)
{txt}(179 missing values generated)

{com}.     gen MDDW_OtherFruits_oth = (PWMDDWFruitOth_oth == 1) if !mi(PWMDDWFruitOth_oth)
{txt}(179 missing values generated)

{com}.         gen MDDW_Index_oth = MDDW_Staples_oth + MDDW_Pulses_oth + MDDW_NutsSeeds_oth + MDDW_Dairies_oth + MDDW_MeatFish_oth + ///
>                            MDDW_Eggs_oth + MDDW_LeafGVeg_oth + MDDW_VitA_oth + MDDW_OtherVeg_oth + MDDW_OtherFruits_oth if !mi(MDDW_Staples_oth)
{txt}(179 missing values generated)

{com}.         gen MDDW_Index_5_oth = (MDDW_Index_oth >= 5) if !mi(MDDW_Index_oth)
{txt}(179 missing values generated)

