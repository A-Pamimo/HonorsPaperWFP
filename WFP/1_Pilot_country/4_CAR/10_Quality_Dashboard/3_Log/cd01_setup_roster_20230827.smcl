{com}.         
. * load dataset
. * ------------
.         use "${c -(}d_temp{c )-}/CAR_F2F_Roster_Correct_`cdate'.dta", clear 
{txt}
{com}.         compress
{txt}  (0 bytes saved)

{com}.         
.         * create unique ID for each individual 
.         makeid HH_Index ___index, gen(Ind_Index) project(CAR)
{txt}(data now sorted by {bf:HH_Index ___index})
(data now sorted by {bf:Ind_Index})

{com}.         
. ********************************************************************************
. *                                       PART 2: Create Household Level Variables
. *******************************************************************************/
.         
.         ** Create household level tag variable to filter
.         egen HH_Tag = tag(HH_Index)
{txt}
{com}.         
.         ** [Quality Outcome] check if respondent is in the roster
.         bysort  HH_Index: egen Num_Resp = total(RESPYN == 1)
{txt}
{com}.         tab             Num_Resp if HH_Tag == 1         // should be 1

   {txt}Num_Resp {c |}      Freq.     Percent        Cum.
{hline 12}{c +}{hline 35}
          0 {c |}{res}         17        1.93        1.93
{txt}          1 {c |}{res}        828       93.88       95.80
{txt}          2 {c |}{res}         25        2.83       98.64
{txt}          3 {c |}{res}          3        0.34       98.98
{txt}          6 {c |}{res}          2        0.23       99.21
{txt}          7 {c |}{res}          2        0.23       99.43
{txt}          8 {c |}{res}          3        0.34       99.77
{txt}          9 {c |}{res}          1        0.11       99.89
{txt}         12 {c |}{res}          1        0.11      100.00
{txt}{hline 12}{c +}{hline 35}
      Total {c |}{res}        882      100.00
{txt}
{com}.         gen             Err_Resp = (Num_Resp != 1)      
{txt}
{com}. 
.         ** [Quality Outcome] check total number of hh member marked as head
.         bysort  HH_Index: egen Num_hhh = total(PRelationHHH == 100)
{txt}
{com}.         tab     Num_hhh if  HH_Tag == 1         // should be 1

    {txt}Num_hhh {c |}      Freq.     Percent        Cum.
{hline 12}{c +}{hline 35}
          0 {c |}{res}         11        1.25        1.25
{txt}          1 {c |}{res}        863       97.85       99.09
{txt}          2 {c |}{res}          6        0.68       99.77
{txt}          5 {c |}{res}          1        0.11       99.89
{txt}          7 {c |}{res}          1        0.11      100.00
{txt}{hline 12}{c +}{hline 35}
      Total {c |}{res}        882      100.00
{txt}
{com}.         gen             Err_Head = (Num_hhh != 1)
{txt}
{com}.         
.         ** [Quality Outcome] check total number of hh member marked as spouse
.         bysort  HH_Index: egen Num_Spouse = total(PRelationHHH == 200)
{txt}
{com}.         tab     Num_Spouse if  HH_Tag == 1              // should be 0 or 1

 {txt}Num_Spouse {c |}      Freq.     Percent        Cum.
{hline 12}{c +}{hline 35}
          0 {c |}{res}        242       27.44       27.44
{txt}          1 {c |}{res}        623       70.63       98.07
{txt}          2 {c |}{res}         17        1.93      100.00
{txt}{hline 12}{c +}{hline 35}
      Total {c |}{res}        882      100.00
{txt}
{com}.         gen             Err_Spouse = (Num_Spouse > 1 & !mi(Num_Spouse))
{txt}
{com}.         
.         ** [Quality Outcome] check respondent age and sex
.         bysort HH_Index: egen Resp_Sex  = min(cond(RESPYN == 1, PSex, .))
{txt}(1,994 missing values generated)

{com}.         bysort HH_Index: egen Resp_Age  = min(cond(RESPYN == 1, PAge, .))
{txt}(1,994 missing values generated)

{com}. 
.         ** [Quality Outcome] check household size
.         bysort HH_Index: gen Num_Ind = _n
{txt}
{com}.         bysort HH_Index: egen Num_Household = max(Num_Ind)
{txt}
{com}. *       bysort HH_Index: egen Num_Household_check = max(getP)
. 
.                                 ********* Roster Error Flag - post HHID *********
.                                 
.         **      The age of the spouse is less than 9
.         bysort HH_Index: egen Age_Spouse = min(cond(PRelationHHH == 200, PAge, .))
{txt}(2,014 missing values generated)

{com}.         gen        Err_SpouseAge = (Age_Spouse < 9) if !mi(Age_Spouse)
{txt}(2,014 missing values generated)

{com}.         
.         **      The age difference between parent and head is less than 9.
.         bysort HH_Index: egen Age_Head     = max(cond(PRelationHHH == 100, PAge, .))
{txt}(1,117 missing values generated)

{com}.         bysort HH_Index: egen Age_Parent = min(cond(PRelationHHH == 400, PAge, .))
{txt}(4,935 missing values generated)

{com}.         gen        Err_ParentAge = (Age_Parent - Age_Head < 9) if !mi(Age_Parent) & !mi(Age_Head)
{txt}(5,162 missing values generated)

{com}.         
.         **      The age of parent is less than 18
.         gen     Err_ParentMinor = (Age_Parent < 18) if mi(Age_Parent)
{txt}(464 missing values generated)

{com}.         
.         **      The hoh and his/her spouse have the same sex
.         bysort HH_Index: gen Err_SameSex = (PRelationHHH == 200 & PSex == PSex[1] ///
>                                                                             & PRelationHHH[1] == 100)
{txt}
{com}.         
.                                 ********* Roster Household-Level Outcomes  *********
.         
.         ** [Respondent] Relationship to head of household
.         bysort HH_Index: egen RESPRelationHHH = min(cond(RESPYN == 1, PRelationHHH, .))
{txt}(95 missing values generated)

{com}.         
.         ** [Demo] Head of Household Sex
.         bysort HH_Index: egen HHH_Sex  = min(cond(PRelationHHH == 100, PSex, .))
{txt}(1,117 missing values generated)

{com}.         ** [Demo] Head of Household Age
.         bysort HH_Index: egen HHH_Age  = min(cond(PRelationHHH == 100, PAge, .))
{txt}(1,117 missing values generated)

{com}.         ** [Demo] Head of Household Education
.         bysort HH_Index: egen HHH_Literate  = min(cond(PRelationHHH == 100, PSchoolEver, .))
{txt}(1,117 missing values generated)

{com}.         bysort HH_Index: egen HHH_Education = min(cond(PRelationHHH == 100, PschoolLevel, .))
{txt}(2,381 missing values generated)

{com}.         
.         ** [Demo] Total Male & Female
.         bysort  HH_Index: egen Num_Male   = total(PSex == 1)
{txt}
{com}.         bysort  HH_Index: egen Num_Female = total(PSex == 0)
{txt}
{com}.         
.         ** [Demo] Total number of children by sex
.         bysort  HH_Index: egen Num_Child = total(PAge < 18)
{txt}
{com}.         bysort  HH_Index: egen Num_Boy   = total(PSex == 1 & PAge < 18)
{txt}
{com}.         bysort  HH_Index: egen Num_Girl  = total(PSex == 0 & PAge < 18)
{txt}
{com}.         
.         ** [Demo] Total number of Senior
.         bysort  HH_Index: egen Num_Senior = total(PAge >= 60)
{txt}
{com}.         
.         ** [Demo] Total number of Adults
.         bysort  HH_Index: egen Num_Adult = total(PAge >= 18 & PAge < 60)
{txt}
{com}.                    
. ********************************************************************************
. *                                                       PART 3: Label new variables
. *******************************************************************************/
.         
.         order Err_*, a(HH_Index)
{txt}
{com}.         
.         label val RESPRelationHHH       PRelationHHH
{txt}
{com}.         label val HHH_Sex Resp_Sex      PSex
{txt}
{com}.         label val HHH_Literate          PSchoolEver
{txt}
{com}.         label val HHH_Education         PschoolLevel
{txt}
{com}.         
.         label var HH_Index                      "Household Index: Identifier"
{txt}
{com}.         label var Num_Ind                       "Individual Index: Household Size"
{txt}
{com}.         label var Err_Resp                      "Error: no or more than 1 respondent in roster"
{txt}
{com}.         label var Err_Head                      "Error: no or more than 1 household head in roster"
{txt}
{com}.         label var Err_Spouse            "Error: no or more than 1 spouse in roster"
{txt}
{com}.         label var Err_SpouseAge         "Error: age of the spouse < 9"
{txt}
{com}.         label var Err_ParentAge         "Error: age diff between head and youngest parent < 9"
{txt}
{com}.         label var Err_ParentMinor       "Error: age of parent < 18"
{txt}
{com}.         label var Err_SameSex           "Error: head and spouse of same sex"
{txt}
{com}.         label var Num_Resp                      "Total number of respondent in roster"
{txt}
{com}.         label var Num_hhh                       "Total number of household head in roster"
{txt}
{com}.         label var Num_Spouse            "Total number of spouse"
{txt}
{com}.         label var Num_Household         "Total number of household member"
{txt}
{com}.         label var Num_Male                      "Total number of male household member"
{txt}
{com}.         label var Num_Female            "Total number of female household member"
{txt}
{com}.         label var Num_Boy                       "Total number of boys (male under 18)"
{txt}
{com}.         label var Num_Girl                      "Total number of girls (female under 18)"
{txt}
{com}.         label var Num_Senior            "Total number of senior"
{txt}
{com}.         label var Num_Adult                     "Total number of adults"
{txt}
{com}.         label var Num_Child                     "Total number of children"
{txt}
{com}.         
.         label var Age_Spouse            "Age of spouse (min if more than one)"
{txt}
{com}.         label var Age_Head                      "Age of household head"
{txt}
{com}.         label var Age_Parent            "Age of parent (min if more than one)"
{txt}
{com}.         
.         label var Resp_Sex                      "Respondent Sex"
{txt}
{com}.         label var Resp_Age                      "Respondent Age"
{txt}
{com}.         label var RESPRelationHHH       "Respondent relationship to head of household"
{txt}
{com}.         
.         label var HHH_Sex                       "Head of Household Sex"
{txt}
{com}.         label var HHH_Age                       "Head of Household Age"
{txt}
{com}.         label var HHH_Literate          "Household head has attended school"
{txt}
{com}.         label var HHH_Education         "Education level of household head"
{txt}
{com}.         
