{com}.         
.         ** keep relevant variables
.         keep Admin1Name Admin2Name Admin3Name Admin5Name house_type age relationship ///
>                  hh_status hh_head_sex hh_head_marital hh_head_educ hh_size             ///
>                  mem_lessthan15 mem_greaterthan60 mem_disability area_house             ///
>                  roofing_material_house floor_material_house phone_ownership            ///
>                  mobile_coverage Modality_Type Length_Type Ind_OutSample                        ///
>                  Phone_Assignment Uid ___index
{txt}
{com}.         
. ********************************************************************************
. *                                                       PART 2: Organize Sample Variables
. *******************************************************************************/
.         
.         replace Modality_Type = Modality_Type + 1
{txt}(2,287 real changes made)

{com}.         replace Length_Type   = Length_Type + 1
{txt}(2,287 real changes made)

{com}.         
.         ren Modality_Type       Assign_Modality
{res}{txt}
{com}.         ren Length_Type         Assign_Length
{res}{txt}
{com}.         ren Admin1Name          Geo_Admin1
{res}{txt}
{com}.         ren Admin2Name          Geo_Admin2
{res}{txt}
{com}.         ren Admin3Name          Geo_Admin3
{res}{txt}
{com}.         ren Admin5Name          Geo_Admin5
{res}{txt}
{com}. 
.         ren        Uid HHID
{res}{txt}
{com}.         ren        Phone_Assignment Assign_Phone
{res}{txt}
{com}.         
.         order  HHID, first
{txt}
{com}.         order  Assign_Modality Assign_Length Assign_Phone Geo_Admin*, a(HHID)
{txt}
{com}.         order  relationship hh_status, a(age)
{txt}
{com}.         order  hh_head_sex hh_head_marital, b(hh_head_educ)
{txt}
{com}.         order  house_type area_house, a(mem_disability)
{txt}
{com}.         
.         * Randomly select 300 from the 737 non phone owner face to face
.         set  seed 208976                        // set stable seed
{txt}
{com}.         sort ___index, stable
{txt}
{com}.         gen  Select_RandomNum = uniform() if phone_ownership == 0 & ///
>                                                                                  mobile_coverage == 1 & ///
>                                                                                  Assign_Modality == 1
{txt}(1,763 missing values generated)

{com}.         egen Select_Order         = rank(Select_RandomNum)                              ///
>                                                                           if phone_ownership == 0 & ///
>                                                                                  mobile_coverage == 1 & ///
>                                                                                  Assign_Modality == 1
{txt}(1,763 missing values generated)

{com}.                                                                                  
.         gen  Select_Yes           = (Select_Order <= 300) if phone_ownership == 0 & ///
>                                                                                  mobile_coverage == 1 & ///
>                                                                                  Assign_Modality == 1
{txt}(1,763 missing values generated)

{com}.         
.         gen     Random_Comparison = 1 if Select_Yes == 1                // F2F Random Partial
{txt}(2,200 missing values generated)

{com}.         replace Random_Comparison = 0 if Assign_Phone == 1      // Remote Gave Phone 
{txt}(300 real changes made)

{com}.         
.         drop Select_RandomNum Select_Order
{txt}
{com}.         
. ********************************************************************************
. *                                                       PART 3: Label Sample Variables
. *******************************************************************************/
.         
.         label var HHID                          "Household ID"
{txt}
{com}.         label var Assign_Modality       "Assigned Survey Modality"
{txt}
{com}.         label var Assign_Length         "Assigned Survey Length"
{txt}
{com}.         label var Geo_Admin1            "Geographic Region: Admin 1"
{txt}
{com}.         label var Geo_Admin2            "Geographic Region: Admin 2"
{txt}
{com}.         label var Geo_Admin3            "Geographic Region: Admin 3"
{txt}
{com}.         label var Geo_Admin5            "Geographic Region: Admin 5"
{txt}
{com}.         
.         label var age                           "List respondent age"
{txt}
{com}.         label var relationship          "List respondent relationship to head of household"
{txt}
{com}.         label var hh_status                     "Household residence status"
{txt}
{com}.         label var hh_head_sex           "Household head sex"
{txt}
{com}.         label var hh_head_marital       "Household head married"
{txt}
{com}.         label var hh_head_educ          "Household head years of education"
{txt}
{com}.         label var hh_size                       "Household size"
{txt}
{com}.         label var mem_lessthan15        "Number of household member younger than 15"
{txt}
{com}.         label var mem_greaterthan60     "Number of household member older than 60"
{txt}
{com}.         label var mem_disability        "Has household member with disability/chronic disease"
{txt}
{com}.         label var area_house            "Number of rooms"
{txt}
{com}.         label var house_type            "Permanent house/structure"
{txt}
{com}.         label var roofing_material_house "Household main roof material"
{txt}
{com}.         label var floor_material_house   "Household main floor material"
{txt}
{com}.         label var phone_ownership       "Household owns phone"
{txt}
{com}.         label var mobile_coverage       "Household has mobile network coverage"
{txt}
{com}.         label var Assign_Phone          "Assigned cell phone to no phone remote"
{txt}
{com}.         label var Select_Yes            "Randomly select 300 from no phone f2f"
{txt}
{com}.         label var Random_Comparison "Indicator: comparing no phone f2f vs. rm"
{txt}
{com}.         
.         compress
  {txt}variable {bf}{res}Select_Yes{sf}{txt} was {bf}{res}float{sf}{txt} now {bf}{res}byte{sf}
  {txt}variable {bf}{res}Random_Comparison{sf}{txt} was {bf}{res}float{sf}{txt} now {bf}{res}byte{sf}
{txt}  (15,000 bytes saved)

{com}.         keep if Ind_OutSample == 0 
{txt}(420 observations deleted)

{com}.         drop Ind_OutSample ___index
{txt}
{com}.         
.         save  "${c -(}sample{c )-}/CAR_Sample_Merge.dta", replace
