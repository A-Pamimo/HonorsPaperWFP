{com}.         
.         order  HHID, first
{txt}
{com}.         order  Assign_Modality Assign_Length Assign_Phone Geo_Admin*, a(HHID)
{txt}
{com}.         order  relationship hh_status, a(age)
{txt}
{com}.         order  hh_head_sex hh_head_marital, b(hh_head_educ)
{txt}
{com}.         order  house_type area_house, a(mem_disability)
{txt}
{com}.         
.         * Randomly select 300 from the 737 non phone owner face to face
.         set  seed 208976                        // set stable seed
{txt}
{com}.         sort ___index, stable
{txt}
{com}.         gen  Select_RandomNum = uniform() if phone_ownership == 0 & ///
>                                                                                  mobile_coverage == 1 & ///
>                                                                                  Assign_Modality == 1
{txt}(1,550 missing values generated)

{com}.         egen Select_Order         = rank(Select_RandomNum)                              ///
>                                                                           if phone_ownership == 0 & ///
>                                                                                  mobile_coverage == 1 & ///
>                                                                                  Assign_Modality == 1
{txt}(1,550 missing values generated)

{com}.                                                                                  
.         gen  Select_Yes           = (Select_Order <= 300) if phone_ownership == 0 & ///
>                                                                                  mobile_coverage == 1 & ///
>                                                                                  Assign_Modality == 1
{txt}(1,550 missing values generated)

{com}.         
.         gen     Random_Comparison = 1 if Select_Yes == 1                // F2F Random Partial
{txt}(1,987 missing values generated)

{com}.         replace Random_Comparison = 0 if Assign_Phone == 1      // Remote Gave Phone 
{txt}(300 real changes made)

{com}.         
.         drop Select_RandomNum Select_Order
{txt}
{com}.         
