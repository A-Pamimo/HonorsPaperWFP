  {txt}variable {bf}{res}Age{sf}{txt} was {bf}{res}int{sf}{txt} now {bf}{res}byte{sf}
  {txt}variable {bf}{res}Marital_Status{sf}{txt} was {bf}{res}long{sf}{txt} now {bf}{res}byte{sf}
  {txt}variable {bf}{res}Education{sf}{txt} was {bf}{res}long{sf}{txt} now {bf}{res}byte{sf}
