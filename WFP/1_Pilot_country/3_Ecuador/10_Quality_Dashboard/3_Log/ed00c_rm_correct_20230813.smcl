{txt}(32 real changes made)

{com}.         drop if mi(HHID)
{txt}(2 observations deleted)

{com}.         
.         ** check duplicates
.         duplicates tag HHID, generate(Dup)

{p 0 4}{txt}Duplicates in terms of {res} HHID{p_end}
{txt}
{com}.         
.         ** Recode for best outcome - combining the consent and availability
.         recode RESPpart (0=4) (1=1) (2=5) (999=6), gen(Outcome_Order)
{txt}(1,700 differences between {bf:RESPpart} and {bf:Outcome_Order})

{com}.         replace Outcome_Order = 2 if Outcome_Order == 1 & RESPAvailable == 2
{txt}(8 real changes made)

{com}.         replace Outcome_Order = 3 if Outcome_Order == 1 & RESPAvailable == 0
{txt}(2 real changes made)

{com}.         
.         label def Outcome_L 1 "Agreed & Available" 2 "Agreed & Later" ///
>                                                 3 "Agreed & Not Available" 4 "Not answer" ///
>                                                 5 "Refused" 6 "Other"
{txt}
{com}.         label val Outcome_Order Outcome_L
{txt}
{com}.         
.         bysort HHID: egen Survey_Outcome = min(Outcome_Order) if Dup >= 1
{txt}(388 missing values generated)

{com}.         replace Survey_Outcome = Outcome_Order if Dup == 0
{txt}(388 real changes made)

{com}.         
.         gen HH_Final = (Outcome_Order == Survey_Outcome)
{txt}
{com}.         
.         egen HH_TAG = tag(HHID) if HH_Final == 1
{txt}
{com}.         
.         replace Survey_Outcome = . if HH_TAG == 0 
{txt}(1,369 real changes made, 1,369 to missing)

{com}.         label val Survey_Outcome Outcome_L
{txt}
{com}.                 
.         ** create one consent variable 
.         gen  Temp_Complete = !mi(HHIncChg)
{txt}
{com}. 
.         bysort HHID: gen Consent = inlist(Survey_Outcome,1,2,3)
{txt}
{com}.         label val Consent sampleYN
{txt}
{com}.         
.         keep if Temp_Complete == 1
{txt}(1,710 observations deleted)

