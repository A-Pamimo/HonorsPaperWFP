{txt}
{com}.         gen RESPHHH     = (RESPRelationHHH              == 100)
{txt}
{com}.         
. ** Outcome: [FCS] Food consumption score 
.         sum FCS*

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
{space 5}FCSStap {c |}{res}        656    4.925305    2.316005          0          7
{txt}{space 4}FCSPulse {c |}{res}        656    2.496951    2.244584          0          7
{txt}{space 4}FCSDairy {c |}{res}        656    2.030488    2.318657          0          7
{txt}{space 7}FCSPr {c |}{res}        656    3.477134    2.391351          0          7
{txt}{space 6}FCSVeg {c |}{res}        656    4.748476    2.564436          0          7
{txt}{hline 13}{c +}{hline 57}
{space 4}FCSFruit {c |}{res}        656    2.897866    2.614743          0          7
{txt}{space 6}FCSFat {c |}{res}        656     5.39939     2.33505          0          7
{txt}{space 4}FCSSugar {c |}{res}        656     5.63872    2.245734          0          7
{txt}
{com}.         gen FCS = FCSStap * 2 + FCSPulse * 3 + FCSDairy * 4 + FCSPr * 4 +                ///
>                           FCSVeg  * 1 + FCSFruit * 1 + FCSFat * 0.5 + FCSSugar * 0.5
{txt}
{com}.         gen FCSCat28 = cond(FCS <= 28, 1, cond(FCS <= 42, 2, 3))
{txt}
{com}. 
. ** Outcome: [rCSI] Reduced Coping Strategies 
.         gen rCSI         = rCSILessQlty * 1 + rCSIBorrow * 2 + rCSIMealNb * 1 +         ///
>                                    rCSIMealSize * 1 + rCSIMealAdult * 3
{txt}
