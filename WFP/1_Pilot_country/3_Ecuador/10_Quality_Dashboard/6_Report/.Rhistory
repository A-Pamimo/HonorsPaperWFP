Malawi_Vul <- Malawi_Camp_Prioritization %>%
tbl_summary(
include =
c(CARI_2Classes, FCS, rCSI, CS_CARI, FES, FES_CARI, LCS_CARI, CARI_Class,
HH_Population, HHHFemale, HHHAge, HHHSenior, HHHMinor, HHHMaritalStatus,
HHHMarried, HHHDivWid, HHHIlliterate, HHHPrimary, HHHDisable, HHHDisease,
HHSize, HHSize_check, HHSize_5More, HHSize_6More, HHSize_7More,
TotHHSizeM, TotHHSizeF, FemaleMale_Ratio, FemaleMale_Ratio_1_5, HHHFemale_HighFe_Ratio,
Num_Children_U2, Cat_Children_U2, Num_Children_U5, Cat_Children_U5, Cat_Children_U5_2More,
Num_Children, Cat_Children_3More, Cat_Children_4More, Num_Senior, Cat_Senior,
Num_Girl, Cat_Girl_2More, Cat_Girl_3More, Num_NonDep, Num_Dep, Cat_NoAdultMale,
Dependency_ratio, Dep_Ratio_Cat, Dep_Ratio_1_5, Dep_ratio_2More,
HHIlliterate, HHDisease, HHPLW, HHOrphan, HHMalChild,
HHAccess_Land_Dep, HHOwnlivestock_Dep, HHOwnbusiness_Dep, HHOwnbin_Dep,
HHOwnradio_Dep, HHOwntv_Dep, HHOwnbed_Dep, HHOwnmattress_Dep, HHOwnbednet_Dep,
HHOwnmat_Dep, HHOwntable_Dep, HHOwnchair_Dep, HHOwnpot_Dep, HHOwnbucket_Dep,
HHOwnsolarlamp_Dep, HHOwnkerolamp_Dep, HHOwnstove_Dep, HHOwnsewmachine_Dep,
HHOwnsmallshop_Dep, HHOwnhammer_Dep, HHOwnshovel_Dep, HHOwnpanga_Dep,
HHOwngenset_Dep, HHOwnplough_Dep, HHOwnwheelbar_Dep, HHOwnhoe_Dep,
HHOwnphone_Dep, HHOwnaccount_Dep, HHOwnhouse_Dep, HHOwnmotorcycle_Dep, HHOwncar_Dep),
type = list(where(is.numeric) ~ "continuous",
where(is.factor) ~ "categorical"),
statistic = list(all_continuous() ~ "{mean}",
all_categorical() ~ "{n}({p}%)"),
missing = "no") %>%
modify_header(update = list(label ~ "**Variable**")) %>%
bold_labels() %>%
italicize_labels() %>%
italicize_levels() %>%
modify_spanning_header(c("stat_0") ~ "**n%**")
Malawi_Vul
