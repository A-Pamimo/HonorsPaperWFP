{hline 13}{c +}{hline 57}
{space 4}Crowding {c |}{res}      1,478    3.869441    1.930608         .2         14
{txt}
{com}.         replace Crowding = `r(max)' if mi(Crowding)
{txt}(25 real changes made)

{com}.         
.         gen CrowdIndex_3More = (Crowding >= 3)
{txt}
{com}.         gen CrowdIndex_4More = (Crowding >= 4)
{txt}
{com}.         gen CrowdIndex_5More = (Crowding >= 5)
{txt}
{com}.         
.         ** Female/Male Ratio
.         gen     FemaleMale_Ratio = HHSizeF/HHSizeM      // 12 missing coz no male
{txt}(12 missing values generated)

{com}.         sum     FemaleMale_Ratio

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
FemaleMale~o {c |}{res}      1,491    1.187913    .8819359          0         10
{txt}
{com}.         replace FemaleMale_Ratio = `r(max)' if mi(FemaleMale_Ratio)
{txt}(12 real changes made)

{com}.         gen FemaleMale_Ratio_1_5 = (FemaleMale_Ratio >= 1.5)
{txt}
{com}.         
.         ** Dependency Ratio
.         egen Num_Dependent = rowtotal(HHSize06M_M HHSize06M_F HHSize6_59M_M      ///
>                                                  HHSize6_59M_F HHSize517M HHSize517F HHSize60AboveM  ///
>                                                  HHSize60AboveF)
{txt}
{com}.         egen Num_Adult     = rowtotal(HHSize1859M HHSize1859F)
{txt}
{com}.         gen  Dependency_Ratio = Num_Dependent/Num_Adult
{txt}(24 missing values generated)

{com}.         sum     Dependency_Ratio

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
Dependency~o {c |}{res}      1,479    2.546449    1.692665          0         13
{txt}
{com}.         replace Dependency_Ratio = `r(max)' if mi(Dependency_Ratio)
{txt}(24 real changes made)

{com}.                                         
.         gen     Dep_Ratio_Cat = 0
{txt}
{com}.         replace Dep_Ratio_Cat = 1 if Dependency_Ratio <= 1
{txt}(287 real changes made)

{com}.         replace Dep_Ratio_Cat = 2 if Dependency_Ratio >  1       & Dependency_Ratio <= 1.5
{txt}(198 real changes made)

{com}.         replace Dep_Ratio_Cat = 3 if Dependency_Ratio >  1.5 & Dependency_Ratio <= 2.5
{txt}(447 real changes made)

{com}.         replace Dep_Ratio_Cat = 4 if Dependency_Ratio >  2.5
{txt}(571 real changes made)

{com}. 
.         gen Dep_Ratio_1_5More   = (Dependency_Ratio >= 1.5)
{txt}
{com}.         gen     Dep_Ratio_2                     = (Dependency_Ratio >  2)
{txt}
{com}.         gen Dep_Ratio_2More     = (Dependency_Ratio >= 2)
{txt}
{com}.         
.         ** Children
.         egen Num_Children = rowtotal(HHSize06M_M HHSize06M_F HHSize6_59M_M              ///
>                                                 HHSize6_59M_F HHSize517M HHSize517F)
{txt}
{com}.         gen Cat_Children = (Num_Children >= 1) 
{txt}
{com}.         
.         egen Num_Children_U5 = rowtotal(HHSize06M_M HHSize06M_F HHSize6_59M_M   ///
>                                                    HHSize6_59M_F)
{txt}
{com}.         gen  Cat_Children_U5       = (Num_Children_U5 >= 1)
{txt}
{com}.         gen  Cat_Children_U5_2More = (Num_Children_U5 >= 2)
{txt}
{com}.         
.         ** Senior
.         egen Num_Senior = rowtotal(HHSize60AboveM HHSize60AboveF)
{txt}
{com}.         gen  Cat_Senior = (Num_Senior >= 1)
{txt}
{com}.         
.         ** Dwelling ? Buush/bas (hut larger than Buul; Cariish (mud hut); Jiingad; Stick house (Kamar/Dhis/Buul); Tent
.         gen HHDwelling_Bad = inlist(HHDwellType,5,6,7,8,10)
{txt}
{com}.         gen HHTempShelter  = (living_arrangement == 5)
{txt}
{com}.         ** Water source bad: unprotected water sources
.         gen HHWater_Bad    = inlist(HHWaterSRC,501,503,504)
{txt}
{com}.         ** Toilet bad: Composting/dry latrine; VIP/simple pit latrine with floor/slab;
.         ** Pit latrine without floor/slab; Service or bucket latrine; Hanging toilet/latrine; No facility, field, bush, plastic bag
.         gen HHToilet_Bad   = inlist(HHToiletType,10300,10401,10402,20200,20300,20400)
{txt}
{com}.         
.         ** Assets
.         label def yesno 1 "Yes" 0 "No"
{txt}
{com}.         
.         local assets Car Bicycle Motorbike Jewl Gas Radio Tv Cellphone Plough            ///
>                                  Machete Tractor OxenPlough Hoe Sickle Shovel Axe Pump IrrigSys  ///
>                                  HoneyExt Beehive Grind Hammer Storage Cart
{txt}
{com}. foreach item of local assets {c -(}
{txt}  2{com}.         gen HHOwn`item' = (HHAsset`item' > 0)
{txt}  3{com}.         gen HHOwn`item'_Dep = (HHAsset`item' == 0)
{txt}  4{com}.         
.         label var HHOwn`item'           "Household owns `item'"
{txt}  5{com}.         label var HHOwn`item'_Dep       "Household doesn't own `item'"
{txt}  6{com}.         label val HHOwn`item' HHOwn`item'_Dep yesno
{txt}  7{com}. {c )-}
{txt}
{com}.         
. ********************************************************************************
. *                                                       PART 6: Outcome indicators
. *******************************************************************************/        
. 
.         
. ********************************************************************************
. *                                                       PART 7: Label variables
. *******************************************************************************/        
.         
. /*      label def FCS_rCSI_l   1 "Acceptable"   2 "Acceptable and rCSI>4" ///
>                                                    3 "Borderline"       4 "Poor"
>         label val FCS_4pt_CARI FCS_rCSI_l
>         
>         label def FS_CARI          1 "Food Secure"  2 "Marginally Food Secure" ///
>                                                    3 "Moderately Food Insecure" 4 "Severely Food Insecure"
>         label val FCS_4pt_CARI CARI_FES_Cat FES_Cat FS_CARI        
>         
>         label def LCS_l            1 "HH not adopting coping strategies"                ///
>                                                    2 "HH adopted stress coping strategies"              ///
>                                                    3 "HH adopted crisis coping strategies"              ///
>                                                    4 "HH adopted emergency coping strategies"
>         label val LCS_Cat LCS_l
> */      
.         label def depratio_label 1 "up to 1" 2 "1 to 1.5" 3 "1 to 2.5" 4 "more than 2.5"
{txt}
{com}.         label val Dep_Ratio_Cat depratio_label 
{txt}
{com}.         
.         label val HHPermResident HHDisplaced HHReturnee HHIDP HHIDP_Camp HHHost_Com ///
>                           HHBeneficiary HHNonBen HHReprodWoman HHPLW HHDisable HHHResp      ///
>                           HHHFemale HHHSenior HHHMarried HHHDivSepWid HHHDisable                    ///
>                           HHSize_7More HHSize_8More HHSize_9More CrowdIndex_3More                       ///
>                           CrowdIndex_4More CrowdIndex_5More FemaleMale_Ratio_1_5                        ///
>                           Dep_Ratio_1_5More Dep_Ratio_2 Dep_Ratio_2More Cat_Children            ///
>                           Cat_Children_U5 Cat_Children_U5_2More Cat_Senior HHDwelling_Bad       ///
>                           HHTempShelter HHWater_Bad HHToilet_Bad yesno
{txt}
{com}.         
