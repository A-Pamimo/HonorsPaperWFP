>         label var HH_Vul_CARI                   "Household is Vulnerable based on CARI"
>         label var HH_Vul_FEI                    "Household is Vulnerable based on existing var FSIStatus"
>         label var HH_Vul                                "Household is Vulnerable based on FCS, rcsi and LCS_Cat"
> */
