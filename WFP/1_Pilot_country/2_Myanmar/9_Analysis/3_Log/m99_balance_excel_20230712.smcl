{com}.         
.         * export current codebook
. *       iecodebook export using "${c -(}codebook{c )-}/Somalia_CoI_2023_Codebook.xlsx", replace
.         
. ********************************************************************************
. *                                               PART 4: Correct variable types
. *******************************************************************************/
.         
.         * categorical string to byte
.         local conv_cat_var ADMIN5Name Q15
{txt}
{com}. 
. foreach var of local conv_cat_var {c -(}
{txt}  2{com}.         encode  `var'     , gen(`var'_byte)
{txt}  3{com}.         order   `var'_byte, a(`var')
{txt}  4{com}.         drop    `var'
{txt}  5{com}.         rename  `var'_byte `var'
{txt}  6{com}. {c )-}
{res}{txt}
{com}.         
. ********************************************************************************
. *                                                       PART 5: Variable creation
. *******************************************************************************/
.         
.         ** Variable for sub-sample analysis: ADMIN0Name Livelihood strata_compiled
.         
.         ** Household Characteristics 
.         gen HHPermResident = (HHStatus == 1)    // one missing as 0 
{txt}
{com}.         gen HHDisplaced    = (HHStatus == 2)    
{txt}
{com}.         gen HHReturnee     = (hh_returnee == 1) // only 2 returnee in HHStatus
{txt}
{com}.         gen HHIDP                  = (hh_an_idp_household == 1)
{txt}
{com}.         gen HHIDP_Camp     = (hh_in_idp_camp == 1)
{txt}
{com}.         gen HHHost_Com     = (hh_in_host_community == 1)
{txt}
{com}.         
.         // one missing as 0 and this doesn't match with IDPs in Livelihood 
.         gen HHBeneficiary  = (strata_compiled == 2)     
{txt}
{com}.         gen HHNonBen       = (strata_compiled == 1)     
{txt}
{com}.         gen HHReprodWoman  = (Q9 == 1)
{txt}
{com}.         gen HHPLW                  = (Q9_1 == 1)
{txt}
{com}.         gen HHDisable      = (Q14_2_1_Member_none == 0)
{txt}
{com}.         
.         ** Household Head Characteristics
.         gen HHHResp        = (HHH       == 1)
{txt}
{com}.         gen HHHFemale      = (HHHSex == 0)
{txt}
{com}.         gen HHHSenior      = (HHHAge >= 60)
{txt}
{com}.         gen HHHMarried     = (HHHStatus == 300)
{txt}
{com}.         gen HHHDivSepWid   = (HHHStatus == 400 | HHHStatus == 401 | HHHStatus == 500)
{txt}
{com}.         gen HHHDisable     = (Q14_1_1_None == 0)
{txt}
{com}. *       gen HHHNoEdu       = (Q15 == ) // no label check the instrument
. 
.         * HH Size
.         assert HHSize == HH_cal                         // YES
{txt}
{com}.         egen HHSizeF = rowtotal(HHSize06M_F HHSize6_59M_F HHSize517F HHSize1859F  ///
>                                    HHSize60AboveF)
{txt}
{com}.         egen HHSizeM = rowtotal(HHSize06M_M HHSize6_59M_M HHSize517M HHSize1859M  ///
>                                    HHSize60AboveM)                 
{txt}
{com}.         assert HHSize == HHSizeF + HHSizeM      // YES
{txt}
{com}.         
.         gen HHSize_7More  = (HHSize >= 7)
{txt}
{com}.         gen HHSize_8More  = (HHSize >= 8)
{txt}
{com}.         gen HHSize_9More  = (HHSize >= 9)
{txt}
{com}.         
.         * Household crowding index
.         gen Crowding = HHSize/HHCrowdIndex
