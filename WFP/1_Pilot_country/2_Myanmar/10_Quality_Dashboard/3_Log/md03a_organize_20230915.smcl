{com}. /* *************************************************************************** *
> *                       Comprehensive Dataset for In-Kind Assistance Gap Analysis                  * 
> *                                                                                                                                                          *
> *  PURPOSE:                     Master dofile                                                                              * 
> *  AUTHOR:                              Nicole Wu (nicole.wu@wfp.org)                                              *
> *  DATE:                                May 19 2023                                                                                        *
> *  LATEST UPDATE:               May 25 2023                                                                                        *
> *                 
> ********************************************************************************
> 
>         ** OUTLINE:             PART 1: Install packages and Set directories
>                                         PART 2: Organize country datasets
>                                         PART 3: Append country datasets
>                                         PART 4: Analyze Food MEB Gap  
>                                         
>         ** REQUIRES:    ${c -(}ecmen{c )-}/Bangladesh_Cox_Bazar/2_standarized_dataset/Bangladesh_Cox_Bazar_harmonized.dta
>                                         ${c -(}ecmen{c )-}/Cameroon/2_standarized_dataset/Cameroon_harmonized.dta
>                                         ${c -(}ecmen{c )-}/Cameroon/2_standarized_dataset/Cameroon_harmonized.dta
>                                         ${c -(}ecmen{c )-}/Ethiopia_Tigray/2_standarized_dataset/Ethiopia_Tigray_harmonized.dta
>                                         ${c -(}ecmen{c )-}/Jordan/2_standarized_dataset/Jordan_harmonized.dta
>                                         ${c -(}ecmen{c )-}/Rwanda/2_standarized_dataset/Rwanda_harmonized.dta
>                                         
>         ** CREATES:             ${c -(}data{c )-}/Gap_Analysis_data_${c -(}today{c )-}.dta
>                                         ${c -(}output{c )-}/In_Kind_Assistance_Gap_FES.png
>                                         ${c -(}output{c )-}/In_Kind_Assistance_Gap_ECMEN.png
>                                         ${c -(}output{c )-}/In_Kind_Assistance_Gap_Bangladesh_FES.png
>                                         ${c -(}output{c )-}/In_Kind_Assistance_Gap_Bangladesh_ECMEN.png
>                                         
>         ** NOTES:               Relevant variables in each dataset: 
>                                         HHSize HHExpFood_1M HHAsstHumanCBTRec_1M
>                                         FCSCat28 rCSI Max_coping_behaviour FES
>                                         ECMEN_recomp ECMEN_SMEB_recomp
>                                         
> *******************************************************************************/
. *                 PART 1:  INSTALL PACKAGES AND SET DIRECTORIES                *
. ********************************************************************************
. 
. * Install packages      
.         local   packages                        0       
{txt}
{com}. if `packages'   {c -(}       
.         local user_commands ietoolkit iefieldkit sumstats savespss
.         foreach command of local user_commands {c -(}
{txt}  2{com}.                 cap which `command'
{txt}  3{com}.                 if _rc == 111 ssc install `command'
{txt}  4{com}.         {c )-}
. {c )-}
{txt}
{com}. 
. *Standardize settings accross users
.         ieboilstart, version(13.1)  

{res}{phang}{err:DISCLAIMER:} Due to how settings work in Stata, this command can only attempt to harmonize settings as much as possible across users, but no guarantee can be given that all commands will always behave identically unless the exact same version and type of Stata is used, with the same releases of user-contributed commands installed.{p_end}

{col 5}{ul:Settings set by this command:}{break}{col 5}clear all{break}{col 5}set maxvar {col 22}120000{col 28}, permanently{break}{col 5}set matsize {col 22}400{col 28}, permanently{break}{col 5}set niceness{col 22}5{col 28}, permanently{break}{col 5}set min_memory {col 22}0{col 28}, permanently{break}{col 5}set max_memory {col 22}.{col 28}, permanently{break}{col 5}set segmentsize  {col 22}32m{col 28}, permanently{break}{col 5}set more {col 22}off{col 28}, permanently{break}{col 5}pause {col 22}on{break}{col 5}set varabbrev {col 22}off{col 28}, permanently{break}{col 5}set type {col 22}float{col 28}, permanently

{phang}{err:IMPORTANT:} One important setting of this command – the Stata version – cannot be set inside the command due to how this setting works. The setting has been prepared by this command, and you only need to write `r(version)' after this command (include the apostrophes) for the version setting to be applied.{p_end}
{txt}
{com}.         //Set the version number to the oldest version used by anyone in the project team
.         `r(version)'  
{txt}
{com}.         
.         *set global for today
.         gl today :      display %tdCCYYNNDD date(c(current_date),"DMY")
{res}{txt}
{com}.         graph set window fontface "Open Sans"
{txt}
{com}. 
.         * add your directory below
.         display c(username)     // Get your username and add path to the working folder
{res}nicolewu
{txt}
{com}.         
.         global nicole    1
{txt}
{com}. 
.         * set the GD Folder
. if $nicole {c -(}
.         gl inkind  "/Users/nicolewu/Library/CloudStorage/OneDrive-WorldFoodProgramme/4_Gap_Analysis/1_DataWork"
.         gl ecmen   "/Users/nicolewu/Library/CloudStorage/OneDrive-WorldFoodProgramme/Data"
.         {c )-}
{txt}
{com}. 
.         * Subfolder globals
.         * -----------------
. 
.         gl data                 "${c -(}inkind{c )-}/1_Data"
{txt}
{com}.         gl dofile               "${c -(}inkind{c )-}/2_Code"
{txt}
{com}.         gl output               "${c -(}inkind{c )-}/3_Output"
{txt}
{com}.         
.         gl data_bgd             "${c -(}ecmen{c )-}/Bangladesh_Cox_Bazar/2_standarized_dataset/Bangladesh_Cox_Bazar_harmonized"   
{txt}
{com}.         gl data_cmr             "${c -(}ecmen{c )-}/Cameroon/2_standarized_dataset/Cameroon_harmonized"   
{txt}
