{txt}
{com}.         gl data_eth             "${c -(}ecmen{c )-}/Ethiopia_Tigray/2_standarized_dataset/Ethiopia_Tigray_harmonized"
{txt}
{com}.         gl data_gmb             "${c -(}ecmen{c )-}/Gambia/2_standarized_dataset/Gambia_harmonized"               
{txt}
{com}.         gl data_jor             "${c -(}ecmen{c )-}/Jordan/2_standarized_dataset/Jordan_harmonized"
{txt}
{com}.         gl data_moz             "${c -(}ecmen{c )-}/Mozambique/2_standarized_dataset/Mozambique_harmonized"
{txt}
{com}.         gl data_rwa             "${c -(}ecmen{c )-}/Rwanda/2_standarized_dataset"
{txt}
