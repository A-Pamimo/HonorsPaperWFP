{txt}
{com}.         
.         **      Number of school-aged children not attending school
.         gen child_noschool = (child_atten == 0) if Age >= 7 & Age <= 20
{txt}(6,504 missing values generated)

{com}.         bysort ___parent_indexs: egen num_child_noschool = sum(child_noschool)
{txt}
{com}.         
.         **  Sex of school-aged children not attending school
.         gen boy_noschool  = (child_noschool == 1 & Sex == 1) if Age >= 7 & Age <= 20
{txt}(6,504 missing values generated)

{com}.         gen girl_noschool = (child_noschool == 1 & Sex == 2) if Age >= 7 & Age <= 20
{txt}(6,504 missing values generated)

{com}.         bysort ___parent_indexs: egen num_boy_noschool  = sum(boy_noschool)
{txt}
{com}.         bysort ___parent_indexs: egen num_girl_noschool = sum(girl_noschool)
{txt}
{com}.         
. *       Number of able-bodied, working-age HH members
.         gen work_able = (HH_disa == 0 & (Age >= 18 & Age <= 59)) 
{txt}
{com}.         bysort ___parent_indexs: egen num_work_able = sum(work_able)
{txt}
{com}. 
.         **      Number of currently employed members (should not be used for targeting as this is highly variable and difficult to verify) 
.         //${c -(}Age{c )-} >= 16 and ${c -(}Age{c )-} <= 65
.         gen employed = (mm_emp_last == 1) if Age >= 16 & Age <= 65
{txt}(5,379 missing values generated)

{com}.         bysort ___parent_indexs: egen num_employed = sum(employed)
{txt}
{com}.         
. *       Number of household members falling into following special needs (protection) categories:
.         **      Disabled (with/without medical report)
.         gen disable = (HH_disa == 1) 
{txt}
{com}.         bysort ___parent_indexs: egen num_disable = sum(disable)
{txt}
{com}.         
.         **      Chronically ill (with/without medical report)
.         gen chronic_ill = (HH_chro == 1)
{txt}
{com}.         bysort ___parent_indexs: egen num_chronic_ill = sum(chronic_ill)
{txt}
{com}.         
.         **      Elderly who cannot take care of self
.         gen senior_nocare = (Age >= 60 & inlist(PDisabWash, 2,3,4))
{txt}
{com}.         bysort ___parent_indexs: egen num_senior_nocare = sum(senior_nocare)
{txt}
{com}.         
.         ******** Capability-based Indicators for Self-Reliance Profiling ******
.         
.         ** Number of working-age, able-bodied adult: num_work_able
.         
.         ** Number of working-age, able-bodied adult male
.         gen work_able_male = (HH_disa == 0 & (Age >= 18 & Age <= 59) & Sex == 1) 
{txt}
{com}.         bysort ___parent_indexs: egen num_work_able_male = sum(work_able_male)
{txt}
{com}.         
.         ** Number of member with high school or higher education 
.         // ${c -(}Age{c )-} >= 16 and ${c -(}Age{c )-} <= 65
.         gen edu_secondary = inlist(working_edu_leve, 1,5,6,7) if Age >= 16 & Age <= 65
{txt}(5,379 missing values generated)

{com}.         bysort ___parent_indexs: egen num_edu_secondary = sum(edu_secondary)
{txt}
{com}.         
.         ** Number of member with expertise or certifications other than formal ///
>            education (variable: n_cert)
.         gen certification = (n_cert == 1) if Age >= 16 & Age <= 65
{txt}(5,379 missing values generated)

{com}.         bysort ___parent_indexs: egen num_certification = sum(certification)
{txt}
{com}. 
.         ** Number of members with expertise and certifications in specific sectors ///
>            (agriculture, manufacturing, textiles, health, construction, other)
.         gen cert_ag             = (n_sec_agriculture   == 1) if Age >= 16 & Age <= 65
{txt}(5,379 missing values generated)

{com}.         bysort ___parent_indexs: egen num_cert_ag = sum(cert_ag)
{txt}
{com}. 
.         gen cert_manu   = (n_sec_manufacturing == 1) if Age >= 16 & Age <= 65
{txt}(5,379 missing values generated)

{com}.         bysort ___parent_indexs: egen num_cert_manu = sum(cert_manu)
{txt}
{com}.         
.         gen cert_tex    = (n_sec_textile           == 1) if Age >= 16 & Age <= 65
{txt}(5,379 missing values generated)

{com}.         bysort ___parent_indexs: egen num_cert_tex = sum(cert_tex)
{txt}
{com}.         
.         gen cert_health = (n_sec_health            == 1) if Age >= 16 & Age <= 65
{txt}(5,379 missing values generated)

{com}.         bysort ___parent_indexs: egen num_cert_health = sum(cert_health)
{txt}
{com}.         
.         gen cert_const  = (n_sec_construction  == 1) if Age >= 16 & Age <= 65
{txt}(5,379 missing values generated)

{com}.         bysort ___parent_indexs: egen num_cert_const = sum(cert_const)
{txt}
{com}.         
.         gen cert_oth    = (n_sec_other             == 1) if Age >= 16 & Age <= 65
{txt}(5,379 missing values generated)

{com}.         bysort ___parent_indexs: egen num_cert_oth = sum(cert_oth)
{txt}
{com}.         
.         **  Num of able-bodied, working age member with at least medium level ///
>                 knowledge of Turkish (conversational)
.         gen work_able_turkish = (work_able == 1 & inlist(working_lang, 2,3,5))
{txt}
{com}.         bysort ___parent_indexs: egen num_work_able_turkish = sum(work_able_turkish)
{txt}
{com}.         
.         **      Num of member who works in a field in which they have certification ///
>                 or specialized knowledge
.         gen work_cert = (mm_emp_last == 1 & working_cer == 1)
{txt}
{com}.         bysort ___parent_indexs: egen num_work_cert = sum(work_cert)
{txt}
{com}.         
.         **      Num of member who has regular, full-time work
.         gen work_full = (mm_emp_last == 1 & working_sector_type == 1)
{txt}
{com}.         bysort ___parent_indexs: egen num_work_full = sum(work_full)
{txt}
{com}.         
.         **      Num of member who has been working in the same sector for 1 or more years
.         gen work_1moreyear = (mm_emp_last == 1 & emp_time >= 2)
{txt}
{com}.         bysort ___parent_indexs: egen num_work_1moreyear = sum(work_1moreyear)
{txt}
{com}.         
.         ******************* Other Potential Targeting indicators *************
.         
.         * total number of male and female
.         gen             sex_male        = (Sex == 1) 
{txt}
{com}.         bysort  ___parent_indexs: egen num_male   = sum(sex_male)
{txt}
{com}.         gen     sex_female      = (Sex == 2) 
{txt}
{com}.         bysort  ___parent_indexs: egen num_female = sum(sex_female)
{txt}
{com}.         
.         * Dependency ratio 
.         gen dependent           = (Age < 18 | Age >= 60)
{txt}
{com}.         bysort ___parent_indexs: egen num_dependent = sum(dependent)
{txt}
{com}.         
.         gen non_dependent   = (dependent == 0)
{txt}
{com}.         bysort ___parent_indexs: egen num_nondependent = sum(non_dependent)
{txt}
{com}.         
.         * Adults
.         gen adult = (Age >= 18) 
{txt}
{com}.         bysort ___parent_indexs: egen num_adult = sum(adult)
{txt}
{com}.         
.         * Children under 18 years 
.         gen minor = (Age < 18) 
{txt}
{com}.         bysort ___parent_indexs: egen num_minor = sum(minor)
{txt}
{com}. 
.         * Age and Sex Groups
.         gen age01m = (Age < 2 & Sex == 1)
{txt}
{com}.         bysort ___parent_indexs: egen HHSize01M = sum(age01m)
{txt}
{com}.         gen age01f = (Age < 2 & Sex == 2)
{txt}
{com}.         bysort ___parent_indexs: egen HHSize01F = sum(age01f)
{txt}
{com}.         
.         gen age24m = (Age >= 2 & Age < 5 & Sex == 1)
{txt}
{com}.         bysort ___parent_indexs: egen HHSize24M = sum(age24m)
{txt}
{com}.         gen age24f = (Age >= 2 & Age < 5 & Sex == 2)
{txt}
{com}.         bysort ___parent_indexs: egen HHSize24F = sum(age24f)
{txt}
{com}.         
.         gen age511m = (Age >= 5 & Age < 12 & Sex == 1)
{txt}
{com}.         bysort ___parent_indexs: egen HHSize511M = sum(age511m)
{txt}
{com}.         gen age511f = (Age >= 5 & Age < 12 & Sex == 2)
{txt}
{com}.         bysort ___parent_indexs: egen HHSize511F = sum(age511f)
{txt}
{com}.         
.         gen age1217m = (Age >= 12 & Age < 18 & Sex == 1)
{txt}
{com}.         bysort ___parent_indexs: egen HHSize1217M = sum(age1217m)
{txt}
{com}.         gen age1217f = (Age >= 12 & Age < 18 & Sex == 2)
{txt}
{com}.         bysort ___parent_indexs: egen HHSize1217F = sum(age1217f)
{txt}
{com}.         
.         gen age1859m = (Age >= 18 & Age < 60 & Sex == 1)
{txt}
{com}.         bysort ___parent_indexs: egen HHSize1859M = sum(age1859m)
{txt}
{com}.         gen age1859f = (Age >= 12 & Age < 60 & Sex == 2)
{txt}
{com}.         bysort ___parent_indexs: egen HHSize1859F = sum(age1859f)
{txt}
{com}.         
.         gen age50abovem = (Age >= 60 & Sex == 1)
{txt}
{com}.         bysort ___parent_indexs: egen HHSize60AboveM = sum(age50abovem)
{txt}
{com}.         gen age50abovef = (Age >= 60 & Sex == 2)
{txt}
{com}.         bysort ___parent_indexs: egen HHSize60AboveF = sum(age50abovef)
{txt}
{com}.         
.         ** Beneficiary size 
.         gen beneficiary = (HH_kiz == 1)
{txt}
{com}.         bysort ___parent_indexs: egen num_beneficiary = sum(beneficiary)
{txt}
{com}.         
