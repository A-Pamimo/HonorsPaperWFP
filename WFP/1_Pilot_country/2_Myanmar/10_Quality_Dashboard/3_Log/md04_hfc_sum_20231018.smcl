{com}. /* *************************************************************************** *
> *                               WFP TRCO Targeting and Resilience Profiling Survey 2023            * 
> *                                                                Master Dofile                                                             * 
> *                                                                                                                                                          *
> *  AUTHOR:                              Nicole Wu (nicole.wu@wfp.org)                                              *
> *  DATE:                                Oct 09 2023                                                                                        *
> *  LATEST UPDATE:               Oct 10 2023                                                                                        *
> *                                                                                                                                                          *
> ********************************************************************************
> 
>         ** OUTLINE:             PART 0: Select parts to run
>                         PART 1: Install packages and harmonize settings
>                                         PART 2: Prepare globals and define paths
>                                         PART 3: Run selected dofiles
>                                 
>         ** REQUIRES:    ${c -(}data_raw{c )-}/Head_file_data_28.09.dta
>                                         ${c -(}data_raw{c )-}/HHmemberinformation.dta
>                                         
>         ** CREATES:             ${c -(}output{c )-}/Turkiye_Targeting_2023_Household_Cleaned.dta
>                                         ${c -(}output{c )-}/Turkiye_Targeting_2023_Household_Cleaned.sav
>                                         
>         ** NOTES:               
>                                         
> *******************************************************************************/
. *                               PART 0:  SELECT PARTS TO RUN                       *
. ********************************************************************************
. 
. * select which parts of this do-file to run
. 
.         local   packages                        0       // Update packages used
{txt}
{com}.         local   organize                        1   // Translation and correct variable type
{txt}
{com}.         local   roster                          1   // Create roster variables
{txt}
{com}.         local   proxy                           1       // Create demographic and target proxies
{txt}
{com}.         local   outcome                         1       // Create other food security outcomes
{txt}
{com}.         
. *******************************************************************************/
. *                                       PART 1:  Install packages and harmonize settings                   *
. ********************************************************************************
. 
. if `packages'   {c -(}       
.         local user_commands ietoolkit iefieldkit 
.         foreach command of local user_commands {c -(}
{txt}  2{com}.                 cap which `command'
{txt}  3{com}.                 if _rc == 111 ssc install `command'
{txt}  4{com}.         {c )-}
. {c )-} 
{txt}
{com}. * Note that this never updates outdated versions of already installed commands
. * to update commands use adoupdate
. 
. *Standardize settings accross users
.         ieboilstart, version(17.0)  

{res}{phang}{err:DISCLAIMER:} Due to how settings work in Stata, this command can only attempt to harmonize settings as much as possible across users, but no guarantee can be given that all commands will always behave identically unless the exact same version and type of Stata is used, with the same releases of user-contributed commands installed.{p_end}

{col 5}{ul:Settings set by this command:}{break}{col 5}clear all{break}{col 5}set maxvar {col 22}120000{col 28}, permanently{break}{col 5}set matsize {col 22}400{col 28}, permanently{break}{col 5}set niceness{col 22}5{col 28}, permanently{break}{col 5}set min_memory {col 22}0{col 28}, permanently{break}{col 5}set max_memory {col 22}.{col 28}, permanently{break}{col 5}set segmentsize  {col 22}32m{col 28}, permanently{break}{col 5}set more {col 22}off{col 28}, permanently{break}{col 5}pause {col 22}on{break}{col 5}set varabbrev {col 22}off{col 28}, permanently{break}{col 5}set type {col 22}float{col 28}, permanently

{phang}{err:IMPORTANT:} One important setting of this command – the Stata version – cannot be set inside the command due to how this setting works. The setting has been prepared by this command, and you only need to write `r(version)' after this command (include the apostrophes) for the version setting to be applied.{p_end}
{txt}
{com}.         //Set the version number to the oldest version used by anyone in the project team
.         `r(version)'  
{txt}
{com}.         graph set window fontface "Open Sans"
{txt}
{com}.         
.         *set global for today
.         gl today :      display %tdCCYYNNDD date(c(current_date),"DMY")
{res}{txt}
{com}.         
. ********************************************************************************
. *                                               PART 2:  Prepare globals and define paths                          *
. ********************************************************************************
.         
. * add your directory below
.         display c(username)     // Get your username
{res}nicolewu
{txt}
{com}.          
. * set directories
. * ---------------       
. if "`c(username)'" == "nicolewu" {c -(}
.         global Turkiye  "/Users/nicolewu/Library/CloudStorage/OneDrive-WorldFoodProgramme/General - Turkiye CO Camps Needs Assessment and Targeting"
.         {c )-}
{txt}
{com}. 
. if "`c(username)'" == "" {c -(}
.         global Turkiye  ""
.         {c )-} // add path to the working folder
{txt}
{com}. 
. * Subfolder globals
. * -----------------
.         gl dataset                      "${c -(}Turkiye{c )-}/01_Data"
{txt}
{com}.         gl dofile                       "${c -(}Turkiye{c )-}/02_Code"
{txt}
{com}.         gl output                       "${c -(}Turkiye{c )-}/03_Output"
{txt}
{com}.         gl instrument           "${c -(}Turkiye{c )-}/04_Instrument"
{txt}
{com}.         gl codebook                     "${c -(}Turkiye{c )-}/05_Codebook"
{txt}
{com}.         
.         gl data_raw                     "${c -(}dataset{c )-}/01_Raw"
{txt}
{com}.         gl data_temp            "${c -(}dataset{c )-}/02_Temp"
{txt}
{com}.         
. ********************************************************************************
. *                                               PART 3: Select dofiles to run                                              *
. ********************************************************************************
. 
.         if `organize'   do      "${c -(}dofile{c )-}/TUR00_Organize.do"
{txt}
{com}. /* *************************************************************************** *
> *                               WFP TRCO Targeting and Resilience Profiling Survey 2023            * 
> *                                                                                                                                                          *
> *  PURPOSE:                     Organize Househole Dataset                                                         *
