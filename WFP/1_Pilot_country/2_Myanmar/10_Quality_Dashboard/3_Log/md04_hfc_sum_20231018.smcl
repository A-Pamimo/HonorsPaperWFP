{txt}
{com}. /* *************************************************************************** *
> *                               WFP TRCO Targeting and Resilience Profiling Survey 2023            * 
> *                                                                                                                                                          *
> *  PURPOSE:                     Create food security outcomes                                              *
> *  AUTHOR:                              Nicole Wu (nicole.wu@wfp.org)                                              *
> *  DATE:                                Oct 10 2023                                                                                        *
> *  LATEST UPDATE:               Oct 11 2023                                                                                        *
> *                                                                                                                                                          *
> ********************************************************************************
>                         
>         ** OUTLINE:             PART 1: Create Outcomes based on CARI
>                                         PART 2: Label Variables and Values
>                                         PART 3: Save Dataset for Analysis
>                                         
>         ** NOTES:               Need to discuss with Lina/CO
>                                         -> FCS sub group contradictions: PENDING
>                                         -> LCS 4+3+3: Go with 12/include all as Chris did
>                                         -> FES no debt and no saving - drop 1 total expenditure 0? -> YES
>                                         -> Assistance value 150: PENDING
>                                         
> *******************************************************************************/
. *                                               PART 1: Create Outcomes based on CARI
. ********************************************************************************
.         
. **      1. Food Consumption Score
.         fsum FCS* // no missing, all 0-7

{txt}{ralign 9: Variable} {c |}{ralign 9:N}{ralign 9:Mean}{ralign 9:SD}{ralign 9:Min}{ralign 9:Max}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}
{hline 10}{c +}{hline 45}
{ralign 9 : FCSStap} {c |}{res}{ralign 0:     2001     6.55     1.24     0.00     7.00{space 0}}{ralign 0:{col 59}}
{txt}{ralign 9 : FCSPulse} {c |}{res}{ralign 0:     2001     2.24     1.51     0.00     7.00{space 0}}{ralign 0:{col 59}}
{txt}{ralign 9 : FCSDairy} {c |}{res}{ralign 0:     2001     5.43     2.06     0.00     7.00{space 0}}{ralign 0:{col 59}}
{txt}{ralign 9 : FCSPr} {c |}{res}{ralign 0:     2001     3.45     2.60     0.00     7.00{space 0}}{ralign 0:{col 59}}
{txt}{ralign 9 : FCSVeg} {c |}{res}{ralign 0:     2001     5.71     1.84     0.00     7.00{space 0}}{ralign 0:{col 59}}
{txt}{ralign 9 : FCSFruit} {c |}{res}{ralign 0:     2001     2.32     2.10     0.00     7.00{space 0}}{ralign 0:{col 59}}
{txt}{ralign 9 : FCSFat} {c |}{res}{ralign 0:     2001     6.76     0.94     0.00     7.00{space 0}}{ralign 0:{col 59}}
{txt}{ralign 9 : FCSSugar} {c |}{res}{ralign 0:     2001     6.47     1.65     0.00     7.00{space 0}}{ralign 0:{col 59}}
{txt}{ralign 9 : FCSCond} {c |}{res}{ralign 0:     2001     6.78     0.89     0.00     7.00{space 0}}{ralign 0:{col 59}}
{txt}
{com}.         gen FCS = (FCSStap * 2) + (FCSPulse * 3) + (FCSDairy * 4) +     ///
>                           (FCSPr * 4)   + (FCSVeg * 1)   + (FCSFruit * 1) +     ///
>                           (FCSFat * 0.5)+ (FCSSugar * 0.5)      
{txt}
{com}.         // 2 FCS 0
.         gen FCSCat28 = cond(FCS <= 28,1,cond(FCS <= 42,2,3))
{txt}
{com}.         tab FCSCat28

   {txt}FCSCat28 {c |}      Freq.     Percent        Cum.
{hline 12}{c +}{hline 35}
          1 {c |}{res}         30        1.50        1.50
{txt}          2 {c |}{res}        147        7.35        8.85
{txt}          3 {c |}{res}      1,824       91.15      100.00
{txt}{hline 12}{c +}{hline 35}
      Total {c |}{res}      2,001      100.00
{txt}
{com}.         
.         ** sub-group checks
.         egen FCSStap_check  = rowmax(HDDSStapCer HDDSStapRoot)
{txt}(4 missing values generated)

{com}. *       assert FCSStap >= FCSStap_check if !mi(FCSStap_check) // 50 contradictions
.         egen FCSPr_check    = rowmax(HDDSPrMeatF HDDSPrMeatO HDDSPrFish HDDSPrEggs)
{txt}(278 missing values generated)

{com}. *       assert FCSPr >= FCSPr_check if !mi(FCSPr_check)           // 454 contradictions
.         
. **  2. Reduced Coping Strategies Index
.         fsum rCSI* // no missing, all 0-7

{txt}{ralign 14: Variable} {c |}{ralign 9:N}{ralign 9:Mean}{ralign 9:SD}{ralign 9:Min}{ralign 9:Max}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}{ralign 9:}
{hline 15}{c +}{hline 45}
{ralign 14 : rCSILessQlty} {c |}{res}{ralign 0:     2001     3.74     3.10     0.00     7.00{space 0}}{ralign 0:{col 64}}
{txt}{ralign 14 : rCSIBorrow} {c |}{res}{ralign 0:     2001     0.64     1.36     0.00     7.00{space 0}}{ralign 0:{col 64}}
{txt}{ralign 14 : rCSIMealSize} {c |}{res}{ralign 0:     2001     0.90     1.83     0.00     7.00{space 0}}{ralign 0:{col 64}}
{txt}{ralign 14 : rCSIMealAdult} {c |}{res}{ralign 0:     2001     1.09     2.23     0.00     7.00{space 0}}{ralign 0:{col 64}}
{txt}{ralign 14 : rCSIMealNb} {c |}{res}{ralign 0:     2001     1.42     2.49     0.00     7.00{space 0}}{ralign 0:{col 64}}
{txt}
{com}.         gen rCSI = (rCSILessQlty * 1) + (rCSIBorrow * 2) + (rCSIMealNb * 1) + ///
>                            (rCSIMealSize * 1) + (rCSIMealAdult * 3)
{txt}
{com}.         sum rCSI

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
{space 8}rCSI {c |}{res}      2,001     10.5962    11.32077          0         56
{txt}
{com}.         gen rCSI_Group = cond(rCSI <= 3, 1, cond(rCSI <= 18, 2, 3))
{txt}
{com}.         
.         recode  FCSCat28 (1 = 4) (2 = 3) (3 = 1), gen(FCS_4pt_CARI)
{txt}(2,001 differences between {bf:FCSCat28} and {bf:FCS_4pt_CARI})

{com}.         replace FCS_4pt_CARI = 2 if FCSCat28 == 3 & rCSI >= 4
{txt}(1,269 real changes made)

{com}.         
. **  3. LCS
. local lcs_var LcsEN_stress_DomAsset LcsEN_stress_Saving LcsEN_stress_CrdtFood  ///
>           LcsEN_stress_BorrowCash LcsEN_crisis_ProdAssets LcsEN_crisis_OutSchool   ///
>           LcsEN_crisis_Health LcsEN_crisis_Edu LcsEN_em_childmarriage                      ///
>           LcsEN_em_ChildWork LcsEN_em_Begged LcsEN_em_Migration 
{txt}
{com}. 
. foreach var of local lcs_var {c -(}
{txt}  2{com}.         gen `var'_yn    = `var'  == 1 | `var' == 2
{txt}  3{com}.         label var `var'_yn "`: var label `var''"
{txt}  4{com}.         label val `var'_yn yesno
{txt}  5{com}. {c )-} 
{txt}
{com}.         gen LcsEN_Stress_Coping  = (LcsEN_stress_DomAsset_yn    == 1 | ///
>                                                                 LcsEN_stress_Saving_yn      == 1 | ///
>                                                                 LcsEN_stress_CrdtFood_yn    == 1 | ///
>                                                                 LcsEN_stress_BorrowCash_yn  == 1)
{txt}
{com}.                                                                 
.         gen LcsEN_Crisis_Coping  = (LcsEN_crisis_ProdAssets_yn  == 1 | ///
>                                                                 LcsEN_crisis_OutSchool_yn   == 1 | ///
>                                                                 LcsEN_crisis_Health_yn      == 1 | ///
>                                                                 LcsEN_crisis_Edu_yn                 == 1)
{txt}
{com}.                                                                 
.         gen LcsEN_Emergency_Coping = (LcsEN_em_childmarriage_yn == 1 | ///
>                                                                   LcsEN_em_ChildWork_yn         == 1 | ///
>                                                                   LcsEN_em_Begged_yn            == 1 | ///
>                                                                   LcsEN_em_Migration_yn     == 1)
{txt}
{com}. 
.         gen     Max_coping_behaviour = 1
{txt}
{com}.         replace Max_coping_behaviour = 2 if LcsEN_Stress_Coping    == 1
{txt}(1,291 real changes made)

{com}.         replace Max_coping_behaviour = 3 if LcsEN_Crisis_Coping    == 1
{txt}(530 real changes made)

{com}.         replace Max_coping_behaviour = 4 if LcsEN_Emergency_Coping == 1
{txt}(303 real changes made)

{com}.         tab     Max_coping_behaviour

{txt}Max_coping_ {c |}
  behaviour {c |}      Freq.     Percent        Cum.
{hline 12}{c +}{hline 35}
          1 {c |}{res}        684       34.18       34.18
{txt}          2 {c |}{res}        768       38.38       72.56
{txt}          3 {c |}{res}        246       12.29       84.86
{txt}          4 {c |}{res}        303       15.14      100.00
{txt}{hline 12}{c +}{hline 35}
      Total {c |}{res}      2,001      100.00
{txt}
{com}.         
. **      4. ECMEN/FES - Expenditure
. 
. ***** FOOD EXPENDITURE *********************************************************
.         
.         * 7 days food purchase in cash/credit
.         egen HHExp_Food_Purch_MN_7D = rowtotal(HHExpFCer_Purch_MN_7D                            ///
>                  HHExpFTub_Purch_MN_7D HHExpFPuls_Purch_MN_7D HHExpFVeg_Purch_MN_7D     ///
>                  HHExpFFrt_Purch_MN_7D HHExpFAnimMeat_Purch_MN_7D                                               ///
>                  HHExpFAnimFish_Purch_MN_7D HHExpFFats_Purch_MN_7D                                              ///
>                  HHExpFDairy_Purch_MN_7D HHExpFEgg_Purch_MN_7D HHExpFSgr_Purch_MN_7D    ///
>                  HHExpFCond_Purch_MN_7D HHExpFBev_Purch_MN_7D HHExpFOut_Purch_MN_7D)
{txt}
{com}.         
.         * 7 days food gift/aid value 
.         // HHExp_Food_GiftAid_MN_7D 
.         
.         * 7 days food own-production value
.         // HHExp_Food_Own_MN_7D
. 
.         * 7 days food values in total and 1 month average 
.         egen HHExpFoodTotal_7D = rowtotal(HHExp_Food_Purch_MN_7D        ///
>                                                                           HHExp_Food_GiftAid_MN_7D  ///
>                                                                           HHExp_Food_Own_MN_7D) 
{txt}
{com}.                                                         
.         gen HHExpF_1M = (HHExpFoodTotal_7D/7) * 30
{txt}
{com}.         
. ***** NON-FOOD EXPENDITURE *****************************************************
.         
.         **** 1 MONTH ****
.         * Monthly non food expenditure in cash/credit
.         egen HHExp_NonFood_Purch_MN_1M = rowtotal(HHExpNFHyg_Purch_MN_1M                        ///
>                  HHExpNFTransp_Purch_MN_1M HHExpNFFuel_Purch_MN_1M                                              ///
>                  HHExpNFPhone_Purch_MN_1M HHExpNFAlcTobac_Purch_MN_1M                                   ///
>                  HHExpNFRecr_Purch_MN_1M)
{txt}
{com}. 
.          * Monthly non food gift/aid value 
.         egen HHExp_NonFood_GiftAid_MN_1M = rowtotal(HHExpNFTotal_GiftAid_MN_30D)
{txt}
{com}. 
.         **** 6 MONTHS ****
.         * Non food expenditure in cash/credit in 6 months
.         egen HHExp_NonFood_Purch_MN_6M = rowtotal(HHExpNFMedServ_Purch_MN_6M            ///
>                  HHExpNFMedGood_Purch_MN_6M HHExpNFCloth_Purch_MN_6M                                    ///
>                  HHExpNFEduGood_Purch_MN_6M HHExpNFHHSoft_Purch_MN_6M                                   ///
>                  HHExpNFHHMaint_Purch_MN_6M HHExpNFHHOther_Purch_MN_6M)
{txt}
{com}. 
.          * Non food expenditure gift/aid value in 6 months
.         egen HHExp_NonFood_GiftAid_MN_6M = rowtotal(HHExpNFTotal_GiftAid_MN_6M)
{txt}
{com}. 
.         **** TOTAL 1 MONTH AVERAGE ****
.         * Total monthly non food expenditure in cash/credit 
.         gen HHExpNFTotal_Purch_MN_1M = HHExp_NonFood_Purch_MN_1M +                                      ///
>                                                                   (HHExp_NonFood_Purch_MN_6M/6)
{txt}
{com}.         * Total monthly non-food gift/aid value
.         gen HHExpNFTotal_GiftAid_MN_1M = HHExp_NonFood_GiftAid_MN_1M +                          ///
>                                                                     (HHExp_NonFood_GiftAid_MN_6M/6)
{txt}
{com}.         * Total monthly non-food
.         gen HHExpNF_1M = HHExpNFTotal_Purch_MN_1M + HHExpNFTotal_GiftAid_MN_1M 
{txt}
{com}.                 
.         **** TOTAL **** 
.         gen HHExpTot_1M = HHExpF_1M + HHExpNF_1M
{txt}
{com}.         gen PCExpTot_1M = HHExpTot_1M/hhsize
{txt}
{com}.         
.         * FES // household level
.         gen     FES = HHExpF_1M/HHExpTot_1M // 1 missing
{txt}(1 missing value generated)

{com}.         
.         count if HHExpTot_1M == 0               // 1
  {res}1
{txt}
{com}.         drop  if HHExpTot_1M == 0       
{txt}(1 observation deleted)

{com}.         count if HHExpF_1M == 0                 // 5
  {res}4
{txt}
{com}.         
.         gen byte Foodexp_4pt = 1 if FES <  0.5 
{txt}(1,908 missing values generated)

{com}.         replace  Foodexp_4pt = 2 if FES >= 0.5  & FES < 0.65
{txt}(325 real changes made)

{com}.         replace  Foodexp_4pt = 3 if FES >= 0.65 & FES < 0.75
{txt}(607 real changes made)

{com}.         replace  Foodexp_4pt = 4 if FES >= 0.75
{txt}(976 real changes made)

{com}. 
. ** ECMEN
.         * survey month 
.         gen Survey_Month = month(Date)
{txt}
{com}.         * ECMEN // per capita level: number provided by CO
.         gen     MEB  = 1021 if Survey_Month == 7
{txt}(1,931 missing values generated)

{com}.         replace MEB  = 1196 if Survey_Month == 8
{txt}(1,302 real changes made)

{com}.         replace MEB  = 1213 if Survey_Month == 9
{txt}(629 real changes made)

{com}.         
.         gen     SMEB = 528  if Survey_Month == 7
{txt}(1,931 missing values generated)

{com}.         replace SMEB = 560      if Survey_Month == 8
{txt}(1,302 real changes made)

{com}.         replace SMEB = 560      if Survey_Month == 9    
{txt}(629 real changes made)

{com}.         
.         * ECMEN used for assessments (excluding assistance), the value of consumed ///
>           in-kind assistance and gifts should be excluded from the household       ///
>           economic capacity aggregate
.         
.         * Aggregate food expenditures and value of consumed food from own production
.         egen HHExpF_ECMEN_7D = rowtotal(HHExp_Food_Purch_MN_7D HHExp_Food_Own_MN_7D)
{txt}
{com}.         gen  HHExpF_ECMEN        = (HHExpF_ECMEN_7D/7) * 30
{txt}
{com}.         * For NF only expenditures are considered
.         gen HHExpNF_ECMEN = HHExpNFTotal_Purch_MN_1M
{txt}
{com}.         * Aggregate food and non-food
.         egen HHExp_ECMEN = rowtotal(HHExpF_ECMEN HHExpNF_ECMEN)
{txt}
{com}.         gen  PCExp_ECMEN = HHExp_ECMEN/hhsize
{txt}
{com}.         
.         * gen PC exp minus assistance (150 TRY)
.         gen PCExpTot_NoAssist   =  PCExp_ECMEN - 150
{txt}
{com}.         gen PCExpTot_BeniAssist = (HHExp_ECMEN - 150 * num_beneficiary)/hhsize
{txt}
{com}.         
.         gen byte ECMEN          = PCExpTot_BeniAssist > MEB
{txt}
{com}.         gen byte ECMEN_SMEB = PCExpTot_BeniAssist > SMEB
{txt}
{com}.         
.         gen byte ECMEN_Cat = 1 if ECMEN == 1
{txt}(322 missing values generated)

{com}.         replace  ECMEN_Cat = 3 if ECMEN == 0 & ECMEN_SMEB == 1
{txt}(294 real changes made)

{com}.         replace  ECMEN_Cat = 4 if ECMEN == 0 & ECMEN_SMEB == 0
{txt}(28 real changes made)

{com}.         
. **      CARI
.         ** New CARI // 38.45% Vulnerable
.         gen CC_FES_Cat   = (Foodexp_4pt + Max_coping_behaviour)/2       // no round here
{txt}
{com}.         gen CARI_FES_Raw = (FCS_4pt_CARI + CC_FES_Cat)/2
{txt}
{com}.         gen CARI_FES_Cat = round(CARI_FES_Raw)
{txt}
{com}. 
. *       ECMEN Based CARI
.         gen CC_ECMEN_Cat = (ECMEN_Cat + Max_coping_behaviour)/2         // no round here
{txt}
{com}.         gen CARI_ECMEN_Raw       = (FCS_4pt_CARI + CC_ECMEN_Cat)/2
{txt}
{com}.         gen CARI_ECMEN_Cat   = round(CARI_ECMEN_Raw)
{txt}
{com}. 
.         ** Old CARI     // 14.20% Vulnerable
.         recode  FCSCat28 (1 = 4) (2 = 3) (3 = 1), gen(FCS_4pt_CARI_Old)
{txt}(2,000 differences between {bf:FCSCat28} and {bf:FCS_4pt_CARI_Old})

{com}.         gen CARI_FES_Raw_Old = (FCS_4pt_CARI_Old + CC_FES_Cat)/2
{txt}
{com}.         gen CARI_FES_Cat_Old = round(CARI_FES_Raw_Old)
{txt}
{com}. 
. ** Vulnerability Framework with New/Standardized CARI
.         gen HH_Vul              = (CARI_FES_Cat == 3 | CARI_FES_Cat == 4)
{txt}
{com}.         gen HH_Vul_Old  = (CARI_FES_Cat_Old == 3 | CARI_FES_Cat_Old == 4)
{txt}
{com}.         gen HH_Vul_ECMEN= (CARI_ECMEN_Cat == 3 | CARI_ECMEN_Cat == 4)
{txt}
{com}.         
. ********************************************************************************
. *                                                       PART 2: Label Variables and Values
. ********************************************************************************        
.         
.         label val HH_Vul HH_Vul_Old HH_Vul_ECMEN yesno
{txt}
{com}.         
.         label def fs_status     1 "Food Secure"         2 "Marginally Food Secure"      ///
>                                                         3 "Moderately Food Insecure" 4 "Severely Food Insecure"
{txt}
{com}.         label val FCS_4pt_CARI FCS_4pt_CARI_Old CARI_FES_Cat CARI_FES_Cat_Old fs_status
{txt}
{com}.         
.         label def fes_l                 1 "FES: <50%"   2 "FES: 50-65%" ///
>                                                         3 "FES: 65-75%" 4 "FES: >= 75%"
{txt}
{com}.         label val Foodexp_4pt   fes_l
{txt}
{com}.         
.         label def coping_label  1 "No coping strategies used"            ///
>                                                         2 "Max engaged stress coping strategies" ///
>                                                         3 "Max engaged crisis coping strategies" ///
>                                                         4 "Max engaged emergency coping strategies"
{txt}
{com}.         label val Max_coping_behaviour coping_label
{txt}
{com}.         
