. *       iecodebook export using "${c -(}codebook{c )-}/Turkiye_Targeting_Needs_Assessment_Codebook.xlsx", replace
.         
. ********************************************************************************
. *                                               PART 2: Correct Variable Type
. *******************************************************************************/
. 
.         label def yesno 1 "Yes" 0 "No"
{txt}
{com}.         label def lcs_l 1 "Already used" 2 "Yes" 3 "No need" 4 "Not applicable"
{txt}
{com}.         
.         * categorical string to byte
. local conv_cat_var Province Camp leave_camp_to Marital_status_HHH               ///
>           working_edu_leve working_lang working_sectors
{txt}
{com}.           
. foreach var of local conv_cat_var {c -(}
{txt}  2{com}.         encode  `var', gen(`var'_b)
{txt}  3{com}.         order   `var'_b, a(`var')
{txt}  4{com}.         drop    `var'
{txt}  5{com}.         rename  `var'_b `var'
{txt}  6{com}. {c )-}
{res}{txt}
{com}. 
.         * yes no string to byte
. local conv_yesno RESPConsent arr_camp another_camp n_cert n_plac                        ///
>           mm_emp_last working_cer working_social HH_disa DisabHHMemberMed               ///
>           disabled_treatment HH_chro ChoHHMemberMed Cho_treatment HH_kiz                ///
>           child_atten separatedchild pregnant lactating other_assistance                ///
>           enco_challengers stove refrigerator washingmachine ventilator                 ///
>           heater iron vacuum tv satellite_dish computer do_phone mobile_data
{txt}
{com}. 
. foreach var of local conv_yesno {c -(}
{txt}  2{com}.         replace  `var' = "1" if `var' == "Yes"
{txt}  3{com}.         replace  `var' = "0" if `var' == "No"
{txt}  4{com}.         destring `var', replace
{txt}  5{com}.         label val `var' yesno
{txt}  6{com}. {c )-}
