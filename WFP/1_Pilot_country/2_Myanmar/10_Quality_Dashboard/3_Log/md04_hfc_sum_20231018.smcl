{com}.  
. *       Head of Household Charateristics from the Roster
.         ** Household head sex (calculated from roster: hhh_sex) 
.         gen hhh_female = (hhh_sex == 2)
{txt}
{com}.         **  Household head age (calculated from roster: hhh_age)
.         ** Household head age categories (minor <18, youth 18-30, working age 31-59, elderly >=60)
.         gen hhh_age_cat = cond(mi(hhh_age),   0,                ///
>                                           cond(hhh_age <  18, 1,                ///
>                                           cond(hhh_age <= 30, 2,                ///
>                                           cond(hhh_age <= 59, 3, 4))))
{txt}
{com}.         gen hhh_senior  = (hhh_age >= 60)
{txt}
{com}.         
.         ** Household head marital status (calculated from roster: hhh_marital_status) 
.         gen hhh_married         = (hhh_marital_status == 2) 
{txt}
{com}.         gen hhh_single          = (hhh_marital_status == 3)
{txt}
{com}.         gen hhh_divwidaway      = (hhh_marital_status == 1 | hhh_marital_status == 4 | ///
>                                                    hhh_marital_status == 5) 
{txt}
{com}.         **  Household headed by single female
.         gen hhh_single_female = (hhh_single == 1 & hhh_female == 1)
{txt}
{com}.         **  Household headed by single parent 
.         gen cat_child = (num_minor > 0) // have children
{txt}
{com}.         gen hhh_single_parent = (hhh_divwidaway == 1 & cat_child == 1)
{txt}
{com}.         
.         ** Household head education level: (calculated from roster: hhh_working_edu_leve) 
.         ** Household head education binned (literate or higher, primary or higher, secondary or higher)
.         gen hhh_illiterate = (hhh_working_edu_leve == 2)
{txt}
{com}.         gen hhh_literate   = (hhh_illiterate != 2)
{txt}
{com}.         gen hhh_primary    = inlist(hhh_working_edu_leve, 1,4,5,6,7)
{txt}
{com}.         gen hhh_secondary  = inlist(hhh_working_edu_leve, 1,5,6,7)
{txt}
{com}. ** Household head Turkish language ability (may not be useful for targeting, unless there is verification possible)
.         gen hhh_turkish    = (hhh_working_lang == 3 | hhh_working_lang == 5)    
{txt}
{com}.         // only mother tone and proficient
. 
. *       Household Size: Number of household members
.         ren HHSize hhsize
{res}{txt}
{com}.         **      Household size categories (small 1-3, medium 4-6, large 7+)
.         gen hhsize_cat = cond(mi(hhsize), 0,                    ///
>                                          cond(hhsize <= 3, 1,                   ///
>                                          cond(hhsize <= 6, 2,3)))
{txt}
{com}.                                          
.         **      Household size cutoffs (6+ members, 7+, 8+, etc.)
.         gen hhsize_6more = (hhsize >= 6)
{txt}
{com}.         gen hhsize_7more = (hhsize >= 7)
{txt}
{com}.         gen hhsize_8more = (hhsize >= 8)
{txt}
{com}.         
. *       Young children
.         **  Children under 5 (binary)
.         gen cat_child_u5         = (num_child_u5 > 0)
{txt}
{com}.         **      Two or more children under 5 (binary)
.         gen cat_child_u5more = (num_child_u5 >= 2)
{txt}
{com}.         **  Children under 2 (binary)
.         gen cat_child_u2         = (num_child_u2 > 0)
{txt}
{com}.         **      Two or more children under 2 (binary)
.         gen cat_child_u2more = (num_child_u2 >= 2)
{txt}
{com}.         
. *       School-aged children not attending school
.         ** Number of school-aged children not attending school
.         sum num_child_noschool

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
num_child_~l {c |}{res}      2,001    .3113443    .7053483          0          6
{txt}
{com}.         gen cat_child_noschool = (num_child_noschool > 0)
{txt}
{com}.         ** Sex of school-aged children not attending school     
.         sum num_boy_noschool num_girl_noschool

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
num_boy_no~l {c |}{res}      2,001    .1724138    .4730313          0          5
{txt}num_girl_n~l {c |}{res}      2,001    .1389305    .4203435          0          4
{txt}
{com}.         
. *       Number of able-bodied, working-age HH members
.         sum num_work_able

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
num_work~ble {c |}{res}      2,001    2.006997    .8960753          0          7
{txt}
{com}.         **      Households with at least one able-bodied working age member
.         gen cat_work_able         = (num_work_able > 0)
{txt}
{com}.         **      Households with two or more able-bodied working age members
.         gen cat_work_ablemore = (num_work_able >= 2)
{txt}
{com}.         **      Number of currently employed members
.         sum num_employed

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
num_employed {c |}{res}      2,001    1.034983    .7174786          0          5
{txt}
{com}.         
. * protection variables: 
.         ** Disabled (with/without medical report)
.         gen hh_disable            = (num_disable > 0)
{txt}
{com}.         ** Chronically ill (with/without medical report)
.         gen hh_chronic_ill        = (num_chronic_ill > 0)
{txt}
{com}.         ** Elderly who cannot take care of self
.         gen hh_senior_nocare  = (num_senior_nocare > 0)
{txt}
{com}.         ** separatedchild, pregnant, lactating
.         gen hh_separatedchild = (separatedchild == 1)
{txt}
{com}.         gen hh_pregnant           = (pregnant == 1)
{txt}
{com}.         gen hh_lactating          = (lactating == 1)
{txt}
{com}.         gen hh_plw                        = (hh_pregnant == 1 | hh_lactating == 1)
{txt}
{com}.         
. *       Asset 
. **  Deprivation in individual asset classes (stove, refrigerator, washing                ///
>         machine, ventilation fan, heater, iron, vacuum cleaner, TV, satellite dish, ///
>         computer/laptop/tablet)
.         
. local asset_var stove refrigerator washingmachine ventilator heater iron vacuum tv satellite_dish computer do_phone mobile_data
{txt}
{com}. 
. foreach asset of local asset_var {c -(}
{txt}  2{com}.         gen hhown_`asset'        = `asset'
{txt}  3{com}.         gen hhown_`asset'_dep = (hhown_`asset' == 0) 
{txt}  4{com}.         label var hhown_`asset'                 "Household owns `asset'"
{txt}  5{com}.         label var hhown_`asset'_dep     "Household doesn't own `asset'"
{txt}  6{com}.         label val hhown_`asset' hhown_`asset'_dep yesno
{txt}  7{com}. {c )-}
{txt}
{com}. 
. **      Basic Asset Deprivation Index
.         gen num_basic_asset = stove + refrigerator + washingmachine + heater + tv + satellite_dish
{txt}
{com}.         
.         gen hh_basic_asset_dep_2more = (num_basic_asset <= 4)
{txt}
{com}.         gen hh_basic_asset_dep_3more = (num_basic_asset <= 3)
{txt}
{com}.         
.         ******** Capability-based Indicators for Self-Reliance Profiling ******
.         
. *       Household has at least one working-age, able-bodied adult 
.         gen hh_work_able         = (num_work_able > 0)
{txt}
{com}.         ** HH has two or more working-age, able-bodied adults
.         gen hh_work_ablemore = (num_work_able >= 2)
{txt}
{com}. *       HH has at least one working-age, able-bodied adult male
.         gen hh_work_able_male     = (num_work_able_male > 0)
{txt}
{com}.         ** HH has two more working-age, able-bodied males
.         gen hh_work_able_malemore = (num_work_able_male >= 2)
{txt}
{com}. *       HH has at least one member with high school or higher education
.         gen hh_edu_secondary      = (num_edu_secondary > 0)
{txt}
{com}.         ** HH has two or more members with at least high school education
.         gen hh_edu_secondarymore  = (num_edu_secondary >= 2)
{txt}
{com}. *       HH has at least one member with expertise or certifications other than formal education
.         gen hh_certification = (num_certification > 0)
{txt}
{com}. *       HH has members with expertise and certifications in specific sectors (agriculture, manufacturing, textiles, health, construction, other)
.         gen hh_cert_ag     = (num_cert_ag > 0) 
{txt}
{com}.         gen hh_cert_manu   = (num_cert_manu > 0) 
{txt}
{com}.         gen hh_cert_tex    = (num_cert_tex > 0) 
{txt}
{com}.         gen hh_cert_health = (num_cert_health > 0) 
{txt}
{com}.         gen hh_cert_const  = (num_cert_const > 0) 
{txt}
{com}.         gen hh_cert_oth    = (num_cert_oth > 0)     
{txt}
{com}. *       HH has at least one able-bodied, working age member with at least medium level knowledge of Turkish (conversational)
.         gen hh_work_able_turkish = (num_work_able_turkish > 0)
{txt}
{com}. *       HH has at least one member who works in a field in which they have certification or specialized knowledge
.         gen hh_work_cert = (num_work_cert > 0)
{txt}
{com}. *       HH has at least one member who has regular, full-time work
.         gen hh_work_full = (num_work_full > 0)
{txt}
{com}. *       HH has at least one member who has been working in the same sector for 1 or more years
.         gen hh_work_1moreyear = (num_work_1moreyear > 0)
{txt}
{com}.         
.         ******************* Other Potential Targeting indicators *************
. 
.         * Dependancy ratio
.         gen     dependency_ratio = num_dependent/num_nondependent
{txt}(67 missing values generated)

{com}.         sum     dependency_ratio

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
dependency~o {c |}{res}      1,934    1.501941     .960622          0          6
{txt}
{com}.         replace dependency_ratio = `r(max)' if mi(dependency_ratio)
{txt}(67 real changes made)

{com}.                                         
.         gen     dep_ratio_cat = 0
{txt}
{com}.         replace dep_ratio_cat = 1 if dependency_ratio <= 1
{txt}(783 real changes made)

{com}.         replace dep_ratio_cat = 2 if dependency_ratio >  1       & dependency_ratio <= 1.5
{txt}(415 real changes made)

{com}.         replace dep_ratio_cat = 3 if dependency_ratio >  1.5 & dependency_ratio <= 2.5
{txt}(530 real changes made)

{com}.         replace dep_ratio_cat = 4 if dependency_ratio >  2.5
{txt}(273 real changes made)

{com}. 
.         gen dep_ratio_1_5more   = (dependency_ratio >= 1.5)
{txt}
{com}.         gen     dep_ratio_2                     = (dependency_ratio >  2)
{txt}
{com}.         gen dep_ratio_2more     = (dependency_ratio >= 2)
{txt}
{com}.         
.         ** Female/Male Ratio
.         gen femalemale_ratio       = num_female/num_male
{txt}(86 missing values generated)

{com}.         sum femalemale_ratio

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
femalemale~o {c |}{res}      1,915     1.19814    .9430928          0          7
{txt}
{com}.         replace femalemale_ratio   = `r(max)' if mi(femalemale_ratio)
{txt}(86 real changes made)

{com}.         gen femalemale_ratio_1_5   = (femalemale_ratio >= 1.5)
{txt}
{com}.         
.         ******************* targeting for C-ESSN and ESSN programmes  *************
.         
. *       C-ESSN criteria
.         gen eligible_CESSN = (hhh_single_parent == 1 | hhh_senior == 1 | ///
>                                                   hh_disable == 1)
{txt}
{com}. *       ESSN criteria
.         ** Households who are NOT eligible for C-ESSN and;
.         gen ineligible_CESSN = (eligible_CESSN == 0)
{txt}
{com}.         ** Households with at least one able-bodied, working-age adult male who ///
>            have a "gender-adjusted dependency ratio" of 1.5 or greater – G-A DR ///
>            = (Number of members 0-17 + Number of members 60+) / Number of               ///
>            able-bodied male members age 18-59, or;
.         gen gender_dep_ratio = num_dependent/num_work_able_male
{txt}(420 missing values generated)

{com}.         sum gender_dep_ratio

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
gender_dep~o {c |}{res}      1,581    2.912555    1.789771          0         10
{txt}
{com}.         replace gender_dep_ratio   = `r(max)' if mi(gender_dep_ratio)
{txt}(420 real changes made)

{com}.         gen gender_dep_ratio_1_5   = (gender_dep_ratio >= 1.5)
{txt}
{com}.         gen hh_work_gender_dep_1_5 = (hh_work_able_male == 1 & gender_dep_ratio_1_5 == 1)
{txt}
{com}.         ** Households with no able-bodied, working-age adult male members who have ///
>            both 6 or fewer members and 2 or fewer able-bodied, working-age female ///
>            members (18-59 years);
.         gen num_work_able_female = num_work_able - num_work_able_male
{txt}
{com}.         gen hh_work_male_female  = (num_work_able_male == 0 & hhsize <= 6 & ///
>                                                                 num_work_able_female <= 2)
{txt}
{com}.         ** eligible_ESSN
.         gen eligible_ESSN = (ineligible_CESSN == 1) &                           ///
>                                                 (hh_work_gender_dep_1_5 == 1 |                  ///
>                                                  hh_work_male_female    == 1)
{txt}
{com}.                                                  
.         *********************** Plans outside of camps ************************
. 
.         * Plans outside of camps – responses to questions related to leaving or remaining in the camps - too few responses
.         
. *       HH planning to leave the camp: 57
.         gen hh_leave_camp = (leave_camp == 2)
{txt}
{com}. *       HH who plan to return to home country: 1
.         gen hh_return_home = (leave_camp_to == 1)
{txt}
{com}. *       HH who plan to leave for another country
.         gen hh_go_other_country = (leave_camp_to == 4)
{txt}
{com}. *       HH who plan to stay in Turkiye (same or different province)
.         gen hh_stay_tur = (leave_camp == 1) | (leave_camp == 2 & (leave_camp_to == 2 | leave_camp_to == 3))
{txt}
{com}. *       HH mentioning challenges about leaving the camps (variable: obst_camps)
. *       HH mentioning support required to leave the camps (variable: faci_camp)
. 
. ********************************************************************************
. *                                               PART 3: Label Variables and Values
. ********************************************************************************
. 
.         label val hhh_female hhh_senior hhh_married hhh_single hhh_divwidaway           ///
>                   hhh_single_female cat_child hhh_single_parent hhh_illiterate                  ///
>                   hhh_literate hhh_primary hhh_secondary hhh_turkish hhsize_6more               ///
>                   hhsize_7more hhsize_8more cat_child_u5 cat_child_u5more cat_child_u2  ///
>                   cat_child_u2more cat_child_noschool cat_work_able cat_work_ablemore   ///
>                   hh_disable hh_chronic_ill hh_senior_nocare hh_separatedchild                  ///
>                   hh_pregnant hh_lactating hh_plw hh_basic_asset_dep_2more                              ///
>                   hh_basic_asset_dep_3more hh_work_able hh_work_ablemore                                ///
>                   hh_work_able_male hh_work_able_malemore hh_edu_secondary                              ///
>                   hh_edu_secondarymore hh_certification hh_cert_ag hh_cert_manu                 ///
>                   hh_cert_tex hh_cert_health hh_cert_const hh_cert_oth                                  ///
>                   hh_work_able_turkish hh_work_cert hh_work_full hh_work_1moreyear              ///
>                   dep_ratio_1_5more dep_ratio_2 dep_ratio_2more femalemale_ratio_1_5    ///
>                   eligible_CESSN ineligible_CESSN gender_dep_ratio_1_5                                  ///
>                   hh_work_gender_dep_1_5 hh_work_male_female eligible_ESSN                              ///
>                   hh_leave_camp hh_return_home hh_go_other_country hh_stay_tur yesno
{txt}
{com}.         
.         label def timeturk_l 1 "Up to 1 year"   2 "2-5 years"   ///
>                                                  3 "6-8 years"          4 "9+ years"
{txt}
{com}.         label val time_in_turkey_cat time_in_thiscamp_cat timeturk_l 
{txt}
