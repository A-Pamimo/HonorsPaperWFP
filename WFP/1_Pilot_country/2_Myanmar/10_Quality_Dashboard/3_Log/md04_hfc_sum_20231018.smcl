> *                                                                                                                                                          *
> ********************************************************************************
> 
>         ** OUTLINE:             PART 1: Set Codebook Template
>                                         PART 2: Correct Variable Type
>                         
>         ** NOTES:               Need to 
>                                         
>                                         
> ********************************************************************************
> *                                                       PART 1: Set Codebook Template                                      *
> *******************************************************************************/
. 
. * load dataset
.         * ------------
.         use "${c -(}data_raw{c )-}/Head_file_data_28.09.dta", clear
{txt}
{com}.         compress
  {txt}variable {bf}{res}Date{sf}{txt} was {bf}{res}long{sf}{txt} now {bf}{res}int{sf}
  {txt}variable {bf}{res}___submission_time{sf}{txt} was {bf}{res}long{sf}{txt} now {bf}{res}int{sf}
  {txt}variable {bf}{res}___submission_times{sf}{txt} was {bf}{res}long{sf}{txt} now {bf}{res}byte{sf}
