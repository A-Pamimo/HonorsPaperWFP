{txt}  09002CECF {c |}{res}          1       50.00      100.00
{txt}{hline 12}{c +}{hline 35}
      Total {c |}{res}          2      100.00
{txt}
{com}.         
. ** Error in Roster: 
.         *  The head is not married but has one or more spouses
.         gen   R_Err_Married = HHHSingle == 1 & R_HH_HasSpouse == 1
{txt}
{com}.         *  The head was never married but has a son/daughter
.         gen   R_Err_Child   = HHHSingle == 1 & R_HH_HasChild  == 1
{txt}
{com}.         order R_Err_Married R_Err_Child, a(R_HH_HasChild)
{txt}
{com}. 
. **# Lorenzo to add outcomes for Health/MMDI releted variables
.         gen HHDisable = (MDDIHHDisabledNb > 0)
{txt}
