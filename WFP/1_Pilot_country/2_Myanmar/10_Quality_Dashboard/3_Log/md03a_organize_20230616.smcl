{com}.         
.         * load dataset
.         use "${c -(}d_temp{c )-}/Myanmar_F2F_Household_Prep_`cdate'.dta", clear 
{txt}
{com}.         
.         * keep if sampleYN == 1 
. 
.         ** rename ___variables
.         ren ___* Sys_*
{res}{txt}
{com}.         order R_*, a(RepeatPID_count)
{txt}
{com}.         
.         * survey duration variable
.         destring Sys_duration, replace
{txt}Sys_duration: all characters numeric; {res}replaced {txt}as {res}long
{txt}
{com}.         gen     Duration_Min = Sys_duration/60
{txt}
{com}.         
.         * survey modality
.         gen     Modality        = 1                      // f2f
{txt}
{com}.         
.         * form version long vs. short
.         gen     ID_Length = length(HHID)
{txt}
{com}.         
.         gen             Form = 1 if ID_Length == 10  // Long
{txt}(197 missing values generated)

{com}.         replace Form = 2 if ID_Length == 9   // Short
{txt}(196 real changes made)

{com}. 
. ********************************************************************************
. *                                               PART 2: Create and Define Variables
. ********************************************************************************
. 
. ** Demongraphics and basic respondents/household information
.         gen RESPHHH     = (R_RESPRelationHHH == 100)
{txt}
{com}.         gen RESPFemale  = (R_RESPSex             == 0)
{txt}
{com}.         gen HHDisplaced = (HHStatus              == 2)
{txt}
{com}.         gen HHHSingle   = (RESPStatus            == 100)
{txt}
{com}.         gen HHHMarried  = (RESPStatus            == 300)
{txt}
{com}.         
. *       assert R_Num_Household == HHSize
.         tab HHID if R_Num_Household != HHSize

         {txt}i. {c |}
  Household {c |}
         ID {c |}      Freq.     Percent        Cum.
