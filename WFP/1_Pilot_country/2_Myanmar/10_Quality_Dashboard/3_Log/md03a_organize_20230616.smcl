{com}.         * Total monthly non-food
.         gen HHExpNFTotal_1M = HHExpNFTotal_Purch_MN_1M + HHExpNFTotal_GiftAid_MN_1M + ///
>                                                   HHExp_NonFood_Own_MN_1M
{txt}
{com}.         
.         **** TOTAL **** 
.         gen HHExpTotal = HHExpFoodTotal_1M + HHExpNFTotal_1M
{txt}
{com}.         gen PCExpTotal = HHExpTotal/HHSize
{txt}
{com}. 
.         * FES // household level
.         gen     FES = HHExpFoodTotal_1M/HHExpTotal * 100
{txt}(1 missing value generated)

{com}.         count if HHExpFoodTotal_1M == 0 // 3 missing
  {res}1
{txt}
{com}.         
.         replace FES = 0          if mi(FES)
{txt}(1 real change made)

{com}.         
.         gen byte FES_Cat = 1 if FES <  50
{txt}(347 missing values generated)

{com}.         replace  FES_Cat = 2 if FES >= 50 & FES < 65
{txt}(107 real changes made)

{com}.         replace  FES_Cat = 3 if FES >= 65 & FES < 75
{txt}(109 real changes made)

{com}.         replace  FES_Cat = 4 if FES >= 75
{txt}(131 real changes made)

{com}.         
.         ** Income
.         gl income HHHOccupation HHInc_PCT HHIncNb HHIncFirst_SRi HHIncFirst_oth ///
>                           HHIncF_PCT HHInc017_PCT HHIncChg
{txt}
{com}.         
. foreach var of global income {c -(}
{txt}  2{com}.         replace `var' = `var'_S if Form == 2 & mi(`var')
{txt}  3{com}. {c )-}
{txt}(195 real changes made)
(195 real changes made)
(195 real changes made)
(181 real changes made)
(11 real changes made)
(195 real changes made)
(178 real changes made)
(195 real changes made)

{com}.         gen CARI_Inc = .
{txt}(396 missing values generated)

{com}.         replace CARI_Inc = 1 if inlist(HHIncFirst_SRi, 1, 2, 5, 12, 13, 15) & inlist(HHIncChg, 0, 1, 5)
{txt}(68 real changes made)

{com}.         replace CARI_Inc = 2 if inlist(HHIncFirst_SRi, 1, 2, 5, 12, 13, 15) & inlist(HHIncChg, 2, 3, 4)
{txt}(46 real changes made)

{com}.         replace CARI_Inc = 2 if inlist(HHIncFirst_SRi, 3, 4, 6, 11) & inlist(HHIncChg, 0, 1, 5)
{txt}(89 real changes made)

{com}.         replace CARI_Inc = 3 if inlist(HHIncFirst_SRi, 3, 4, 6, 11) & inlist(HHIncChg, 2, 3, 4)
{txt}(122 real changes made)

{com}.         replace CARI_Inc = 4 if HHIncNb == 0 | inlist(HHIncFirst_SRi, 7, 8, 9, 10)
{txt}(42 real changes made)

{com}.         replace CARI_Inc = 5 if HHIncFirst_SRi == 999
{txt}(24 real changes made)

{com}.         * Recode missing values
.         replace CARI_Inc = . if CARI_Inc == 5
{txt}(24 real changes made, 24 to missing)

{com}.         
. ** Outcome: [CARI] COMBINING CURRENT STATUS AND COPING CAPACITY
.         recode  FCSCat28 (1 = 4) (2 = 3) (3 = 1), gen(FCS_4pt_CARI)
{txt}(396 differences between {bf:FCSCat28} and {bf:FCS_4pt_CARI})

{com}.         replace FCS_4pt_CARI = 2 if FCSCat28 == 3 & rCSI >= 4
{txt}(45 real changes made)

{com}.         
.         gen CC_FES_Cat   = (FES_Cat + LCS_Cat)/2        // no round here
{txt}
{com}.         gen CARI_FES_Raw = (FCS_4pt_CARI + CC_FES_Cat)/2
{txt}
{com}.         gen CARI_FES_Cat = round(CARI_FES_Raw)
{txt}
{com}.         gen HH_Vul_FES   = (CARI_FES_Cat == 3 | CARI_FES_Cat == 4)
{txt}
{com}. 
.         gen CC_Inc_Cat   = (CARI_Inc + LCS_Cat)/2       // no round here
{txt}(29 missing values generated)

{com}.         gen CARI_Inc_Raw = (FCS_4pt_CARI + CC_Inc_Cat)/2
{txt}(29 missing values generated)

{com}.         gen CARI_Inc_Cat = round(CARI_Inc_Raw)
{txt}(29 missing values generated)

{com}.         gen HH_Vul_Income  = (CARI_Inc_Cat == 3 | CARI_Inc_Cat == 4)
{txt}
{com}.         
.         // Standard MDDW method - SNF home group will be grains
.         gen MDD_Staples          = (PWMDDWStapCer == 1 |  PWMDDWStapRoo == 1 | PWMDDWSnf == 1) 
{txt}
{com}.         gen MDD_Pulses           = (PWMDDWPulse == 1)
{txt}
{com}.         gen MDD_NutsSeeds        = (PWMDDWNuts == 1)
{txt}
{com}.         gen MDD_Dairies          = (PWMDDWDairy == 1 | PWMDDWMilk == 1)
{txt}
{com}.         gen MDD_MeatFish         = (PWMDDWPrMeatO == 1 | PWMDDWPrMeatF == 1 | PWMDDWPrMeatPro == 1 | ///
>                                                         PWMDDWPrMeatWhite == 1 |  PWMDDWPrFish == 1)
{txt}
{com}.         gen MDD_Eggs             = (PWMDDWPrEgg == 1)
{txt}
{com}.         gen MDD_LeafGVeg         = (PWMDDWVegGre == 1)
{txt}
{com}.         gen MDD_VitA             = (PWMDDWVegOrg == 1 | PWMDDWFruitOrg == 1)
{txt}
{com}.     gen MDD_OtherVeg     = (PWMDDWVegOth == 1) 
{txt}
{com}.     gen MDD_OtherFruits  = (PWMDDWFruitOth == 1)
{txt}
{com}.         gen MDD_Index            = MDD_Staples + MDD_Pulses + MDD_NutsSeeds + MDD_Dairies + ///
>                                                    MDD_MeatFish + MDD_Eggs + MDD_LeafGVeg + MDD_VitA +          ///
>                                                    MDD_OtherVeg + MDD_OtherFruits
{txt}
{com}.         gen MDD_Index_5 = (MDD_Index >= 5)
{txt}
{com}.         
