{com}. do "/var/folders/p4/tpy5_7mn71sbyj0zqp9zpb5c0000gn/T//SD80414.000000"
{txt}
{com}.         gen Gap_ref = PCExp_ECMEN<MEB & (CARI_ECMEN==3 | CARI_ECMEN==4)
{txt}
{com}.         label var Gap_ref "Gap analysis cohort (below MEB and food insecure)"
{txt}
{com}.         label define  cohort 1 "Part of cohort"  0 "Not part of cohort"
{txt}
{com}.         label val Gap_ref cohort
{txt}
{com}. 
{txt}end of do-file

