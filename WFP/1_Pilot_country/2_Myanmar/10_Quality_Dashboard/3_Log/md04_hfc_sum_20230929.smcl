{com}. use "/Users/nicolewu/Library/CloudStorage/OneDrive-WorldFoodProgramme/4_Gap_Analysis/99_Example/1_Data/Gap_Analysis_Sample.dta"

. sum PCExp_ECMEN_inclAsst
