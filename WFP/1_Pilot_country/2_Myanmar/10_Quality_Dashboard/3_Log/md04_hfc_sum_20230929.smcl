. do "/var/folders/p4/tpy5_7mn71sbyj0zqp9zpb5c0000gn/T//SD80414.000000"
{txt}
{com}. 
. *** Step 1 - Identifying the cost of essential needs
. 
. /* A MEB is already available in the dataset, expressed in per capita monthly 
> term, and differentiated by groups of household size to account for household 
> economies of scale      */
. 
. *** Step 2 - Computing the household economic capacity 
. /* The computation of the household economic capacity should follow the 
> methodology used for the ECMEN indicator (version excluding assistance).        */
. 
.         ** Sum food expenditures, value of consumed food from own-production, and non-food expenditures
.         egen PCExp_ECMEN = rowtotal(PC_HHExp_Food_Purch_MN_1M                   ///
>                                                             PC_HHExp_Food_Own_MN_1M                     ///
>                                                             PC_HHExpNFTotal_Purch_MN_1M), missing 
{txt}
{com}.         // will be missing if all sub-aggregates are missing
.         
.         label var PCExp_ECMEN "Household Economic Capacity per capita - monthly"
{txt}
{com}. 
.         ** Deduct the value of cash assistance received from WFP and partner humanitarian organizations
.         replace PCExp_ECMEN = PCExp_ECMEN-PC_HHAsstCBTRec_Cons_1M if    ///
>                                                   !mi(PC_HHAsstCBTRec_Cons_1M)
{txt}(205 real changes made)

{com}.         replace PCExp_ECMEN=0 if PCExp_ECMEN < 0        // set negative values to zero
{txt}(0 real changes made)

{com}. 
. *** Step 3 - Identifying the gap analysis cohort
. /* In this example the gap analysis group is made of the households with economic 
> capacity below the MEB and who are moderately or severely food insecure based on
> CARI    */
. 
.         ** create a variable to identify the cohort
.         gen Gap_ref = PCExp_ECMEN < MEB & (CARI_ECMEN == 3 | CARI_ECMEN == 4)
{txt}
{com}.         
.         label var Gap_ref "Gap analysis cohort (below MEB and food insecure)"
{txt}
{com}.         label def cohort        1 "Part of cohort"  0 "Not part of cohort"
{txt}
{com}.         label val Gap_ref cohort
{txt}
{com}. 
. *** Step 4 - Estimating the gap
. 
.         ** Compute per capita gap for each household
.         gen PCGap= MEB - PCExp_ECMEN if PCExp_ECMEN < MEB 
{txt}(267 missing values generated)

{com}.         // the gap is defined only for hh with economic capacity below the MEB
.         
.         label var PCGap "Gap, per capita, monthly"
{txt}
{com}. 
.         ** Compute average gap for the gap analysis cohort and save to a variable
.         sum PCGap if Gap_ref == 1 // compute average

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
{space 7}PCGap {c |}{res}        497    8308.338    4066.742   107.6445      20418
{txt}
{com}.         gen PCGap_avg = `r(mean)' if Gap_ref == 1 
