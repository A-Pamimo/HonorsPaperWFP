.         balancetable (mean if Modality_Bin == 0 & Country == 1 & Err_ExpNF == 0)  ///
>                                  (mean if Modality_Bin == 1 & Country == 1 & Err_ExpNF == 0)  ///
>                                  (diff    Modality_Bin     if Country == 1 & Err_ExpNF == 0)  ///
