{com}.         
. *       isid HHID 
.         ** temp
.         * replace HHID = HHID_manual if mi(HHID)                // 19 this is temporary
.         * drop if sampleYN == 0
.         
.         ** create one consent variable 
.         duplicates tag HHID, generate(Dup)

{p 0 4}{txt}Duplicates in terms of {res} HHID{p_end}
{txt}
{com}.         
.         bysort HHID: egen Survey_Outcome = max(ConsentYN) if Dup >= 1
{txt}(971 missing values generated)

{com}.         replace Survey_Outcome = ConsentYN if Dup == 0
{txt}(971 real changes made)

{com}.         
.         gen HH_Final = (ConsentYN == Survey_Outcome)
{txt}
{com}.         egen HH_TAG = tag(HHID) if HH_Final == 1
{txt}
{com}.         
.         replace Survey_Outcome = . if HH_TAG == 0
{txt}(11 real changes made, 11 to missing)

{com}.         label val Survey_Outcome ConsentYN
{txt}
{com}. 
.         bysort HHID: egen Consent = max(ConsentYN) 
{txt}
{com}.         label val Consent ConsentYN
{txt}
{com}.         
