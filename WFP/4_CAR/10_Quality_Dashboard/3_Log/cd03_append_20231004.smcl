{com}. /*      dtable i.Admin1Name i.Admin2Name i.Admin3Name i.Admin5Name,                     ///
>                    by(phone_ownership) title(CAR rCARI Validation Study - Summary of Listed Sample ADMIN Distribution)  ///
>                    export(${c -(}sample{c )-}/CAR_rCARI_Listed_Sample_ADMIN.docx, replace)
> */        
. 
. ********************************************************************************
. *                                               PART 3:  RUN RANDOMIZATION - Own Phone                         *
. ********************************************************************************        
.         
.         * keep if phone_ownership == 1
.         
.     * Assign sampled household with phone to F2F and Remote 
.         sort Admin5Name, stable
{txt}
{com}.         by Admin5Name: gen  Modality_RandomNum_P = uniform()                      ///
>                                    if phone_ownership == 1
{txt}(1,452 missing values generated)

{com}.         by Admin5Name: egen Modality_Order_P = rank(Modality_RandomNum_P) ///
>                                    if phone_ownership == 1
{txt}(1,452 missing values generated)

{com}.         by Admin5Name: egen TotSample_P  = max(Modality_Order_P)                  ///
>                                    if phone_ownership == 1
{txt}(1,452 missing values generated)

{com}.         
.     gen    Modality_Type_P = (Modality_Order_P <= TotSample_P/2)          ///
>                    if phone_ownership == 1 
{txt}(1,452 missing values generated)

{com}.         
.         ********* Form Length
.         sort Admin5Name Modality_Type_P, stable
{txt}
{com}.         by Admin5Name Modality_Type_P: gen  Length_RandomNum_P = uniform() ///
>                                                                    if !mi(Modality_Type_P)
{txt}(1,452 missing values generated)

{com}.         by Admin5Name Modality_Type_P: egen Length_Order_P = rank(Length_RandomNum_P) ///
>                                                                    if !mi(Modality_Type_P)
{txt}(1,452 missing values generated)

{com}.         by Admin5Name Modality_Type_P: egen TotModality_P  = max(Length_Order_P) ///
>                                                                    if phone_ownership == 1
{txt}(1,452 missing values generated)

{com}.         
.         gen    Length_Type_P = (Length_Order_P <= TotModality_P/2)                         ///
>                    if phone_ownership == 1
{txt}(1,452 missing values generated)

{com}.         
.         ** check in Own Phone group, assigned to Remote but without coverage
.         count if Modality_Type_P == 1 & mobile_coverage == 0 // 68
  {res}68
{txt}
{com}. 
