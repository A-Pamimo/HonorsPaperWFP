      Total {c |}{res}      2,500      100.00
{txt}
{com}. /*      dtable i.Admin1Name i.Admin2Name i.Admin3Name i.Admin5Name,                     ///
>                    by(phone_ownership) title(CAR rCARI Validation Study - Summary of Listed Sample ADMIN Distribution)  ///
>                    export(${c -(}sample{c )-}/CAR_rCARI_Listed_Sample_ADMIN.docx, replace)
> */        
. 
. ********************************************************************************
. *                                               PART 3:  RUN RANDOMIZATION - Own Phone                         *
. ********************************************************************************        
.         
.         * keep if phone_ownership == 1
.         
.     * Assign sampled household with phone to F2F and Remote 
.         sort Admin5Name, stable
{txt}
{com}.         by Admin5Name: gen  Modality_RandomNum_P = uniform()                      ///
>                                    if phone_ownership == 1
{txt}(1,872 missing values generated)

{com}.         by Admin5Name: egen Modality_Order_P = rank(Modality_RandomNum_P) ///
>                                    if phone_ownership == 1
{txt}(1,872 missing values generated)

{com}.         by Admin5Name: egen TotSample_P  = max(Modality_Order_P)                  ///
>                                    if phone_ownership == 1
{txt}(1,872 missing values generated)

{com}.         
.     gen    Modality_Type_P = (Modality_Order_P <= TotSample_P/2)          ///
>                    if phone_ownership == 1 
{txt}(1,872 missing values generated)

{com}.         
.         ********* Form Length
.         sort Admin5Name Modality_Type_P, stable
{txt}
{com}.         by Admin5Name Modality_Type_P: gen  Length_RandomNum_P = uniform() ///
>                                                                    if !mi(Modality_Type_P)
{txt}(1,872 missing values generated)

{com}.         by Admin5Name Modality_Type_P: egen Length_Order_P = rank(Length_RandomNum_P) ///
>                                                                    if !mi(Modality_Type_P)
{txt}(1,872 missing values generated)

{com}.         by Admin5Name Modality_Type_P: egen TotModality_P  = max(Length_Order_P) ///
>                                                                    if phone_ownership == 1
{txt}(1,872 missing values generated)

{com}.         
.         gen    Length_Type_P = (Length_Order_P <= TotModality_P/2)                         ///
>                    if phone_ownership == 1
{txt}(1,872 missing values generated)

{com}.         
.         ** check in Own Phone group, assigned to Remote but without coverage
.         count if Modality_Type_P == 1 & mobile_coverage == 0 // 68
  {res}68
{txt}
{com}. 
. ********************************************************************************
. *                                               PART 4:  RUN RANDOMIZATION - No Phone                          *
. ********************************************************************************        
.         
.         * keep if phone_ownership == 0
.         sort Admin5Name, stable
{txt}
{com}.     * Assign sampled household with phone to F2F and Remote 
.         by Admin5Name: gen  Modality_RandomNum_NP = uniform()                           ///
>                                    if phone_ownership == 0
{txt}(628 missing values generated)

{com}.         by Admin5Name: egen Modality_Order_NP = rank(Modality_RandomNum_NP) ///
>                                    if phone_ownership == 0
{txt}(628 missing values generated)

{com}.         by Admin5Name: egen TotSample_NP  = max(Modality_Order_NP)                      ///
>                                    if phone_ownership == 0
{txt}(628 missing values generated)

{com}.         
.     gen    Modality_Type_NP = (Modality_Order_NP <= TotSample_NP/2)         ///
>                    if phone_ownership == 0
{txt}(628 missing values generated)

{com}.         
.         ********* Form Length 
.         sort Admin5Name Modality_Type_NP, stable
{txt}
{com}.         by Admin5Name Modality_Type_NP: gen  Length_RandomNum_NP = uniform()    ///
>                                                                         if !mi(Modality_Type_NP)
{txt}(628 missing values generated)

{com}.         by Admin5Name Modality_Type_NP: egen Length_Order_NP = rank(Length_RandomNum_NP) ///
>                                                                         if !mi(Modality_Type_NP)
{txt}(628 missing values generated)

{com}.         by Admin5Name Modality_Type_NP: egen TotModality_NP  = max(Length_Order_NP) ///
>                                                                         if phone_ownership == 0
{txt}(628 missing values generated)

{com}.         
.         gen    Length_Type_NP = (Length_Order_NP <= TotModality_NP/2)                      ///
>                    if phone_ownership == 0
{txt}(628 missing values generated)

{com}.         
.         ** check in Own Phone group, assigned to Remote but without coverage
.         count if Modality_Type_NP == 1 & mobile_coverage == 0 // 213
  {res}213
{txt}
{com}.         gen   FLAG_Remote_NoPhone_NoCoverage = (Modality_Type_NP == 1 & mobile_coverage == 0)
{txt}
{com}.         
.         count if Modality_Type_NP == 1 & mobile_coverage == 1 // 715
  {res}715
{txt}
{com}. 
. ********************************************************************************
. *                                                       PART 5:  Label Variables                                           *
. ********************************************************************************        
.         
.         gen               Modality_Type = Modality_Type_P  if  phone_ownership == 1
{txt}(1,872 missing values generated)

{com}.         replace   Modality_Type = Modality_Type_NP if  phone_ownership == 0
{txt}(1,872 real changes made)

{com}.         
.         replace   Modality_Type = . if FLAG_Remote_NoPhone_NoCoverage == 1
{txt}(213 real changes made, 213 to missing)

{com}.         
.         gen       Length_Type   = Length_Type_P    if  phone_ownership == 1
{txt}(1,872 missing values generated)

{com}.         replace   Length_Type   = Length_Type_NP   if  phone_ownership == 0
{txt}(1,872 real changes made)

{com}.         replace   Length_Type   = . if FLAG_Remote_NoPhone_NoCoverage == 1
{txt}(213 real changes made, 213 to missing)

{com}.         
.         label var Modality_Type                 "Modality Assignment: Type"
{txt}
{com}.         label var Length_Type                   "Form Length Assignment: Type"
{txt}
{com}.                 
.         label def Modality_L                    1 "Remote"        0 "Face-to-Face"
{txt}
{com}.         label val Modality_Type                 Modality_L
{txt}
{com}.         
.         label def Length_L                              1 "Long Form" 0 "Short Form"
{txt}
{com}.         label val Length_Type                   Length_L
{txt}
{com}.         
.         sort Modality_Type Length_Type, stable
{txt}
