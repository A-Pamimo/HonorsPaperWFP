{com}.         
. ** Initial Balance Test on Listing Charateristics
.         
.         gen HHHResp                     = (relationship == 1)
{txt}
{com}.         gen HHHRespSpouse       = (relationship == 2)
{txt}
{com}.         gen HHDisplaced         = (hh_status    == 2)
{txt}
{com}.         gen HHHFemale           = (hh_head_sex  == 0)
{txt}
{com}.         gen HHHMarried          = (hh_head_marital == 1)
{txt}
{com}.         
.         gen     HHCrowding      = hh_size/area_house
{txt}(74 missing values generated)

{com}.         sum     HHCrowding

{txt}    Variable {c |}        Obs        Mean    Std. dev.       Min        Max
{hline 13}{c +}{hline 57}
{space 2}HHCrowding {c |}{res}      2,426    3.298289    1.779506        .25         15
{txt}
{com}.         replace HHCrowding  = `r(max)' if mi(HHCrowding)
{txt}(74 real changes made)

{com}.         
. ** Randomly select 300 from the 737 non phone owner
.         sort ___index, stable
{txt}
{com}.         gen  Select_RandomNum = uniform() if phone_ownership == 0 & ///
>                                                                                  mobile_coverage == 1 & ///
>                                                                                  Modality_Type == 0
{txt}(1,763 missing values generated)

{com}.         egen Select_Order         = rank(Select_RandomNum)                              ///
>                                                                           if phone_ownership == 0 & ///
>                                                                                  mobile_coverage == 1 & ///
>                                                                                  Modality_Type == 0
{txt}(1,763 missing values generated)

{com}.                                                                                  
.         gen  Select_Yes           = (Select_Order <= 300) if phone_ownership == 0 & ///
>                                                                                  mobile_coverage == 1 & ///
>                                                                                  Modality_Type == 0
{txt}(1,763 missing values generated)

{com}.         
.         gen     Random_Comparison = 1 if Select_Yes == 1                // F2F Random Partial
{txt}(2,200 missing values generated)

{com}.         replace Random_Comparison = 0 if Phone_Assignment == 1  // Remote Gave Phone 
{txt}(300 real changes made)

