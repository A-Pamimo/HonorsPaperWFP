. egen HHExp_NonFood_Purch_MN_6M = rowtotal(HHExpNFMedServ_Purch_MN_6M                            ///
>          HHExpNFMedGood_Purch_MN_6M HHExpNFCloth_Purch_MN_6M HHExpNFEduFee_Purch_MN_6M  ///
>          HHExpNFEduGood_Purch_MN_6M HHExpNFRent_Purch_MN_6M HHExpNFHHSoft_Purch_MN_6M   ///
>          HHExpNFHHMaint_Purch_MN_6M HHExpNFMedServGood_Purch_MN_6M_S                                    ///
>          HHExpNFCloth_Purch_MN_6M_S HHExpNFEduFeeGood_Purch_MN_6M_S                                     ///
>          HHExpNFRent_Purch_MN_6M_S HHExpNFHHSoftMaint_Purch_MN_6M_S)
{txt}
{com}. 
.          * Non food expenditure gift/aid value in 6 months
. egen HHExp_NonFood_GiftAid_MN_6M = rowtotal(HHExpNFMedServ_GiftAid_MN_6M        ///
>          HHExpNFMedGood_GiftAid_MN_6M HHExpNFCloth_GiftAid_MN_6M                                ///
>          HHExpNFEduFee_GiftAid_MN_6M HHExpNFEduGood_GiftAid_MN_6M                               ///
>          HHExpNFRent_GiftAid_MN_6M HHExpNFHHSoft_GiftAid_MN_6M                                  ///
>          HHExpNFHHMaint_GiftAid_MN_6M HHExpNFMedServGood_GiftAid_MN_6M                  ///
>          HHExpNFCloth_GiftAid_MN_6M_S HHExpNFEduFeeGood_GiftAid_MN_6M_                  ///
>          HHExpNFRent_GiftAid_MN_6M_S HHExpNFHHSoftMaint_GiftAid_MN_6M)
{txt}
{com}. 
.         **** TOTAL 1 MONTH AVERAGE ****
.         * Total monthly non food expenditure in cash/credit 
.         gen HHExpNFTotal_Purch_MN_1M = HHExp_NonFood_Purch_MN_1M + (HHExp_NonFood_Purch_MN_6M/6)
{txt}
{com}.         * Total monthly non-food gift/aid value
.         gen HHExpNFTotal_GiftAid_MN_1M = HHExp_NonFood_GiftAid_MN_1M + (HHExp_NonFood_GiftAid_MN_6M/6)
{txt}
{com}.         * Total monthly non-food
.         gen HHExpNFTotal_1M = HHExpNFTotal_Purch_MN_1M + HHExpNFTotal_GiftAid_MN_1M 
{txt}
{com}.                                                 // + HHExp_NonFood_Own_MN_1M
.                 
.         **** TOTAL **** 
.         gen HHExpTotal = HHExpFoodTotal_1M + HHExpNFTotal_1M
{txt}
{com}.         gen PCExpTotal = HHExpTotal/HHSize
{txt}
{com}. 
.         * FES // household level
.         gen     FES = HHExpFoodTotal_1M/HHExpTotal
{txt}
{com}.         count if HHExpFoodTotal_1M == 0 //  missing
  {res}0
{txt}
{com}.         
.         replace FES = 0          if mi(FES)
{txt}(0 real changes made)

{com}.         
.         gen byte FES_Cat = 1 if FES <  0.5
{txt}(744 missing values generated)

{com}.         replace  FES_Cat = 2 if FES >= 0.5  & FES < 0.65
{txt}(146 real changes made)

{com}.         replace  FES_Cat = 3 if FES >= 0.65 & FES < 0.75
{txt}(129 real changes made)

{com}.         replace  FES_Cat = 4 if FES >= 0.75
{txt}(469 real changes made)

{com}. 
.         ** Income
.         gl income HHHOccupation HHInc_PCT HHIncNb HHIncFirst_SRi HHIncFirst_oth ///
>                           HHIncF_PCT HHInc017_PCT HHIncChg
{txt}
{com}.         
. foreach var of global income {c -(}
{txt}  2{com}.         replace `var' = `var'_S if Form == 2 & mi(`var')
{txt}  3{com}. {c )-}
{txt}(444 real changes made)
(435 real changes made)
(445 real changes made)
(442 real changes made)
(19 real changes made)
(445 real changes made)
(329 real changes made)
(445 real changes made)

{com}.         gen CARI_Inc = .
{txt}(860 missing values generated)

{com}.         replace CARI_Inc = 1 if inlist(HHIncFirst_SRi, 1, 2, 5, 13, 14, 15, 16) & inlist(HHIncChg, 0, 1, 5)
{txt}(350 real changes made)

{com}.         replace CARI_Inc = 2 if inlist(HHIncFirst_SRi, 1, 2, 5, 13, 14, 15, 16) & inlist(HHIncChg, 2, 3, 4)
{txt}(253 real changes made)

{com}.         replace CARI_Inc = 2 if inlist(HHIncFirst_SRi, 3, 4, 6, 12) & inlist(HHIncChg, 0, 1, 5)
{txt}(89 real changes made)

{com}.         replace CARI_Inc = 3 if inlist(HHIncFirst_SRi, 3, 4, 6, 12) & inlist(HHIncChg, 2, 3, 4)
{txt}(53 real changes made)

{com}.         replace CARI_Inc = 4 if HHIncNb == 0 | inlist(HHIncFirst_SRi, 7, 8, 9, 10, 11)
{txt}(73 real changes made)

{com}.         replace CARI_Inc = 5 if HHIncFirst_SRi == 999
{txt}(42 real changes made)

{com}.         * Recode missing values
.         replace CARI_Inc = . if CARI_Inc == 5
{txt}(42 real changes made, 42 to missing)

{com}.         
.         ** Question relevant when: ${c -(}HHIncNb{c )-} >0
.         tab HHIncFirst_SRi

  {txt}What is the main source of income for {c |}
                         the household? {c |}      Freq.     Percent        Cum.
{hline 40}{c +}{hline 35}
              Wage Labor - Professional {c |}{res}         28        3.28        3.28
{txt}                   Wage Labor - Skilled {c |}{res}         13        1.52        4.81
{txt}Wage Labor - Unskilled/Casual/Agricultu {c |}{res}         80        9.38       14.19
{txt}Wage Labor - Unskilled/Casual/non-agric {c |}{res}         29        3.40       17.58
{txt}                                Pension {c |}{res}          5        0.59       18.17
{txt}                            Remittances {c |}{res}          3        0.35       18.52
{txt}                              Aid/gifts {c |}{res}          4        0.47       18.99
{txt}         Petty trade/selling on streets {c |}{res}         62        7.27       26.26
{txt}             Small trade (own business) {c |}{res}         30        3.52       29.78
{txt}      Medium/large trade (own business) {c |}{res}          3        0.35       30.13
{txt}Small Agriculture production including  {c |}{res}        326       38.22       68.35
{txt}Medium/large agriculture production inc {c |}{res}        228       26.73       95.08
